<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}GestoPro{% endblock %}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
  {% block stylesheets %}{% endblock %}
</head>
<body>
{% if app.user %}
<div class="layout">
  {% include 'partials/_sidebar.html.twig' %}

  <div class="main">
    {% block topbar %}{% endblock %}
    <div class="content">
      {% for msg in app.flashes('success') %}
        <div class="alert alert-success">{{ msg }}</div>
      {% endfor %}
      {% for msg in app.flashes('error') %}
        <div class="alert alert-error">{{ msg }}</div>
      {% endfor %}
      {% block body %}{% endblock %}
    </div>
  </div>
</div>
{% else %}
  {% block body_public %}{% endblock %}
{% endif %}
{% block javascripts %}{% endblock %}
</body>
</html>
