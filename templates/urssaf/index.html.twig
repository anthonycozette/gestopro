{% extends 'base.html.twig' %}
{% block title %}URSSAF — GestoPro{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/urssaf.css') }}">
{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Déclarations URSSAF</h1>
    <div class="topbar-actions">
        <a href="{{ path('app_urssaf_new') }}" class="btn btn-primary">+ Nouvelle déclaration</a>
    </div>
</div>
{% endblock %}

{% block body %}

{# ── Hero ─────────────────────────────────────────────────────────────── #}
<div class="u-home-hero">
    <div class="u-home-hero-bg"></div>
    <div class="u-home-hero-inner">
        <div class="u-home-hero-left">
            {% if nextPending %}
                <div class="u-home-hero-badge">
                    <span class="u-home-hero-badge-dot"></span>
                    {% if nextDaysLeft is not null %}
                        {{ nextDaysLeft }} JOUR{{ nextDaysLeft != 1 ? 'S' : '' }} RESTANT{{ nextDaysLeft != 1 ? 'S' : '' }}
                    {% else %}
                        EN ATTENTE
                    {% endif %}
                </div>
                <div style="font-size:13px;opacity:.7;margin-bottom:4px;">
                    {{ nextPending.periodLabel }} · Échéance {{ nextDueDate ? nextDueDate|date('d/m/Y') : '—' }}
                </div>
                <div class="u-home-hero-amount">
                    {{ nextPending.cotisationAmount|number_format(0, ',', ' ') }} €
                </div>
                <div class="u-home-hero-sub">À déclarer sur urssaf.fr</div>
            {% else %}
                <div class="u-home-hero-badge">
                    <span class="u-home-hero-badge-dot" style="background:#86efac;"></span>
                    TOUT À JOUR
                </div>
                <div class="u-home-hero-amount" style="font-size:28px;margin-top:8px;">
                    Aucune déclaration en attente
                </div>
                <div class="u-home-hero-sub">Vos déclarations sont à jour</div>
            {% endif %}
        </div>
        <div class="u-home-hero-right">
            {% if nextPending %}
                <a href="{{ path('app_urssaf_edit', {id: nextPending.id}) }}" class="u-home-hero-btn u-home-hero-btn-white">
                    Continuer la déclaration
                </a>
            {% endif %}
            <a href="https://www.urssaf.fr" target="_blank" rel="noopener" class="u-home-hero-btn u-home-hero-btn-ghost">
                Aller sur urssaf.fr ↗
            </a>
            <a href="{{ path('app_urssaf_new') }}" class="u-home-hero-btn u-home-hero-btn-ghost">
                + Nouvelle
            </a>
        </div>
    </div>
</div>

{# ── Stat tiles ────────────────────────────────────────────────────────── #}
{% set tvaPercent = yearRevenue > 0 ? min(100, (yearRevenue / thresholdServices * 100)) : 0 %}
<div class="u-stat-grid">

    <div class="u-stat-tile">
        <div class="u-stat-tile-label">CA cumulé {{ curYear }}</div>
        <div class="u-stat-tile-val">{{ yearRevenue|number_format(0, ',', ' ') }} €</div>
        <div class="u-stat-tile-sub">Chiffre d'affaires déclaré</div>
    </div>

    <div class="u-stat-tile">
        <div class="u-stat-tile-label">URSSAF payée {{ curYear }}</div>
        <div class="u-stat-tile-val" style="color:var(--accent);">{{ yearCotisation|number_format(0, ',', ' ') }} €</div>
        <div class="u-stat-tile-sub">Cotisations sociales</div>
    </div>

    <div class="u-stat-tile">
        <div class="u-stat-tile-label">IR via VFL {{ curYear }}</div>
        <div class="u-stat-tile-val" style="color:oklch(48% 0.14 50);">{{ yearLib|number_format(0, ',', ' ') }} €</div>
        <div class="u-stat-tile-sub">Versement libératoire 2,2 %</div>
    </div>

    <div class="u-stat-tile">
        <div class="u-stat-tile-label">Plafond micro-BNC</div>
        <div class="u-stat-tile-val {% if tvaPercent >= 100 %}" style="color:#dc2626;"{% elseif tvaPercent >= 80 %}" style="color:#f97316;"{% else %}"{% endif %}>
            {{ tvaPercent|round }} %
        </div>
        <div class="u-stat-bar-track"><div class="u-stat-bar-fill" style="width:{{ min(100, tvaPercent) }}%;{% if tvaPercent >= 100 %}background:#dc2626;{% elseif tvaPercent >= 80 %}background:#f97316;{% endif %}"></div></div>
        <div class="u-stat-tile-sub">{{ max(0, thresholdServices - yearRevenue)|number_format(0, ',', ' ') }} € restants</div>
    </div>

</div>

{# ── Toolbar ───────────────────────────────────────────────────────────── #}
<div class="u-toolbar">
    <div class="u-filter-pills">
        <button class="u-filter-pill active" data-filter="all">Toutes</button>
        <button class="u-filter-pill" data-filter="declared">Payées</button>
        <button class="u-filter-pill" data-filter="pending">En cours</button>
    </div>
    <div class="u-toolbar-spacer"></div>
    <a href="{{ path('app_export_urssaf_csv') }}" class="btn btn-secondary" style="font-size:12px;">↓ Export CSV</a>
    <a href="{{ path('app_urssaf_new') }}" class="btn btn-primary" style="font-size:12px;">+ Nouvelle déclaration</a>
</div>

{# ── Declarations table ────────────────────────────────────────────────── #}
<div class="u-decl-table-wrap">
    {% if declarations is empty %}
        <div class="empty-state">
            <div class="empty-state-icon">📋</div>
            <p>Aucune déclaration URSSAF enregistrée.</p>
            <a href="{{ path('app_urssaf_new') }}" class="btn btn-primary">Créer ma première déclaration</a>
        </div>
    {% else %}
    <table class="u-decl-table">
        <thead>
            <tr>
                <th>Période</th>
                <th>Type</th>
                <th class="num">CA déclaré</th>
                <th class="num">URSSAF</th>
                <th class="num">IR (VFL)</th>
                <th class="num">Total</th>
                <th>Échéance</th>
                <th>Statut</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        {% set totalCA = 0 %}
        {% set totalCot = 0 %}
        {% set totalVfl = 0 %}
        {% for e in declarations %}
            {% set d = e.d %}
            {% set vfl = e.lib %}
            {% set totalCA = totalCA + d.revenue %}
            {% set totalCot = totalCot + d.cotisationAmount %}
            {% set totalVfl = totalVfl + vfl %}
            <tr data-status="{{ d.declared ? 'declared' : 'pending' }}">
                <td>
                    <a href="{{ path('app_urssaf_show', {id: d.id}) }}"
                       style="font-weight:700;color:var(--fg);text-decoration:none;display:flex;align-items:center;gap:4px;">
                        {% if d.periodicity == 'quarterly' %}
                            <span class="u-period-badge">{{ d.periodLabel|split('-')|last }}</span>
                        {% endif %}
                        {{ d.periodLabel }}
                    </a>
                    <div style="font-size:11px;color:var(--muted);margin-top:2px;">
                        {{ d.periodStart|date('d/m/Y') }} → {{ d.periodEnd|date('d/m/Y') }}
                    </div>
                </td>
                <td style="font-size:12px;color:var(--muted);">
                    {{ d.periodicity == 'monthly' ? 'Mensuelle' : 'Trimestrielle' }}
                </td>
                <td class="num" style="font-family:var(--font-mono);font-weight:600;">
                    {{ d.revenue|number_format(2, ',', ' ') }} €
                </td>
                <td class="num" style="font-family:var(--font-mono);font-weight:700;color:var(--accent);">
                    {{ d.cotisationAmount|number_format(2, ',', ' ') }} €
                </td>
                <td class="num" style="font-family:var(--font-mono);color:oklch(48% 0.14 50);">
                    {{ vfl|number_format(0, ',', ' ') }} €
                </td>
                <td class="num" style="font-family:var(--font-mono);font-weight:700;">
                    {{ (d.cotisationAmount + vfl)|number_format(0, ',', ' ') }} €
                </td>
                <td style="font-size:12px;">
                    {% if e.dueDate %}
                        <div>{{ e.dueDate|date('d/m/Y') }}</div>
                        {% if e.overdue and not d.declared %}
                            <div style="font-size:10px;color:#dc2626;font-weight:700;">En retard</div>
                        {% elseif e.daysLeft is not null and not d.declared %}
                            <div style="font-size:10px;color:{% if e.daysLeft <= 7 %}#f97316{% else %}var(--muted){% endif %};">
                                {{ e.daysLeft }}j restants
                            </div>
                        {% endif %}
                    {% else %}—{% endif %}
                </td>
                <td>
                    {% if d.declared %}
                        <span class="chip chip-green"><span class="chip-dot"></span>Payée</span>
                    {% else %}
                        <span class="chip chip-orange"><span class="chip-dot"></span>En cours</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_urssaf_show', {id: d.id}) }}" class="u-actions-btn" title="Voir">→</a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
        <tfoot>
            <tr>
                <td colspan="2" style="color:var(--muted);font-size:12px;">Cumul {{ curYear }}</td>
                <td class="num" style="font-family:var(--font-mono);">{{ totalCA|number_format(2, ',', ' ') }} €</td>
                <td class="num" style="font-family:var(--font-mono);color:var(--accent);">{{ totalCot|number_format(2, ',', ' ') }} €</td>
                <td class="num" style="font-family:var(--font-mono);color:oklch(48% 0.14 50);">{{ totalVfl|number_format(0, ',', ' ') }} €</td>
                <td class="num" style="font-family:var(--font-mono);">{{ (totalCot + totalVfl)|number_format(0, ',', ' ') }} €</td>
                <td colspan="3"></td>
            </tr>
        </tfoot>
    </table>
    {% endif %}
</div>

{# ── Échéances : toggle trimestriel / mensuel ─────────────────────────── #}
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px;">
    <div style="font-size:13.5px;font-weight:700;">Prochaines échéances {{ curYear }}</div>
    <div class="u-year-tabs" id="cal-toggle">
        <button class="u-year-tab" id="cal-btn-quarterly" data-view="quarterly" onclick="switchCalView('quarterly')">
            Par trimestre
        </button>
        <button class="u-year-tab" id="cal-btn-monthly" data-view="monthly" onclick="switchCalView('monthly')">
            Par mois
        </button>
    </div>
</div>

{# Quarterly grid #}
<div id="cal-quarterly" class="u-quarter-grid">
{% for q in calendar %}
    {% set decl = q.declaration %}
    <div class="u-quarter-card {% if decl %}{% if decl.declared %}u-quarter-card-declared{% elseif q.overdue %}u-quarter-card-overdue{% else %}u-quarter-card-pending{% endif %}{% else %}u-quarter-card-empty{% endif %}">
        <div class="u-quarter-card-head">
            <span class="u-quarter-label">{{ q.label }}</span>
            <span class="u-quarter-status-dot" style="background:{% if decl %}{% if decl.declared %}#16a34a{% elseif q.overdue %}#dc2626{% else %}#f97316{% endif %}{% else %}#d1d5db{% endif %};"></span>
        </div>
        <div class="u-quarter-months">{{ q.monthsLabel }}</div>
        <div class="u-quarter-due">
            Échéance : <strong>{{ q.dueDate|date('d/m/Y') }}</strong>
        </div>
        {% if decl %}
            <div style="margin-top:8px;font-size:12px;">
                {% if decl.declared %}
                    <span style="color:#16a34a;font-weight:600;">✓ Déclarée</span>
                {% else %}
                    <span style="color:#f97316;font-weight:600;">
                        {{ q.daysLeft }}j · {{ decl.cotisationAmount|number_format(0, ',', ' ') }} €
                    </span>
                {% endif %}
            </div>
            <a href="{{ path('app_urssaf_show', {id: decl.id}) }}"
               style="margin-top:8px;display:block;font-size:11.5px;color:var(--accent);text-decoration:none;font-weight:600;">
                Voir →
            </a>
        {% else %}
            <a href="{{ path('app_urssaf_new') }}" class="u-quarter-new-btn">+ Nouvelle</a>
        {% endif %}
    </div>
{% endfor %}
</div>

{# Monthly grid #}
<div id="cal-monthly" class="u-month-cal-grid" style="display:none;">
{% for m in calendarMonthly %}
    {% set decl = m.declaration %}
    <div class="u-month-cal-card {% if decl %}{% if decl.declared %}u-month-cal-declared{% elseif m.overdue %}u-month-cal-overdue{% else %}u-month-cal-pending{% endif %}{% else %}u-month-cal-empty{% endif %}">
        <div class="u-month-cal-head">
            <span class="u-month-cal-label">{{ m.short }}</span>
            <span class="u-month-cal-dot" style="background:{% if decl %}{% if decl.declared %}#16a34a{% elseif m.overdue %}#dc2626{% else %}#f97316{% endif %}{% else %}#d1d5db{% endif %};"></span>
        </div>
        <div class="u-month-cal-due">Éch. {{ m.dueDate|date('d/m') }}</div>
        {% if decl %}
            <div class="u-month-cal-info">
                {% if decl.declared %}
                    <span style="color:#16a34a;">✓ OK</span>
                {% else %}
                    <span style="color:#f97316;">{{ m.daysLeft }}j · {{ decl.cotisationAmount|number_format(0, ',', ' ') }} €</span>
                {% endif %}
            </div>
            <a href="{{ path('app_urssaf_show', {id: decl.id}) }}"
               style="display:block;font-size:10.5px;color:var(--accent);text-decoration:none;font-weight:600;margin-top:4px;">
                Voir →
            </a>
        {% else %}
            <a href="{{ path('app_urssaf_new') }}"
               style="display:block;font-size:10.5px;color:var(--muted);text-decoration:none;margin-top:6px;">
                + Ajouter
            </a>
        {% endif %}
    </div>
{% endfor %}
</div>

{# ── AI help card ─────────────────────────────────────────────────────── #}
<div class="u-ai-card">
    <div class="u-ai-head">
        <div class="u-ai-icon">✦</div>
        <div>
            <div style="font-size:13px;font-weight:700;">Besoin d'aide ?</div>
            <div style="font-size:11.5px;color:var(--muted);">Votre assistant comptable IA</div>
        </div>
    </div>
    <div class="u-ai-questions">
        <button class="u-ai-q">
            <span class="u-ai-q-arrow">→</span>
            Comment calculer mes cotisations URSSAF ?
        </button>
        <button class="u-ai-q">
            <span class="u-ai-q-arrow">→</span>
            Qu'est-ce que le versement libératoire ?
        </button>
        <button class="u-ai-q">
            <span class="u-ai-q-arrow">→</span>
            Quand dois-je déclarer ce trimestre ?
        </button>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
// Filter pills
document.querySelectorAll('.u-filter-pill').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.u-filter-pill').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const f = btn.dataset.filter;
        document.querySelectorAll('.u-decl-table tbody tr').forEach(row => {
            row.style.display = (f === 'all' || row.dataset.status === f) ? '' : 'none';
        });
    });
});

// Calendar toggle (quarterly / monthly)
const CAL_KEY = 'urssaf_cal_view';
const defaultView = localStorage.getItem(CAL_KEY) || '{{ preferredPeriodicity }}';

function switchCalView(view) {
    document.getElementById('cal-quarterly').style.display = view === 'quarterly' ? '' : 'none';
    document.getElementById('cal-monthly').style.display   = view === 'monthly'   ? '' : 'none';
    document.getElementById('cal-btn-quarterly').classList.toggle('active', view === 'quarterly');
    document.getElementById('cal-btn-monthly').classList.toggle('active',   view === 'monthly');
    localStorage.setItem(CAL_KEY, view);
}

switchCalView(defaultView);
</script>
{% endblock %}
