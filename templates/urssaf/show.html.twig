{% extends 'base.html.twig' %}
{% block title %}{{ declaration.periodLabel }} — URSSAF — GestoPro{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/accounting.css') }}">
{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Déclaration {{ declaration.periodLabel }}</h1>
    <div class="topbar-actions">
        <a href="{{ path('app_urssaf_edit', {id: declaration.id}) }}" class="btn btn-secondary">Modifier</a>
        <a href="{{ path('app_urssaf') }}" class="btn btn-secondary">Retour</a>
    </div>
</div>
{% endblock %}

{% block body %}
<div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;align-items:start;">

    {# ── Formal document ──────────────────────────────────────── #}
    <div class="acc-doc">
        <div class="acc-doc-header">
            <div>
                <div class="acc-doc-eyebrow">Déclaration URSSAF</div>
                <div class="acc-doc-period">{{ declaration.periodLabel }}</div>
                <div class="acc-doc-dates">
                    {{ declaration.periodStart|date('d/m/Y') }} → {{ declaration.periodEnd|date('d/m/Y') }}
                </div>
            </div>
            <div style="text-align:right;">
                <div class="acc-doc-eyebrow" style="margin-bottom:6px;">Périodicité</div>
                <span class="chip chip-gray">
                    {{ declaration.periodicity == 'monthly' ? 'Mensuelle' : 'Trimestrielle' }}
                </span>
            </div>
        </div>

        <div class="acc-amounts">
            <div class="acc-row">
                <span class="acc-row-label">Chiffre d'affaires déclaré</span>
                <span class="acc-row-value">{{ declaration.revenue|number_format(2, ',', ' ') }} €</span>
            </div>
            <div class="acc-row">
                <span class="acc-row-label">Taux de cotisation</span>
                <span class="acc-row-value c-muted">{{ (declaration.cotisationRate * 100)|number_format(1, ',', ' ') }} %</span>
            </div>
            <div class="acc-row-total">
                <span class="acc-row-label">Cotisation à payer</span>
                <span class="acc-row-value c-blue">{{ declaration.cotisationAmount|number_format(2, ',', ' ') }} €</span>
            </div>
        </div>
    </div>

    {# ── Sidebar ──────────────────────────────────────────────── #}
    <div>
        {% if declaration.declared %}
        <div class="acc-status-box st-green">
            <div class="acc-status-title" style="color:#15803d;">
                <span class="chip chip-green" style="margin-bottom:6px;">
                    <span class="chip-dot"></span>Déclarée
                </span>
            </div>
            {% if declaration.declaredAt %}
            <div class="acc-status-desc">
                Déclaration effectuée le {{ declaration.declaredAt|date('d/m/Y') }}.
            </div>
            {% endif %}
        </div>
        {% else %}
        <div class="acc-status-box st-orange">
            <div style="margin-bottom:6px;">
                <span class="chip chip-orange">
                    <span class="chip-dot"></span>À déclarer
                </span>
            </div>
            <div class="acc-status-desc">
                Déclarez ce CA sur <strong>urssaf.fr</strong> avant la date limite de la période.
            </div>
        </div>
        {% endif %}

        <div class="card" style="margin-top:0;">
            <div style="display:flex;flex-direction:column;gap:8px;">
                <a href="{{ path('app_urssaf_edit', {id: declaration.id}) }}" class="btn btn-secondary" style="width:100%;text-align:center;">
                    Modifier la déclaration
                </a>
                <form method="post" action="{{ path('app_urssaf_delete', {id: declaration.id}) }}"
                      onsubmit="return confirm('Supprimer cette déclaration ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_urssaf_' ~ declaration.id) }}">
                    <button type="submit" class="btn btn-danger btn-sm" style="width:100%;">Supprimer</button>
                </form>
            </div>
        </div>
    </div>

</div>
{% endblock %}
