<script>
// ─── FAQ ──────────────────────────────────────────────────────────
function toggleFaq(btn) {
  var icon = btn.querySelector('.faq-icon');
  var answer = btn.nextElementSibling;
  var open = answer.classList.contains('open');
  answer.classList.toggle('open', !open);
  icon.classList.toggle('open', !open);
}

// ─── PRICING TOGGLE ───────────────────────────────────────────────
function setPeriod(p) {
  document.querySelectorAll('.period-btn').forEach(function(b) {
    b.classList.toggle('active', b.dataset.period === p);
    var chip = b.querySelector('.period-chip');
    if (chip) chip.className = 'period-chip ' + (b.classList.contains('active') ? 'on-dark' : 'on-light');
  });
  var yearly = p === 'yearly';
  document.getElementById('pro-price').textContent    = yearly ? '15' : '19';
  document.getElementById('expert-price').textContent = yearly ? '39' : '49';
  document.getElementById('pro-save').style.display    = yearly ? 'block' : 'none';
  document.getElementById('expert-save').style.display = yearly ? 'block' : 'none';
}

// ─── AUTH MODAL ───────────────────────────────────────────────────
function openAuth(tab) {
  switchAuthTab(tab || 'login');
  document.getElementById('auth-overlay').classList.add('is-open');
}
function closeAuth() {
  document.getElementById('auth-overlay').classList.remove('is-open');
}
function switchAuthTab(tab) {
  ['login','register'].forEach(function(t) {
    document.getElementById('auth-' + t).classList.toggle('active', t === tab);
    document.querySelectorAll('.auth-tab').forEach(function(btn, i) {
      btn.classList.toggle('active', (i === 0 && tab === 'login') || (i === 1 && tab === 'register'));
    });
  });
}
document.getElementById('auth-overlay').addEventListener('click', function(e) {
  if (e.target === this) closeAuth();
});
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeAuth();
});
</script>
</body>
</html>
