{% extends 'base.html.twig' %}
{% block title %}Connexion — GestoPro{% endblock %}

{% block body_public %}
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: #f5f6f8;
    font-family: "Inter", ui-sans-serif, system-ui, -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased;
  }
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .auth-card {
    background: #fff;
    border: 1px solid #e8eaed;
    border-radius: 14px;
    padding: 40px 36px;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 8px 24px rgba(0,0,0,.04);
  }
  .auth-brand { text-align: center; margin-bottom: 32px; }
  .auth-brand .name { font-size: 22px; font-weight: 800; color: #0f172a; letter-spacing: -.03em; }
  .auth-brand .name span { color: #2563eb; }
  .auth-brand .sub { font-size: 12.5px; color: #9ca3af; margin-top: 4px; }
  h2.auth-heading { font-size: 16px; font-weight: 600; color: #0f172a; letter-spacing: -.01em; margin-bottom: 22px; }
  label.lbl { display: block; font-size: 12.5px; font-weight: 500; color: #374151; margin-bottom: 5px; }
  input.inp {
    width: 100%; padding: 9px 12px; border: 1px solid #d1d5db; border-radius: 7px;
    font-size: 14px; font-family: inherit; color: #0f172a; background: #fff;
    transition: border-color .15s, box-shadow .15s; margin-bottom: 14px;
  }
  input.inp:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,.1); }
  .remember { display: flex; align-items: center; gap: 7px; font-size: 13px; color: #6b7280; margin-bottom: 20px; cursor: pointer; }
  .submit-btn {
    width: 100%; padding: 10px; background: #2563eb; color: #fff; border: none;
    border-radius: 7px; font-size: 14px; font-weight: 600; font-family: inherit;
    cursor: pointer; transition: background .12s; letter-spacing: -.01em;
  }
  .submit-btn:hover { background: #1d4ed8; }
  .auth-foot { text-align: center; margin-top: 20px; font-size: 13px; color: #9ca3af; }
  .auth-foot a { color: #2563eb; font-weight: 500; }
  .err { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; padding: 10px 13px; border-radius: 7px; font-size: 13px; margin-bottom: 16px; }
  .ok  { background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d;  padding: 10px 13px; border-radius: 7px; font-size: 13px; margin-bottom: 16px; }
</style>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <div class="name">Gesto<span>Pro</span></div>
      <div class="sub">La compta sans la migraine</div>
    </div>

    {% if error %}
      <div class="err">{{ error.messageKey | trans(error.messageData, 'security') }}</div>
    {% endif %}
    {% for flash in app.flashes('success') %}
      <div class="ok">{{ flash }}</div>
    {% endfor %}

    <h2 class="auth-heading">Se connecter</h2>

    <form method="post">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
      <label class="lbl" for="login-email">Adresse email</label>
      <input id="login-email" type="email" name="email" value="{{ last_username }}"
             class="inp" required autofocus autocomplete="email" placeholder="vous@exemple.fr">
      <label class="lbl" for="login-pw">Mot de passe</label>
      <input id="login-pw" type="password" name="password"
             class="inp" required autocomplete="current-password" placeholder="••••••••">
      <label class="remember">
        <input type="checkbox" name="_remember_me"> Se souvenir de moi
      </label>
      <button type="submit" class="submit-btn">Se connecter</button>
    </form>

    <div class="auth-foot">
      Pas encore de compte ?
      <a href="{{ path('app_register') }}">Créer un compte gratuit</a>
    </div>
  </div>
</div>
{% endblock %}
