<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}GestoPro — Expert{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="{{ asset('styles/expert.css') }}">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <div class="layout">
            {% include 'partials/_sidebar_expert.html.twig' %}
            <div class="main">
                {% block topbar %}{% endblock %}
                <div class="content">
                    {% for msg in app.flashes('success') %}
                        <div class="alert alert-success">{{ msg }}</div>
                    {% endfor %}
                    {% for msg in app.flashes('error') %}
                        <div class="alert alert-error">{{ msg }}</div>
                    {% endfor %}
                    {% block body %}{% endblock %}
                </div>
            </div>
        </div>
        {% block javascripts %}{% endblock %}

        <!-- Modal de confirmation -->
        <div id="gmodal" class="gmodal-overlay" role="dialog" aria-modal="true">
          <div class="gmodal-box">
            <div class="gmodal-icon" id="gmodal-icon"></div>
            <p class="gmodal-title" id="gmodal-title">Confirmation</p>
            <p class="gmodal-msg" id="gmodal-msg"></p>
            <div class="gmodal-actions">
              <button class="btn btn-secondary" id="gmodal-cancel">Annuler</button>
              <button class="btn btn-primary"   id="gmodal-ok">Confirmer</button>
            </div>
          </div>
        </div>
        <script>
        (function(){
          var o=document.getElementById('gmodal');
          if(!o)return;
          var msg=document.getElementById('gmodal-msg'),
              ttl=document.getElementById('gmodal-title'),
              ico=document.getElementById('gmodal-icon'),
              ok=document.getElementById('gmodal-ok'),
              cancel=document.getElementById('gmodal-cancel'),
              cb=null;
          var WARN='<svg width="22" height="22" viewBox="0 0 16 16" fill="currentColor"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg>';
          var INFO='<svg width="22" height="22" viewBox="0 0 16 16" fill="currentColor"><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/></svg>';
          function show(m,callback,variant){
            variant=variant||'primary';
            ico.className='gmodal-icon is-'+variant;
            ico.innerHTML=variant==='danger'?WARN:INFO;
            ok.className='btn '+(variant==='danger'?'btn-danger':'btn-primary');
            ttl.textContent='Confirmation';
            msg.textContent=m;
            cb=callback;
            o.classList.add('is-open');
            setTimeout(function(){cancel.focus();},60);
          }
          function hide(){o.classList.remove('is-open');cb=null;}
          ok.addEventListener('click',function(){var f=cb;hide();if(f)f();});
          cancel.addEventListener('click',hide);
          o.addEventListener('click',function(e){if(e.target===o)hide();});
          document.addEventListener('keydown',function(e){if(e.key==='Escape')hide();});
          document.addEventListener('submit',function(e){
            var form=e.target,m=form.dataset.confirm;
            if(!m)return;
            e.preventDefault();
            show(m,function(){delete form.dataset.confirm;form.submit();},form.dataset.confirmVariant);
          },true);
          document.addEventListener('click',function(e){
            var btn=e.target.closest('button[data-confirm]');
            if(!btn)return;
            var form=btn.closest('form');
            e.preventDefault();
            show(btn.dataset.confirm,function(){
              if(form){delete btn.dataset.confirm;form.submit();}
            },btn.dataset.confirmVariant);
          },true);
        }());
        </script>
    </body>
</html>
