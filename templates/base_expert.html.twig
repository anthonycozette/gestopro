<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}GestoPro — Expert{% endblock %}</title>
        <link rel="stylesheet" href="{{ asset('styles/expert.css') }}">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <div class="layout">
            <aside class="sidebar">
                <div class="sidebar-brand">
                    Gesto<span>Pro</span>
                    <small>Portail Expert-Comptable</small>
                </div>
                <nav class="sidebar-nav">
                    <a href="{{ path('expert_dashboard') }}" {% if app.request.attributes.get('_route') == 'expert_dashboard' %}class="active"{% endif %}>
                        Tableau de bord
                    </a>
                    <a href="{{ path('expert_clients') }}" {% if app.request.attributes.get('_route') == 'expert_clients' %}class="active"{% endif %}>
                        Clients
                    </a>
                    <a href="{{ path('expert_invite') }}" {% if app.request.attributes.get('_route') == 'expert_invite' %}class="active"{% endif %}>
                        Inviter un client
                    </a>
                </nav>
                <div class="sidebar-footer">
                    {% if app.user %}{{ app.user.firstName }} {{ app.user.lastName }}<br>{% endif %}
                    <a href="{{ path('expert_logout') }}">Déconnexion</a>
                </div>
            </aside>
            <div class="main">
                {% block topbar %}{% endblock %}
                <div class="content">
                    {% for msg in app.flashes('success') %}
                        <div class="alert alert-success">{{ msg }}</div>
                    {% endfor %}
                    {% for msg in app.flashes('error') %}
                        <div class="alert alert-error">{{ msg }}</div>
                    {% endfor %}
                    {% block body %}{% endblock %}
                </div>
            </div>
        </div>
        {% block javascripts %}{% endblock %}
    </body>
</html>
