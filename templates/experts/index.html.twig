{% extends 'base.html.twig' %}
{% block title %}Mon Expert-Comptable — GestoPro{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/bilan.css') }}">
{% endblock %}

{% block topbar %}
<div class="topbar">
    <div>
        <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:2px;">
            Portail expert
        </div>
        <h1>Mon Expert-Comptable</h1>
    </div>
    <div class="topbar-actions">
        <a href="{{ path('app_balance_sheets') }}" class="btn btn-secondary">📊 Mes bilans</a>
    </div>
</div>
{% endblock %}

{% block body %}

{# ════════════════════════════════════════════
   État 3 : pas d'expert — annuaire
   ════════════════════════════════════════════ #}
{% if not myInvitation %}

<div style="max-width:560px;margin:0 auto 32px;">
    <div style="font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:24px;">
        Choisissez un expert-comptable. Il pourra réviser vos bilans IA, ajouter des annotations et les valider officiellement.
    </div>
    <div style="display:flex;flex-direction:column;gap:8px;padding:16px 20px;background:#f8fafc;border-radius:12px;border:1px solid var(--bd);margin-bottom:28px;">
        <div style="display:flex;align-items:center;gap:10px;font-size:13px;">
            <span style="width:24px;height:24px;border-radius:6px;background:#dcfce7;color:#16a34a;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">✓</span>
            Réviser et annoter vos bilans comptables
        </div>
        <div style="display:flex;align-items:center;gap:10px;font-size:13px;">
            <span style="width:24px;height:24px;border-radius:6px;background:#dcfce7;color:#16a34a;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">✓</span>
            Valider et apposer son tampon numérique
        </div>
        <div style="display:flex;align-items:center;gap:10px;font-size:13px;">
            <span style="width:24px;height:24px;border-radius:6px;background:#dcfce7;color:#16a34a;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">✓</span>
            Échanger via la messagerie sécurisée
        </div>
    </div>
</div>

{% if accountants is empty %}
<div style="text-align:center;padding:60px 24px;">
    <div style="font-size:48px;margin-bottom:12px;">🧑‍💼</div>
    <div style="font-size:15px;font-weight:600;margin-bottom:6px;">Aucun expert disponible</div>
    <div style="font-size:13px;color:var(--muted);">Aucun expert-comptable n'est encore inscrit sur GestoPro.</div>
</div>
{% else %}
<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:16px;">
    {% for expert in accountants %}
    <div style="background:#fff;border:1px solid var(--bd);border-radius:14px;padding:22px;display:flex;flex-direction:column;transition:box-shadow .15s;">
        <div style="display:flex;align-items:flex-start;gap:14px;margin-bottom:14px;">
            <div style="width:48px;height:48px;border-radius:14px;
                        background:linear-gradient(135deg,var(--accent),oklch(58% 0.16 290));
                        color:#fff;display:flex;align-items:center;justify-content:center;
                        font-size:16px;font-weight:700;flex-shrink:0;">
                {{ expert.firstName|first|upper }}{{ expert.lastName|first|upper }}
            </div>
            <div>
                <div style="font-size:14.5px;font-weight:700;color:var(--text);">{{ expert.firstName }} {{ expert.lastName }}</div>
                {% if expert.firm %}<div style="font-size:13px;color:var(--muted);">{{ expert.firm }}</div>{% endif %}
                {% if expert.registrationNumber %}<div style="font-size:11px;color:var(--muted);font-family:var(--font-mono);margin-top:2px;">{{ expert.registrationNumber }}</div>{% endif %}
            </div>
        </div>
        {% if expert.bio %}
        <p style="font-size:13px;color:var(--muted);line-height:1.55;flex:1;margin-bottom:16px;
                  display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">{{ expert.bio }}</p>
        {% else %}
        <p style="font-size:13px;color:var(--muted);font-style:italic;margin-bottom:16px;">Présentation à venir.</p>
        {% endif %}
        <div style="margin-top:auto;">
            <form method="post" action="{{ path('app_expert_request', {id: expert.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('expert_connect_' ~ expert.id) }}">
                <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">
                    Choisir cet expert
                </button>
            </form>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

{# ════════════════════════════════════════════
   État 2 : demande en attente
   ════════════════════════════════════════════ #}
{% elseif myInvitation.status == 'pending' %}

{% set expert = myInvitation.accountant %}
<div style="max-width:520px;margin:60px auto;">

    <div class="bl-expert-hero" style="margin-bottom:0;text-align:center;">
        <div class="bl-expert-hero-bg"></div>
        <div style="position:relative;">
            <div class="bl-expert-avatar" style="margin:0 auto 16px;">
                {{ expert.firstName|first|upper }}{{ expert.lastName|first|upper }}
            </div>
            <div style="font-size:18px;font-weight:800;margin-bottom:4px;">{{ expert.firstName }} {{ expert.lastName }}</div>
            {% if expert.firm %}<div style="font-size:13px;color:rgba(255,255,255,.7);margin-bottom:16px;">{{ expert.firm }}</div>{% endif %}
            <span class="bl-badge bl-badge-orange" style="display:inline-flex;margin-bottom:16px;">
                ⏳ Demande envoyée le {{ myInvitation.createdAt|date('d/m/Y') }}
            </span>
            <p style="font-size:13px;color:rgba(255,255,255,.7);line-height:1.6;margin-bottom:24px;">
                Votre expert-comptable a été notifié. La messagerie et la soumission de bilans seront disponibles après acceptation.
            </p>
            <form method="post" action="{{ path('app_expert_cancel', {id: myInvitation.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('expert_cancel_' ~ myInvitation.id) }}">
                <button type="submit" class="btn btn-secondary"
                        style="background:rgba(255,255,255,.15);border-color:rgba(255,255,255,.25);color:#fff;"
                        data-confirm="Annuler cette demande ?" data-confirm-variant="danger">
                    Annuler la demande
                </button>
            </form>
        </div>
    </div>

</div>

{# ════════════════════════════════════════════
   État 1 : expert accepté — HUB complet
   ════════════════════════════════════════════ #}
{% else %}

{% set expert = myInvitation.accountant %}

<div class="bl-expert-layout">

{# ──── Gauche : hero + messagerie ──────────────────── #}
<div>

    {# Hero expert #}
    <div class="bl-expert-hero">
        <div class="bl-expert-hero-bg"></div>
        <div class="bl-expert-hero-inner">
            <div class="bl-expert-avatar">
                {{ expert.firstName|first|upper }}{{ expert.lastName|first|upper }}
            </div>
            <div class="bl-expert-info">
                <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                    <div style="font-size:18px;font-weight:800;letter-spacing:-.4px;">
                        {{ expert.firstName }} {{ expert.lastName }}
                    </div>
                    <span class="bl-badge bl-badge-green">✓ Connecté</span>
                </div>
                {% if expert.firm %}
                <div style="font-size:13px;color:rgba(255,255,255,.75);margin-top:3px;">{{ expert.firm }}</div>
                {% endif %}
                {% if expert.registrationNumber %}
                <div style="font-size:11.5px;color:rgba(255,255,255,.6);margin-top:2px;">N° {{ expert.registrationNumber }}</div>
                {% endif %}
                <div style="font-size:11.5px;color:rgba(255,255,255,.55);margin-top:6px;">
                    Associé depuis le {{ myInvitation.createdAt|date('d/m/Y') }}
                </div>
            </div>
        </div>
        {% if expert.bio %}
        <div class="bl-expert-bio">{{ expert.bio }}</div>
        {% endif %}
        <form method="post" action="{{ path('app_expert_disconnect') }}" style="position:relative;margin-top:16px;">
            <input type="hidden" name="_token" value="{{ csrf_token('expert_disconnect') }}">
            <button type="submit" style="background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);
                    color:rgba(255,255,255,.7);font-size:12px;padding:5px 12px;border-radius:7px;
                    cursor:pointer;font-family:inherit;"
                    data-confirm="Dissocier cet expert ?" data-confirm-variant="danger">
                Dissocier cet expert
            </button>
        </form>
    </div>

    {# Messagerie #}
    <div class="bl-chat-wrap" id="messages">
        <div class="bl-chat-header">
            <div style="font-size:13px;font-weight:700;">Messagerie avec {{ expert.firstName }}</div>
            <div style="font-size:11.5px;color:var(--muted);">{{ messages|length }} message{{ messages|length != 1 ? 's' : '' }}</div>
        </div>
        <div class="bl-chat-messages" id="chat-messages">
            {% if messages is empty %}
            <div style="padding:32px 20px;text-align:center;color:var(--muted);font-size:13px;">
                Aucun message. Démarrez la conversation avec {{ expert.firstName }}.
            </div>
            {% else %}
            {% for msg in messages %}
            <div class="bl-chat-bubble {{ msg.fromClient ? 'bl-bubble-client' : 'bl-bubble-expert' }}">
                <div class="bl-bubble-meta">
                    {{ msg.fromClient ? 'Vous' : expert.firstName }}
                    · {{ msg.createdAt|date('d/m à H:i') }}
                </div>
                <div class="bl-bubble-text">{{ msg.content|nl2br }}</div>
            </div>
            {% endfor %}
            {% endif %}
        </div>
        <form method="post" action="{{ path('app_expert_message') }}" class="bl-chat-form">
            <input type="hidden" name="_token" value="{{ csrf_token('expert_msg') }}">
            <textarea name="content" class="bl-chat-input"
                      placeholder="Écrivez un message à {{ expert.firstName }}…"
                      rows="2" required></textarea>
            <button type="submit" class="bl-chat-send">Envoyer →</button>
        </form>
    </div>

</div>

{# ──── Droite : bilans + activité ─────────────────── #}
<div>

    {# Bilans soumis #}
    <div class="bl-panel" id="bilans">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
            <div class="bl-panel-title">
                Mes bilans
                <span style="font-size:11px;font-weight:400;color:var(--muted);margin-left:6px;">{{ bilans|length }}</span>
            </div>
            <a href="{{ path('app_balance_sheets') }}" class="btn btn-secondary btn-sm">+ Nouveau</a>
        </div>

        {% if bilans is empty %}
        <div style="font-size:13px;color:var(--muted);font-style:italic;padding:8px 0;text-align:center;">
            Aucun bilan généré.
            <a href="{{ path('app_balance_sheets') }}" style="color:var(--accent);font-weight:600;display:block;margin-top:6px;">Créer mon premier bilan IA →</a>
        </div>
        {% else %}
        <div style="display:flex;flex-direction:column;gap:8px;">
            {% for bilan in bilans %}
            <div class="bl-submitted-row">
                <div class="bl-pdf-thumb" style="width:32px;height:40px;flex-shrink:0;">
                    <div class="bl-pdf-thumb-corner"></div>
                    <div class="bl-pdf-type" style="font-size:5.5px;">PDF</div>
                </div>
                <div style="flex:1;min-width:0;">
                    <div style="font-size:12.5px;font-weight:700;color:var(--text);">{{ bilan.period }}</div>
                    <div style="font-size:11px;color:var(--muted);">{{ bilan.createdAt|date('d/m/Y') }}</div>
                </div>
                <div style="display:flex;align-items:center;gap:6px;">
                    {% if bilan.status == 'validated' %}
                        <span class="bl-badge bl-badge-green" style="font-size:10px;">✓ Validé</span>
                    {% elseif bilan.status == 'annotated' %}
                        <span class="bl-badge bl-badge-blue" style="font-size:10px;">💬 Annoté</span>
                    {% elseif bilan.status == 'pending_review' %}
                        <span class="bl-badge bl-badge-orange" style="font-size:10px;">⏳ Révision</span>
                    {% else %}
                        <span class="bl-badge bl-badge-gray" style="font-size:10px;">○ Brouillon</span>
                        <form method="post" action="{{ path('app_expert_bilan_submit', {id: bilan.id}) }}" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('submit_bilan_' ~ bilan.id) }}">
                            <button type="submit" class="btn btn-primary btn-sm" style="font-size:10.5px;height:24px;padding:0 8px;">
                                Soumettre
                            </button>
                        </form>
                    {% endif %}
                    {% if bilan.status in ['annotated', 'validated'] %}
                    <a href="{{ path('app_balance_sheet_show', {id: bilan.id}) }}"
                       style="display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;
                              border-radius:6px;border:1px solid var(--bd);background:#fff;
                              color:var(--muted);text-decoration:none;font-size:12px;">→</a>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        <div style="margin-top:12px;padding:10px 12px;background:#fff7ed;border:1px solid #fed7aa;
                    border-radius:8px;font-size:12px;color:#92400e;line-height:1.5;">
            Seuls les bilans en <strong>Brouillon</strong> peuvent être soumis pour révision.
        </div>
    </div>

    {# Tampon numérique #}
    {% if expert.stampPath %}
    <div class="bl-panel" style="margin-top:12px;">
        <div class="bl-panel-title">Tampon numérique</div>
        <div style="margin-top:10px;padding:12px;background:#f8fafc;border-radius:8px;border:1px solid var(--bd);text-align:center;">
            <img src="{{ asset(expert.stampPath) }}" alt="Tampon expert"
                 style="max-width:120px;max-height:80px;opacity:.85;">
        </div>
        <div style="font-size:11px;color:var(--muted);margin-top:6px;text-align:center;">
            Apposé sur les bilans validés
        </div>
    </div>
    {% endif %}

    {# Activité récente #}
    <div class="bl-panel" style="margin-top:12px;">
        <div class="bl-panel-title" style="margin-bottom:12px;">Activité récente</div>
        <div class="bl-activity">
            {% if messages is not empty %}
            {% set lastMsg = messages|last %}
            <div class="bl-activity-item" style="display:flex;gap:10px;padding-bottom:10px;">
                <span class="bl-activity-dot" style="background:#2563eb;"></span>
                <div>
                    <div style="font-size:12px;font-weight:600;">
                        {% if lastMsg.fromClient %}Vous avez envoyé un message{% else %}{{ expert.firstName }} a répondu{% endif %}
                    </div>
                    <div style="font-size:11px;color:var(--muted);">{{ lastMsg.createdAt|date('d/m/Y à H:i') }}</div>
                </div>
            </div>
            {% endif %}
            {% for bilan in bilans|slice(0,4) %}
            <div class="bl-activity-item" style="display:flex;gap:10px;padding-bottom:10px;">
                <span class="bl-activity-dot" style="background:
                    {% if bilan.status == 'validated' %}#16a34a
                    {% elseif bilan.status == 'annotated' %}#2563eb
                    {% else %}#f97316{% endif %};"></span>
                <div>
                    <div style="font-size:12px;font-weight:600;">
                        Bilan {{ bilan.period }}
                        {% if bilan.status == 'validated' %}validé
                        {% elseif bilan.status == 'annotated' %}annoté par {{ expert.firstName }}
                        {% elseif bilan.status == 'pending_review' %}soumis pour révision
                        {% else %}créé{% endif %}
                    </div>
                    <div style="font-size:11px;color:var(--muted);">{{ bilan.createdAt|date('d/m/Y') }}</div>
                </div>
            </div>
            {% endfor %}
            {% if messages is empty and bilans is empty %}
            <div style="font-size:12px;color:var(--muted);font-style:italic;">Aucune activité récente.</div>
            {% endif %}
        </div>
    </div>

</div>
</div>{# end .bl-expert-layout #}

{% endif %}

{% endblock %}

{% block javascripts %}
<script>
const chat = document.getElementById('chat-messages');
if (chat) chat.scrollTop = chat.scrollHeight;
</script>
{% endblock %}
