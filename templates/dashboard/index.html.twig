{% extends 'base.html.twig' %}
{% block title %}Dashboard — GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Tableau de bord</h1>
    <div style="font-size:13px; color:#6b7280;">
        Bonjour, <strong>{{ app.user.firstName }}</strong> · {{ 'now'|date('d/m/Y') }}
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/dashboard.css') }}">
{% endblock %}

{% block body %}

{# Alertes #}
{% if overdueCount > 0 %}
<div class="alert alert-error" style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
    <span style="font-size:18px;">⚠️</span>
    <div>
        <strong>{{ overdueCount }} facture{{ overdueCount > 1 ? 's' : '' }} en retard</strong> —
        <a href="{{ path('app_invoices') }}" style="color:inherit;text-decoration:underline;">Voir les factures</a>
    </div>
</div>
{% endif %}
{% if caYear >= tvaThreshold * 0.9 %}
<div class="alert alert-error" style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
    <span style="font-size:18px;">⚠️</span>
    <div>
        <strong>Seuil de franchise TVA approché</strong> — CA {{ year }} : {{ caYear|number_format(0, ',', ' ') }} € /
        seuil {{ tvaThreshold|number_format(0, ',', ' ') }} €
    </div>
</div>
{% endif %}

{# ── HERO CA + graphique ─────────────────────────────────────────────── #}
<div class="hero-card">

    {# Colonne gauche : montant + décomposition #}
    <div class="hero-left">
        <div class="hero-eyebrow">
            <div class="hero-icon-wrap">€</div>
            {% set monthNames = {1:'Janvier',2:'Février',3:'Mars',4:'Avril',5:'Mai',6:'Juin',7:'Juillet',8:'Août',9:'Septembre',10:'Octobre',11:'Novembre',12:'Décembre'} %}
            <span>Chiffre d'affaires · {{ monthNames[currentMonth]|default('Mois en cours') }} {{ year }}</span>
        </div>

        <div class="hero-amount-row">
            <div class="hero-amount">{{ caMonthTtc|number_format(0, ',', ' ') }} €</div>
            {% if deltaMonth is not null %}
            <span class="hero-delta {% if deltaMonth >= 0 %}delta-up{% else %}delta-down{% endif %}">
                {{ deltaMonth >= 0 ? '↑' : '↓' }} {{ deltaMonth|abs }} %
            </span>
            {% endif %}
        </div>

        {% if diffMonth != 0 %}
        <div class="hero-diff">
            <strong>{{ diffMonth|abs|number_format(0, ',', ' ') }} €</strong>
            {{ diffMonth >= 0 ? 'de plus' : 'de moins' }} que {{ prevMonthName|lower }}
        </div>
        {% endif %}

        <div class="hero-breakdown">
            <div class="hero-breakdown-cell">
                <div class="hero-breakdown-label">Total HT</div>
                <div class="hero-breakdown-value">{{ caMonthHt|number_format(0, ',', ' ') }} €</div>
            </div>
            <div class="hero-breakdown-cell">
                <div class="hero-breakdown-label">TVA 20%</div>
                <div class="hero-breakdown-value hero-breakdown-tva">{{ caMonthTva|number_format(0, ',', ' ') }} €</div>
            </div>
            <div class="hero-breakdown-cell hero-breakdown-ttc">
                <div class="hero-breakdown-label">Total TTC</div>
                <div class="hero-breakdown-value hero-breakdown-accent">{{ caMonthTtc|number_format(0, ',', ' ') }} €</div>
            </div>
        </div>
    </div>

    {# Colonne droite : graphique #}
    <div class="hero-right">
        <div class="hero-chart-header">
            <span class="hero-period-label" id="period-label">6 derniers mois</span>
            <div class="period-tabs">
                <button class="period-tab active" data-period="6m">6M</button>
                <button class="period-tab" data-period="1a">1A</button>
                <button class="period-tab" data-period="max">MAX</button>
            </div>
        </div>
        <div class="hero-chart-wrap">
            <canvas id="chart-monthly"></canvas>
        </div>
    </div>

</div>

{# ── 3 KPI cards ──────────────────────────────────────────────────────── #}
<div class="kpi-row">

    {# KPI 1 : Factures en attente #}
    <div class="kpi">
        <div class="kpi-header">
            <div class="kpi-icon" style="background:rgba(37,99,235,.1);color:#2563eb;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/><path d="M9 13h6M9 17h4"/></svg>
            </div>
            <div class="kpi-label">Factures en attente</div>
        </div>
        <div class="kpi-value">{{ pending.count }}</div>
        <div class="kpi-sub">
            {% if overdueCount > 0 %}{{ overdueCount }} en retard · {% endif %}{{ pending.amount|number_format(0, ',', ' ') }} €
        </div>
        <div class="kpi-pills">
            {% if invoiceCounts.paid > 0 %}
            <span class="kpi-pill pill-green">{{ invoiceCounts.paid }} payée{{ invoiceCounts.paid > 1 ? 's' : '' }}</span>
            {% endif %}
            {% if invoiceCounts.sent > 0 %}
            <span class="kpi-pill pill-blue">{{ invoiceCounts.sent }} envoyée{{ invoiceCounts.sent > 1 ? 's' : '' }}</span>
            {% endif %}
            {% if invoiceCounts.overdue > 0 %}
            <span class="kpi-pill pill-red">{{ invoiceCounts.overdue }} en retard</span>
            {% endif %}
        </div>
    </div>

    {# KPI 2 : Dépenses du mois #}
    <div class="kpi">
        <div class="kpi-header">
            <div class="kpi-icon" style="background:rgba(234,88,12,.1);color:#ea580c;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2v20l3-2 3 2 3-2 3 2 3-2 1 2V2z"/><path d="M8 7h8M8 11h8M8 15h5"/></svg>
            </div>
            <div class="kpi-label">Dépenses du mois</div>
            {% if deltaExpenses is not null %}
            <span class="kpi-delta {% if deltaExpenses <= 0 %}delta-up{% else %}delta-down{% endif %}" style="margin-left:auto;">
                {{ deltaExpenses > 0 ? '+' : '' }}{{ deltaExpenses }} %
            </span>
            {% endif %}
        </div>
        <div class="kpi-value">{{ expensesMonth|number_format(0, ',', ' ') }} €</div>
        <div class="kpi-sub">{{ expensesScannedCount }} reçu{{ expensesScannedCount > 1 ? 's' : '' }} scannés</div>
    </div>

    {# KPI 3 : URSSAF #}
    <div class="kpi">
        <div class="kpi-header">
            <div class="kpi-icon" style="background:rgba(22,163,74,.1);color:#16a34a;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            </div>
            <div class="kpi-label">URSSAF à régler</div>
        </div>
        <div class="kpi-value {% if nextUrssaf and urssafDaysLeft <= 7 %}kpi-value-warn{% endif %}">
            {{ nextUrssaf ? nextUrssaf.cotisationAmount|number_format(0, ',', ' ') ~ ' €' : urssafYear|number_format(0, ',', ' ') ~ ' €' }}
        </div>
        <div class="kpi-sub">
            {% if nextUrssaf %}
                Dans {{ urssafDaysLeft }} jour{{ urssafDaysLeft > 1 ? 's' : '' }} · {{ nextUrssaf.periodLabel }}
            {% else %}
                Tout est déclaré ✓
            {% endif %}
        </div>
        {% if nextUrssaf %}
        <div class="kpi-progress-wrap" style="margin-top:12px;">
            <div class="kpi-progress-bar" style="width:{{ urssafProgress }}%;background:linear-gradient(90deg,#16a34a,#2563eb);"></div>
        </div>
        {% endif %}
    </div>

</div>

{# ── Strip IA ─────────────────────────────────────────────────────────── #}
{% if app.user.plan in ['pro', 'expert'] %}
<div class="ai-strip">
    <div class="ai-strip-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M5.6 18.4l2.8-2.8M15.6 8.4l2.8-2.8"/></svg>
    </div>
    <div class="ai-strip-body">
        <div class="ai-strip-title">
            Demande à GestoPro IA
            <span class="ai-plan-badge">PLAN PRO</span>
        </div>
        <div class="ai-strip-sub">Réponses comptables en 1 seconde, contexte de tes factures inclus.</div>
        <div class="ai-prompts">
            <a href="{{ path('app_ai') }}" class="ai-prompt-chip">› Calcule ma TVA du trimestre</a>
            <a href="{{ path('app_ai') }}" class="ai-prompt-chip">› Relance les factures en retard</a>
            <a href="{{ path('app_ai') }}" class="ai-prompt-chip">› Récap chiffre d'affaires par client</a>
            <a href="{{ path('app_ai') }}" class="ai-prompt-chip">› Prépare ma déclaration URSSAF</a>
        </div>
    </div>
    <div class="ai-strip-input">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        <a href="{{ path('app_ai') }}" class="ai-placeholder">Écris ta question…</a>
        <a href="{{ path('app_ai') }}" class="ai-send-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
    </div>
</div>
{% else %}
<div class="ai-strip ai-strip-locked">
    <div class="ai-strip-icon" style="background:linear-gradient(135deg,#94a3b8,#cbd5e1);box-shadow:none;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    </div>
    <div class="ai-strip-body">
        <div class="ai-strip-title">
            Assistant IA GestoPro
            <span class="ai-plan-badge" style="background:#94a3b8;">PLAN PRO</span>
        </div>
        <div class="ai-strip-sub">Calcule ta TVA, prépare tes déclarations, relance tes clients — réservé aux plans Pro &amp; Expert.</div>
    </div>
    <a href="{{ path('app_pricing') }}" class="btn btn-primary" style="flex-shrink:0;white-space:nowrap;">Passer au Pro →</a>
</div>
{% endif %}

{# ── Bottom : factures récentes + sidebar ─────────────────────────────── #}
<div class="bottom-grid">

    {# Factures récentes — layout riche #}
    <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;">
            <div>
                <div class="card-title" style="margin-bottom:2px;">Factures récentes</div>
                <div style="font-size:11.5px;color:#8a93a3;">Les 6 dernières · {{ pending.amount|number_format(0, ',', ' ') }} € en attente</div>
            </div>
            <a href="{{ path('app_invoices') }}" style="font-size:12px;color:#2563eb;font-weight:600;">Tout voir →</a>
        </div>

        {% if recentInvoices is empty %}
            <div style="text-align:center;color:#9ca3af;padding:24px 0;font-size:13px;">Aucune facture</div>
        {% else %}
            {% for invoice in recentInvoices %}
            {% set avatarColors = ['#e53935','#8e24aa','#1e88e5','#00897b','#43a047','#fb8c00','#6d4c41','#546e7a'] %}
            {% set colorIdx = (invoice.client.name|length) % 8 %}
            <a href="{{ path('app_invoice_show', {id: invoice.id}) }}" class="inv-row">
                <div class="inv-avatar" style="background:{{ avatarColors[colorIdx] }};">
                    {{ invoice.client.name|first|upper }}{{ invoice.client.name|split(' ')|last|first|upper }}
                </div>
                <div class="inv-info">
                    <div class="inv-client">{{ invoice.client.name }}</div>
                    <div class="inv-number">{{ invoice.number }}</div>
                </div>
                <div class="inv-status">
                    {% if invoice.status == 'paid' %}<span class="st-badge st-paid">Payée</span>
                    {% elseif invoice.status == 'sent' %}<span class="st-badge st-sent">Envoyée</span>
                    {% elseif invoice.status == 'overdue' %}<span class="st-badge st-late">En retard</span>
                    {% else %}<span class="st-badge st-draft">Brouillon</span>{% endif %}
                </div>
                <div class="inv-date" style="{% if invoice.status == 'overdue' %}color:#dc2626;{% endif %}">
                    {{ invoice.dueAt ? invoice.dueAt|date('d/m/Y') : '—' }}
                </div>
                <div class="inv-amount">{{ invoice.totalTtc|number_format(0, ',', ' ') }} €</div>
            </a>
            {% endfor %}
        {% endif %}
    </div>

    {# Sidebar droite : Cette semaine + Reçus scannés #}
    <div style="display:flex;flex-direction:column;gap:16px;">

        {# Cette semaine #}
        <div class="card">
            <div class="card-title" style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                Cette semaine
            </div>

            {% if nextUrssaf %}
            {% set urssafDue = nextUrssaf.periodEnd|date_modify('first day of next month')|date_modify('last day of this month') %}
            <div class="upcoming-row">
                <div class="upcoming-days-box {% if urssafDaysLeft <= 7 %}days-warn{% else %}days-info{% endif %}">
                    <span class="days-num">{{ urssafDaysLeft }}</span>
                    <span class="days-label">JOURS</span>
                </div>
                <div class="upcoming-info">
                    <div class="upcoming-title">Déclaration URSSAF</div>
                    <div class="upcoming-date">{{ nextUrssaf.periodLabel }}</div>
                </div>
                <div class="upcoming-amount">{{ nextUrssaf.cotisationAmount|number_format(0, ',', ' ') }} €</div>
            </div>
            {% endif %}

            {% for invoice in dueSoonInvoices %}
            {% set daysLeft = ('now'|date('Y-m-d')|date_modify('0 day') is same as invoice.dueAt) ? 0 : invoice.dueAt|date('U') - 'now'|date('U') %}
            <div class="upcoming-row">
                <div class="upcoming-days-box days-info">
                    <span class="days-num">{{ ((invoice.dueAt|date('U') - 'now'|date('U')) / 86400)|round(0, 'ceil') }}</span>
                    <span class="days-label">JOURS</span>
                </div>
                <div class="upcoming-info">
                    <div class="upcoming-title">Échéance {{ invoice.number }}</div>
                    <div class="upcoming-date">{{ invoice.dueAt|date('d/m/Y') }}</div>
                </div>
                <div class="upcoming-amount">{{ invoice.totalTtc|number_format(0, ',', ' ') }} €</div>
            </div>
            {% endfor %}

            {% if not nextUrssaf and dueSoonInvoices is empty %}
            <div style="text-align:center;color:#9ca3af;font-size:13px;padding:16px 0;">Aucune échéance proche</div>
            {% endif %}
        </div>

        {# Reçus scannés #}
        <div class="card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                <div class="card-title" style="display:flex;align-items:center;gap:8px;margin-bottom:0;">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2v20l3-2 3 2 3-2 3 2 3-2 1 2V2z"/><path d="M8 7h8M8 11h8M8 15h5"/></svg>
                    Reçus scannés
                </div>
                <a href="{{ path('app_expense_new') }}" class="btn btn-secondary btn-sm" style="font-size:11px;display:inline-flex;align-items:center;gap:4px;">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 16V4M5 11l7-7 7 7M4 20h16"/></svg>
                    Importer
                </a>
            </div>

            {% if recentOcrExpenses is empty %}
            <div style="text-align:center;color:#9ca3af;font-size:13px;padding:16px 0;">
                Aucun reçu scanné encore.<br>
                <a href="{{ path('app_expense_new') }}" style="color:#2563eb;">Scanner un reçu →</a>
            </div>
            {% else %}
            {% for expense in recentOcrExpenses %}
            <a href="{{ path('app_expense_show', {id: expense.id}) }}" class="receipt-row">
                <div class="receipt-thumb">📄</div>
                <div class="receipt-info">
                    <div class="receipt-vendor">{{ expense.vendor }}</div>
                    <div class="receipt-meta">{{ expense.date|date('d/m') }} · {{ expense.category ? expense.category.label : '—' }}</div>
                </div>
                <div style="text-align:right;">
                    <div class="receipt-amount">{{ expense.amountTtc|number_format(2, ',', ' ') }} €</div>
                    {% if expense.ocrConfidence is not null %}
                    {% set pct = (expense.ocrConfidence * 100)|round %}
                    <span class="ocr-badge {% if pct >= 80 %}ocr-high{% elseif pct >= 50 %}ocr-medium{% else %}ocr-low{% endif %}">
                        ● OCR {{ pct }} %
                    </span>
                    {% endif %}
                </div>
            </a>
            {% endfor %}
            {% endif %}
        </div>

        {# Mon expert-comptable — plan expert uniquement #}
        {% if app.user.plan == 'expert' %}
        <div class="card">
            <div class="card-title" style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Mon expert-comptable
            </div>

            {% if linkedAccountant %}
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
                <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#2563eb,#7c3aed);color:#fff;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;flex-shrink:0;">
                    {{ linkedAccountant.firstName|first|upper }}{{ linkedAccountant.lastName|first|upper }}
                </div>
                <div>
                    <div style="font-size:13px;font-weight:700;color:#1c1a17;">{{ linkedAccountant.fullName }}</div>
                    {% if linkedAccountant.firm %}
                    <div style="font-size:11.5px;color:#6b7280;">{{ linkedAccountant.firm }}</div>
                    {% endif %}
                    <div style="font-size:11px;color:#9ca3af;">{{ linkedAccountant.email }}</div>
                </div>
            </div>
            {% if linkedAccountant.registrationNumber %}
            <div style="font-size:11px;color:#9ca3af;margin-bottom:10px;">N° {{ linkedAccountant.registrationNumber }}</div>
            {% endif %}
            <a href="mailto:{{ linkedAccountant.email }}" class="btn btn-secondary" style="width:100%;justify-content:center;font-size:12px;">
                Contacter mon expert →
            </a>
            {% else %}
            <div style="text-align:center;color:#9ca3af;font-size:13px;padding:12px 0 8px;">
                Aucun expert-comptable lié.<br>
                <a href="{{ path('app_subscription_manage') }}" style="color:#2563eb;font-size:12px;">Inviter un expert →</a>
            </div>
            {% endif %}
        </div>
        {% endif %}

    </div>
</div>

{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="{{ asset('js/dashboard.js') }}"></script>
<script>
initMonthlyChart({{ monthLabels|raw }}, {{ chartRevenuesTtc|raw }}, {{ chartExpenses|raw }}, {{ currentMonth }});
{% if chartCatData != '[]' %}
initCategoryChart({{ chartCatLabels|raw }}, {{ chartCatData|raw }});
{% endif %}
</script>
{% endblock %}
