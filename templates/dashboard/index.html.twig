{% extends 'base.html.twig' %}
{% block title %}Dashboard — GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Tableau de bord</h1>
    <div style="font-size:13px; color:#6b7280;">
        Bonjour, <strong>{{ app.user.firstName }}</strong> · {{ 'now'|date('d/m/Y') }}
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/dashboard.css') }}">
{% endblock %}

{% block body %}

{# Alertes #}
{% if overdueCount > 0 %}
<div class="alert alert-error" style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
    <span style="font-size:18px;">⚠️</span>
    <div>
        <strong>{{ overdueCount }} facture{{ overdueCount > 1 ? 's' : '' }} en retard</strong> —
        <a href="{{ path('app_invoices') }}" style="color:inherit;text-decoration:underline;">Voir les factures</a>
    </div>
</div>
{% endif %}
{% if caYear >= tvaThreshold * 0.9 %}
<div class="alert alert-error" style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
    <span style="font-size:18px;">⚠️</span>
    <div>
        <strong>Seuil de franchise TVA approché</strong> — CA {{ year }} : {{ caYear|number_format(0, ',', ' ') }} € /
        seuil {{ tvaThreshold|number_format(0, ',', ' ') }} €
    </div>
</div>
{% endif %}

{# Hero CA + graphique CA vs Dépenses #}
<div class="hero-card">
    <div style="position:relative;z-index:1;">
        <div class="hero-label">Chiffre d'affaires {{ year }}</div>
        <div class="hero-amount">{{ caYear|number_format(0, ',', ' ') }} €</div>
        <div class="hero-sub">
            <span>Ce mois :</span>
            <span class="hero-sub-chip">{{ caMonth|number_format(0, ',', ' ') }} €</span>
        </div>
    </div>
    <div class="hero-chart-wrap">
        <canvas id="chart-monthly" height="100"></canvas>
    </div>
</div>

{# 3 KPIs : factures, dépenses, URSSAF #}
<div class="kpi-row">
    <div class="kpi {% if overdueCount > 0 %}kpi-danger{% elseif pending.count > 0 %}kpi-warning{% endif %}">
        <div class="kpi-label">Factures en attente</div>
        <div class="kpi-value">{{ pending.amount|number_format(0, ',', ' ') }} €</div>
        <div class="kpi-sub">
            {{ pending.count }} facture{{ pending.count != 1 ? 's' : '' }}
            {% if overdueCount > 0 %} · <span style="color:#dc2626;font-weight:600;">{{ overdueCount }} en retard</span>{% endif %}
        </div>
    </div>
    <div class="kpi">
        <div class="kpi-label">Dépenses {{ year }}</div>
        <div class="kpi-value">{{ expensesYear|number_format(0, ',', ' ') }} €</div>
        <div class="kpi-sub">Ce mois : {{ expensesMonth|number_format(0, ',', ' ') }} €</div>
    </div>
    <div class="kpi {% if nextUrssaf %}kpi-warning{% else %}kpi-green{% endif %}">
        <div class="kpi-label">Cotisations {{ year }}</div>
        <div class="kpi-value">{{ urssafYear|number_format(0, ',', ' ') }} €</div>
        <div class="kpi-sub">
            {% if nextUrssaf %}
                À déclarer : {{ nextUrssaf.periodLabel }}
            {% else %}
                Tout est déclaré ✓
            {% endif %}
        </div>
    </div>
</div>

{# Bottom : recouvrement + factures récentes #}
<div class="bottom-grid">
    <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;">
            <div class="card-title" style="margin-bottom:0;">Taux de recouvrement {{ year }}</div>
            <div>
                <span style="font-family:'JetBrains Mono',monospace;font-variant-numeric:tabular-nums;font-size:26px;font-weight:700;color:{% if recoveryRate >= 80 %}#16a34a{% elseif recoveryRate >= 50 %}#f97316{% else %}#ef4444{% endif %};">{{ recoveryRate }} %</span>
            </div>
        </div>
        <div class="progress-bar-wrap" style="margin-bottom:16px;">
            <div class="progress-bar" style="width:{{ recoveryRate }}%; background:{% if recoveryRate >= 80 %}#16a34a{% elseif recoveryRate >= 50 %}#f97316{% else %}#ef4444{% endif %};"></div>
        </div>

        {% if topClients %}
        <div>
            <div style="font-size:11px;font-weight:600;color:#374151;text-transform:uppercase;letter-spacing:.04em;margin-bottom:10px;">Top clients</div>
            {% set maxVal = topClients[0].total %}
            {% for c in topClients %}
            <div style="margin-bottom:10px;">
                <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:3px;">
                    <span>{{ c.name }}</span>
                    <strong class="mono">{{ c.total|number_format(0, ',', ' ') }} €</strong>
                </div>
                <div class="progress-bar-wrap">
                    <div class="progress-bar" style="width:{{ maxVal > 0 ? (c.total / maxVal * 100)|round : 0 }}%;"></div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <div class="cat-wrap" style="flex-direction:column;gap:8px;padding:16px 0;">
            {% if chartCatData != '[]' %}
                <canvas id="chart-categories" height="140"></canvas>
            {% else %}
                <div style="text-align:center;color:#9ca3af;font-size:13px;">Aucune dépense enregistrée</div>
            {% endif %}
        </div>
        {% endif %}
    </div>

    <div class="card">
        <div class="card-title">Factures récentes</div>
        {% if recentInvoices is empty %}
            <div style="text-align:center;color:#9ca3af;padding:24px 0;font-size:13px;">Aucune facture</div>
        {% else %}
            {% for invoice in recentInvoices %}
            <div style="display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid #f3f4f6;">
                <div>
                    <a href="{{ path('app_invoice_show', {id: invoice.id}) }}" style="font-weight:600;font-size:13px;color:#111827;">
                        {{ invoice.number }}
                    </a>
                    <div style="font-size:11px;color:#9ca3af;margin-top:1px;">{{ invoice.client.name }} · {{ invoice.issuedAt|date('d/m/Y') }}</div>
                </div>
                <div style="text-align:right;">
                    <div class="mono" style="font-size:13px;font-weight:600;">{{ invoice.totalTtc|number_format(0, ',', ' ') }} €</div>
                    <div style="margin-top:3px;">
                        {% if invoice.status == 'paid' %}<span class="st-badge st-paid" style="font-size:10px;">Payée</span>
                        {% elseif invoice.status == 'sent' %}<span class="st-badge st-sent" style="font-size:10px;">Envoyée</span>
                        {% elseif invoice.status == 'overdue' %}<span class="st-badge st-late" style="font-size:10px;">En retard</span>
                        {% else %}<span class="st-badge st-draft" style="font-size:10px;">Brouillon</span>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endfor %}
            <div style="margin-top:12px;text-align:center;">
                <a href="{{ path('app_invoices') }}" style="font-size:13px;color:#2563eb;">Toutes les factures →</a>
            </div>
        {% endif %}
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="{{ asset('js/dashboard.js') }}" defer></script>
<script>
initMonthlyChart({{ monthLabels|raw }}, {{ chartRevenues|raw }}, {{ chartExpenses|raw }});
{% if chartCatData != '[]' %}
initCategoryChart({{ chartCatLabels|raw }}, {{ chartCatData|raw }});
{% endif %}
</script>
{% endblock %}
