<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Connexion Expert-Comptable — GestoPro</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, sans-serif; background: #f3f4f6; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .box { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 32px; width: 400px; }
        .brand { text-align: center; margin-bottom: 24px; }
        .brand-name { font-size: 24px; font-weight: 700; color: #1e3a5f; }
        .brand-sub { font-size: 13px; color: #6b7280; margin-top: 4px; }
        label { display: block; font-size: 13px; font-weight: 500; margin-bottom: 5px; }
        input { width: 100%; padding: 9px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; margin-bottom: 14px; }
        button { width: 100%; padding: 10px; background: #1e3a5f; color: #fff; border: none; border-radius: 6px; font-size: 15px; cursor: pointer; margin-top: 4px; }
        button:hover { background: #1e40af; }
        .error { background: #fee2e2; border: 1px solid #fca5a5; color: #991b1b; padding: 10px 14px; border-radius: 6px; font-size: 13px; margin-bottom: 16px; }
        .success { background: #dcfce7; border: 1px solid #86efac; color: #166534; padding: 10px 14px; border-radius: 6px; font-size: 13px; margin-bottom: 16px; }
        .links { text-align: center; margin-top: 16px; font-size: 13px; color: #6b7280; }
        .links a { color: #1e3a5f; }
    </style>
</head>
<body>
<div class="box">
    <div class="brand">
        <div class="brand-name">GestoPro</div>
        <div class="brand-sub">Portail Expert-Comptable</div>
    </div>

    {% if error %}
        <div class="error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}
    {% for flash in app.flashes('success') %}
        <div class="success">{{ flash }}</div>
    {% endfor %}

    <form method="post">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <label>Email</label>
        <input type="email" name="email" value="{{ last_username }}" required autofocus>
        <label>Mot de passe</label>
        <input type="password" name="password" required>
        <button type="submit">Se connecter</button>
    </form>

    <div class="links">
        Pas encore de compte ? <a href="{{ path('expert_register') }}">Créer un compte expert</a>
    </div>
</div>
</body>
</html>
