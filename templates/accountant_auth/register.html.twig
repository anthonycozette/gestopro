<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Inscription Expert-Comptable — GestoPro</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, sans-serif; background: #f3f4f6; display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 24px; }
        .box { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 32px; width: 460px; }
        .brand { text-align: center; margin-bottom: 24px; }
        .brand-name { font-size: 22px; font-weight: 700; color: #1e3a5f; }
        .brand-sub { font-size: 13px; color: #6b7280; margin-top: 4px; }
        label { display: block; font-size: 13px; font-weight: 500; margin-bottom: 5px; }
        input { width: 100%; padding: 9px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; margin-bottom: 14px; }
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        button { width: 100%; padding: 10px; background: #1e3a5f; color: #fff; border: none; border-radius: 6px; font-size: 15px; cursor: pointer; margin-top: 4px; }
        button:hover { background: #1e40af; }
        .error { background: #fee2e2; border: 1px solid #fca5a5; color: #991b1b; padding: 10px 14px; border-radius: 6px; font-size: 13px; margin-bottom: 16px; }
        .links { text-align: center; margin-top: 16px; font-size: 13px; color: #6b7280; }
        .links a { color: #1e3a5f; }
        .section { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: #6b7280; margin: 16px 0 10px; border-top: 1px solid #e5e7eb; padding-top: 16px; }
    </style>
</head>
<body>
<div class="box">
    <div class="brand">
        <div class="brand-name">GestoPro</div>
        <div class="brand-sub">Créer un compte Expert-Comptable</div>
    </div>

    {% if error %}<div class="error">{{ error }}</div>{% endif %}

    <form method="post">
        <div class="form-grid">
            <div>
                <label>Prénom <span style="color:#ef4444">*</span></label>
                <input type="text" name="first_name" required>
            </div>
            <div>
                <label>Nom <span style="color:#ef4444">*</span></label>
                <input type="text" name="last_name" required>
            </div>
        </div>

        <label>Email professionnel <span style="color:#ef4444">*</span></label>
        <input type="email" name="email" required>

        <label>Mot de passe <span style="color:#ef4444">*</span></label>
        <input type="password" name="password" required minlength="8">

        <div class="section">Informations professionnelles (optionnel)</div>

        <label>Cabinet / Société</label>
        <input type="text" name="firm" placeholder="Ex : Cabinet Dupont & Associés">

        <label>N° inscription (ORIAS / Ordre des EC)</label>
        <input type="text" name="registration_number" placeholder="Ex : 12345678">

        <button type="submit">Créer mon compte</button>
    </form>

    <div class="links">
        Déjà inscrit ? <a href="{{ path('expert_login') }}">Se connecter</a>
    </div>
</div>
</body>
</html>
