{% extends 'base_expert.html.twig' %}
{% block title %}Clients — Expert GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Mes clients</h1>
</div>
{% endblock %}

{% block body %}
<div class="card">
    {% if invitations is empty %}
        <div class="empty-state">
            <p>Aucun client lié pour l'instant. Les clients vous trouveront dans l'annuaire.</p>
            <a href="{{ path('expert_profile') }}" class="btn btn-primary">Compléter mon profil</a>
        </div>
    {% else %}
        <table>
            <thead>
                <tr>
                    <th>Client</th>
                    <th>Email</th>
                    <th>Depuis le</th>
                    <th>Statut</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for inv in invitations %}
                <tr>
                    <td><strong>{{ inv.user.firstName }} {{ inv.user.lastName }}</strong></td>
                    <td>{{ inv.user.email }}</td>
                    <td>{{ inv.createdAt|date('d/m/Y') }}</td>
                    <td>
                        {% if inv.status == 'accepted' %}<span class="badge badge-green">Lié</span>
                        {% elseif inv.status == 'declined' %}<span class="badge badge-red">Refusé</span>
                        {% else %}<span class="badge badge-yellow">En attente</span>{% endif %}
                    </td>
                    <td style="text-align:right;">
                        {% if inv.status == 'accepted' %}
                            <a href="{{ path('expert_client_detail', {id: inv.id}) }}" class="btn btn-primary btn-sm">Voir la fiche</a>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
{% endblock %}
