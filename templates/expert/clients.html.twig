{% extends 'base_expert.html.twig' %}
{% block title %}Clients — Expert GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Mes clients</h1>
    <div class="topbar-actions">
        <a href="{{ path('expert_invite') }}" class="btn btn-primary">+ Inviter un client</a>
    </div>
</div>
{% endblock %}

{% block body %}
<div class="card">
    {% if invitations is empty %}
        <div class="empty-state">
            <p>Aucun client invité pour l'instant.</p>
            <a href="{{ path('expert_invite') }}" class="btn btn-primary">Envoyer une invitation</a>
        </div>
    {% else %}
        <table>
            <thead>
                <tr>
                    <th>Client</th>
                    <th>Email</th>
                    <th>Date invitation</th>
                    <th>Expiration</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                {% for inv in invitations %}
                <tr>
                    <td><strong>{{ inv.user.firstName }} {{ inv.user.lastName }}</strong></td>
                    <td>{{ inv.user.email }}</td>
                    <td>{{ inv.createdAt|date('d/m/Y') }}</td>
                    <td>
                        {% if inv.expiresAt %}
                            {% if inv.expired %}<span style="color:#ef4444;">{{ inv.expiresAt|date('d/m/Y') }}</span>
                            {% else %}{{ inv.expiresAt|date('d/m/Y') }}{% endif %}
                        {% else %}—{% endif %}
                    </td>
                    <td>
                        {% if inv.status == 'accepted' %}<span class="badge badge-green">Acceptée</span>
                        {% elseif inv.status == 'declined' %}<span class="badge badge-red">Refusée</span>
                        {% elseif inv.expired %}<span class="badge badge-gray">Expirée</span>
                        {% else %}<span class="badge badge-yellow">En attente</span>{% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
{% endblock %}
