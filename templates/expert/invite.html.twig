{% extends 'base_expert.html.twig' %}
{% block title %}Inviter un client — Expert GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Inviter un client</h1>
</div>
{% endblock %}

{% block body %}
<div style="max-width:560px;">
    <div class="card">
        <div class="card-title">Envoyer une invitation</div>
        <p style="font-size:13px;color:#6b7280;margin-bottom:20px;line-height:1.6;">
            Saisissez l'email du client GestoPro que vous souhaitez accompagner.
            Il recevra un lien pour accepter ou refuser la mise en relation.
            Une fois acceptée, vous pourrez consulter et valider ses bilans.
        </p>

        {% if error %}<div class="alert alert-error">{{ error }}</div>{% endif %}

        <form method="post">
            <div class="form-group">
                <label>Email du client <span style="color:#ef4444">*</span></label>
                <input type="email" name="email" class="form-control" required autofocus
                       placeholder="client@exemple.fr">
            </div>
            <button type="submit" class="btn btn-primary">Créer l'invitation</button>
        </form>

        {% if link %}
        <div style="margin-top:24px;padding:16px;background:#f0fdf4;border:1px solid #86efac;border-radius:6px;">
            <div style="font-size:13px;font-weight:600;color:#166534;margin-bottom:8px;">✓ Invitation créée</div>
            <div style="font-size:12px;color:#374151;margin-bottom:8px;">
                Transmettez ce lien à votre client par email ou message :
            </div>
            <div style="font-size:12px;background:#fff;border:1px solid #d1d5db;border-radius:4px;padding:8px;word-break:break-all;font-family:monospace;">
                {{ link }}
            </div>
            <div style="font-size:11px;color:#6b7280;margin-top:8px;">
                Valable 7 jours.
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
