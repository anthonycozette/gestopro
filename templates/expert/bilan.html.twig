{% extends 'base_expert.html.twig' %}
{% block title %}Bilan {{ sheet.period }} — Expert GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Bilan {{ sheet.period }} — {{ sheet.user.firstName }} {{ sheet.user.lastName }}</h1>
    <div class="topbar-actions">
        <a href="{{ path('expert_dashboard') }}" class="btn btn-secondary">Retour</a>
    </div>
</div>
{% endblock %}

{% block body %}
{% set fd = sheet.financialData %}
<div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;align-items:start;">

    <div>
        <div class="card">
            <div class="card-title">Données financières — {{ sheet.period }}</div>
            <div style="font-size:12px;color:#6b7280;margin-bottom:16px;">
                {{ sheet.periodStart|date('d/m/Y') }} → {{ sheet.periodEnd|date('d/m/Y') }}
            </div>

            <table style="width:340px;">
                <tr>
                    <td style="color:#6b7280;padding:8px 0;">Chiffre d'affaires HT</td>
                    <td style="text-align:right;font-weight:600;">{{ fd.revenue_ht|number_format(2, ',', ' ') }} €</td>
                </tr>
                <tr>
                    <td style="color:#6b7280;padding:8px 0;">Dépenses TTC</td>
                    <td style="text-align:right;color:#ef4444;">− {{ fd.expenses_ttc|number_format(2, ',', ' ') }} €</td>
                </tr>
                <tr>
                    <td style="color:#6b7280;padding:8px 0;">Cotisations URSSAF</td>
                    <td style="text-align:right;color:#ef4444;">− {{ fd.cotisations|number_format(2, ',', ' ') }} €</td>
                </tr>
                <tr>
                    <td colspan="2" style="padding:0;height:2px;background:#e5e7eb;"></td>
                </tr>
                <tr>
                    <td style="font-weight:700;padding:10px 0;font-size:15px;">Résultat net estimé</td>
                    <td style="text-align:right;font-weight:700;font-size:18px;color:{% if fd.net_result < 0 %}#ef4444{% else %}#16a34a{% endif %};">
                        {{ fd.net_result|number_format(2, ',', ' ') }} €
                    </td>
                </tr>
            </table>
        </div>

        {% if sheet.accountantComment %}
        <div class="card">
            <div class="card-title">Commentaire de l'expert</div>
            <div style="font-size:14px;line-height:1.6;white-space:pre-wrap;color:#374151;">{{ sheet.accountantComment }}</div>
        </div>
        {% endif %}

        {% if sheet.status == 'pending_review' or sheet.status == 'annotated' %}
        <div class="card">
            <div class="card-title">Annoter ce bilan</div>
            <form method="post" action="{{ path('expert_bilan_annotate', {id: sheet.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('annotate_' ~ sheet.id) }}">
                <div class="form-group">
                    <label>Commentaire / observations</label>
                    <textarea name="comment" class="form-control" rows="5"
                        placeholder="Remarques, recommandations, points de vigilance…">{{ sheet.accountantComment }}</textarea>
                </div>
                <button type="submit" class="btn btn-primary">Enregistrer les annotations</button>
            </form>
        </div>
        {% endif %}
    </div>

    <div>
        <div class="card">
            <div class="card-title">Statut du bilan</div>
            <div style="margin-bottom:16px;">
                {% if sheet.status == 'validated' %}
                    <span class="badge badge-green" style="font-size:13px;padding:5px 12px;">Validé</span>
                {% elseif sheet.status == 'annotated' %}
                    <span class="badge badge-blue" style="font-size:13px;padding:5px 12px;">Annoté</span>
                {% elseif sheet.status == 'pending_review' %}
                    <span class="badge badge-yellow" style="font-size:13px;padding:5px 12px;">En attente de révision</span>
                {% endif %}
            </div>

            {% if sheet.validatedAt %}
            <div style="font-size:13px;color:#6b7280;margin-bottom:12px;">
                Validé le {{ sheet.validatedAt|date('d/m/Y à H:i') }}<br>
                par {{ sheet.accountant.fullName }}
            </div>
            {% endif %}

            {% if sheet.status != 'validated' %}
            <div style="border-top:1px solid #e5e7eb;padding-top:12px;margin-top:4px;">
                <form method="post" action="{{ path('expert_bilan_validate', {id: sheet.id}) }}"
                      onsubmit="return confirm('Valider et tamponner ce bilan définitivement ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('validate_' ~ sheet.id) }}">
                    <button type="submit" class="btn btn-success" style="width:100%;">
                        ✓ Valider et tamponner
                    </button>
                </form>
            </div>
            {% endif %}
        </div>

        <div class="card">
            <div class="card-title">Client</div>
            <div style="font-size:14px;">
                <strong>{{ sheet.user.firstName }} {{ sheet.user.lastName }}</strong><br>
                <span style="color:#6b7280;font-size:13px;">{{ sheet.user.email }}</span>
                {% if sheet.user.siret %}
                <br><span style="color:#6b7280;font-size:12px;">SIRET : {{ sheet.user.siret }}</span>
                {% endif %}
            </div>
        </div>
    </div>

</div>
{% endblock %}
