{% extends 'base_expert.html.twig' %}
{% block title %}Dashboard Expert — GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Tableau de bord</h1>
    <div style="font-size:13px;color:#6b7280;">
        Bonjour, <strong>{{ accountant.firstName }}</strong>
        {% if accountant.firm %} · {{ accountant.firm }}{% endif %}
    </div>
</div>
{% endblock %}

{% block body %}

{# ── Demandes clients en attente ── #}
{% if pendingRequests is not empty %}
<div class="notif-card">
    <div class="card-title" style="color:#ea580c;font-size:11px;">
        Demandes de mise en relation
        <span class="notif-badge">{{ pendingRequests|length }}</span>
    </div>
    <table>
        <thead>
            <tr>
                <th>Client</th>
                <th>Email</th>
                <th>Reçue le</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for inv in pendingRequests %}
            <tr>
                <td><strong>{{ inv.user.firstName }} {{ inv.user.lastName }}</strong></td>
                <td style="color:#6b7280;">{{ inv.user.email }}</td>
                <td style="color:#6b7280;">{{ inv.createdAt|date('d/m/Y') }}</td>
                <td style="text-align:right;">
                    <form method="post" action="{{ path('expert_request_approve', {id: inv.id}) }}" style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('inv_' ~ inv.id) }}">
                        <button type="submit" class="btn btn-success btn-sm">Accepter</button>
                    </form>
                    <form method="post" action="{{ path('expert_request_decline', {id: inv.id}) }}" style="display:inline;margin-left:6px;">
                        <input type="hidden" name="_token" value="{{ csrf_token('inv_' ~ inv.id) }}">
                        <button type="submit" class="btn btn-danger btn-sm"
                                data-confirm="Refuser cette demande ?" data-confirm-variant="danger">Refuser</button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

{# ── Stat tiles ── #}
<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-card-label">Bilans à réviser</div>
        <div class="stat-card-value {{ pending|length > 0 ? 'c-orange' : 'c-green' }}">{{ pending|length }}</div>
        <div class="stat-card-sub">bilans en attente</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-label">Clients liés</div>
        <div class="stat-card-value c-navy">{{ clientCount }}</div>
        <div class="stat-card-sub">clients actifs</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-label">Bilans traités</div>
        <div class="stat-card-value c-green">{{ others|length }}</div>
        <div class="stat-card-sub">annotés ou validés</div>
    </div>
</div>

{# ── Bilans à réviser ── #}
{% if pending is not empty %}
<div class="card">
    <div class="card-title" style="color:#ea580c;">En attente de révision</div>
    <table>
        <thead>
            <tr>
                <th>Client</th>
                <th>Période</th>
                <th style="text-align:right">CA HT</th>
                <th style="text-align:right">Résultat net</th>
                <th>Soumis le</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for s in pending %}
            {% set fd = s.financialData %}
            <tr>
                <td><strong>{{ s.user.firstName }} {{ s.user.lastName }}</strong></td>
                <td>{{ s.period }}</td>
                <td style="text-align:right" class="mono">{{ fd.revenue_ht|number_format(2, ',', ' ') }} €</td>
                <td style="text-align:right;font-weight:600;" class="mono"
                    style="color:{{ fd.net_result < 0 ? '#ef4444' : '#16a34a' }};">
                    {{ fd.net_result|number_format(2, ',', ' ') }} €
                </td>
                <td style="color:#6b7280;">{{ s.createdAt|date('d/m/Y') }}</td>
                <td style="text-align:right">
                    <a href="{{ path('expert_bilan_show', {id: s.id}) }}" class="btn btn-primary btn-sm">Réviser</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

{# ── Bilans traités ── #}
{% if others is not empty %}
<div class="card">
    <div class="card-title">Bilans traités</div>
    <table>
        <thead>
            <tr>
                <th>Client</th>
                <th>Période</th>
                <th style="text-align:right">CA HT</th>
                <th>Statut</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for s in others %}
            <tr>
                <td>{{ s.user.firstName }} {{ s.user.lastName }}</td>
                <td>{{ s.period }}</td>
                <td style="text-align:right" class="mono">{{ s.financialData.revenue_ht|number_format(2, ',', ' ') }} €</td>
                <td>
                    {% if s.status == 'validated' %}<span class="badge badge-green">Validé</span>
                    {% elseif s.status == 'annotated' %}<span class="badge badge-blue">Annoté</span>
                    {% endif %}
                </td>
                <td style="text-align:right">
                    <a href="{{ path('expert_bilan_show', {id: s.id}) }}" class="btn btn-secondary btn-sm">Voir</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

{% if pending is empty and others is empty %}
<div class="card">
    <div class="empty-state">
        <p>Aucun bilan à réviser pour l'instant.<br>Les clients vous trouveront dans l'annuaire.</p>
        <a href="{{ path('expert_profile') }}" class="btn btn-primary">Compléter mon profil</a>
    </div>
</div>
{% endif %}

{% endblock %}
