{% extends 'base.html.twig' %}
{% block title %}{{ quote.number }} — GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>{{ quote.number }}</h1>
    <div class="topbar-actions">
        {% if quote.status == 'draft' %}
            <form method="post" action="{{ path('app_quote_send', {id: quote.id}) }}" style="display:inline">
                <input type="hidden" name="_token" value="{{ csrf_token('send_quote_' ~ quote.id) }}">
                <button type="submit" class="btn btn-primary">Envoyer au client</button>
            </form>
            <a href="{{ path('app_quote_edit', {id: quote.id}) }}" class="btn btn-secondary">Modifier</a>
        {% endif %}
        {% if quote.status in ['sent', 'accepted'] %}
            <form method="post" action="{{ path('app_quote_convert', {id: quote.id}) }}" style="display:inline"
                  onsubmit="return confirm('Convertir ce devis en facture ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('convert_quote_' ~ quote.id) }}">
                <button type="submit" class="btn btn-success">Convertir en facture</button>
            </form>
        {% endif %}
        {% if quote.status == 'sent' %}
            <form method="post" action="{{ path('app_quote_accept', {id: quote.id}) }}" style="display:inline">
                <input type="hidden" name="_token" value="{{ csrf_token('accept_quote_' ~ quote.id) }}">
                <button type="submit" class="btn btn-success">Marquer accepté</button>
            </form>
            <form method="post" action="{{ path('app_quote_decline', {id: quote.id}) }}" style="display:inline">
                <input type="hidden" name="_token" value="{{ csrf_token('decline_quote_' ~ quote.id) }}">
                <button type="submit" class="btn btn-danger">Marquer refusé</button>
            </form>
        {% endif %}
        <a href="{{ path('app_quotes') }}" class="btn btn-secondary">Retour</a>
    </div>
</div>
{% endblock %}

{% block body %}
<div style="display:grid; grid-template-columns:2fr 1fr; gap:20px; align-items:start;">
    <div>
        <!-- Lignes -->
        <div class="card">
            <div style="display:flex; justify-content:space-between; margin-bottom:16px;">
                <div>
                    <div style="font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;">Client</div>
                    <div style="font-size:16px;font-weight:600;">{{ quote.client.name }}</div>
                    {% if quote.client.email %}<div style="color:#6b7280;font-size:13px;">{{ quote.client.email }}</div>{% endif %}
                    {% if quote.client.fullAddress %}<div style="color:#6b7280;font-size:13px;">{{ quote.client.fullAddress }}</div>{% endif %}
                </div>
                <div style="text-align:right;">
                    <div style="font-size:12px;color:#6b7280;text-transform:uppercase;">Émis le</div>
                    <div>{{ quote.issuedAt|date('d/m/Y') }}</div>
                    {% if quote.dueAt %}
                    <div style="font-size:12px;color:#6b7280;margin-top:8px;text-transform:uppercase;">Valable jusqu'au</div>
                    <div>{{ quote.dueAt|date('d/m/Y') }}</div>
                    {% endif %}
                </div>
            </div>

            <table>
                <thead>
                    <tr>
                        <th>Description</th>
                        <th style="text-align:right">Qté</th>
                        <th style="text-align:right">PU HT</th>
                        <th style="text-align:right">TVA</th>
                        <th style="text-align:right">Total HT</th>
                    </tr>
                </thead>
                <tbody>
                    {% for line in quote.lines %}
                    <tr>
                        <td>{{ line.description }}</td>
                        <td style="text-align:right">{{ line.quantity }}</td>
                        <td style="text-align:right">{{ line.unitPrice|number_format(2, ',', ' ') }} €</td>
                        <td style="text-align:right">{{ line.tvaRate }} %</td>
                        <td style="text-align:right"><strong>{{ line.totalHt|number_format(2, ',', ' ') }} €</strong></td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>

            <div style="border-top:2px solid #e5e7eb; margin-top:12px; padding-top:12px;">
                <div style="display:flex; justify-content:flex-end; gap:40px;">
                    <div style="text-align:right;">
                        <div style="color:#6b7280; font-size:13px; margin-bottom:4px;">Total HT</div>
                        <div style="color:#6b7280; font-size:13px; margin-bottom:8px;">TVA</div>
                        <div style="font-weight:700; font-size:16px;">Total TTC</div>
                    </div>
                    <div style="text-align:right; min-width:120px;">
                        <div style="font-size:13px; margin-bottom:4px;">{{ quote.totalHt|number_format(2, ',', ' ') }} €</div>
                        <div style="font-size:13px; margin-bottom:8px;">{{ quote.totalTva|number_format(2, ',', ' ') }} €</div>
                        <div style="font-weight:700; font-size:16px;">{{ quote.totalTtc|number_format(2, ',', ' ') }} €</div>
                    </div>
                </div>
            </div>

            {% if quote.notes %}
            <div style="margin-top:16px; padding-top:12px; border-top:1px solid #e5e7eb; color:#6b7280; font-size:13px;">
                {{ quote.notes }}
            </div>
            {% endif %}
        </div>
    </div>

    <div>
        <div class="card">
            <div class="card-title">Statut</div>
            <div style="margin-bottom:16px;">
                {% if quote.status == 'draft' %}<span class="badge badge-gray" style="font-size:14px;padding:5px 12px;">Brouillon</span>
                {% elseif quote.status == 'sent' %}<span class="badge badge-blue" style="font-size:14px;padding:5px 12px;">Envoyé</span>
                {% elseif quote.status == 'accepted' %}<span class="badge badge-green" style="font-size:14px;padding:5px 12px;">Accepté</span>
                {% elseif quote.status == 'declined' %}<span class="badge badge-red" style="font-size:14px;padding:5px 12px;">Refusé</span>
                {% elseif quote.status == 'expired' %}<span class="badge badge-orange" style="font-size:14px;padding:5px 12px;">Expiré</span>
                {% endif %}
            </div>

            {% if quote.status == 'draft' %}
            <div style="margin-top:16px; border-top:1px solid #e5e7eb; padding-top:12px;">
                <form method="post" action="{{ path('app_quote_delete', {id: quote.id}) }}"
                      onsubmit="return confirm('Supprimer ce devis définitivement ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_quote_' ~ quote.id) }}">
                    <button type="submit" class="btn btn-danger btn-sm" style="width:100%">Supprimer</button>
                </form>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
