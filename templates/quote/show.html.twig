{% extends 'base.html.twig' %}
{% block title %}{{ quote.number }} — GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
  <h1>{{ quote.number }}</h1>
  <div class="topbar-actions">
    {% if quote.status == 'draft' %}
      <form method="post" action="{{ path('app_quote_send', {id: quote.id}) }}" style="display:inline">
        <input type="hidden" name="_token" value="{{ csrf_token('send_quote_' ~ quote.id) }}">
        <button type="submit" class="btn btn-primary">Envoyer au client</button>
      </form>
      <a href="{{ path('app_quote_edit', {id: quote.id}) }}" class="btn btn-secondary">Modifier</a>
    {% endif %}
    {% if quote.status in ['sent', 'accepted'] %}
      <form method="post" action="{{ path('app_quote_convert', {id: quote.id}) }}" style="display:inline"
            onsubmit="return confirm('Convertir ce devis en facture ?')">
        <input type="hidden" name="_token" value="{{ csrf_token('convert_quote_' ~ quote.id) }}">
        <button type="submit" class="btn btn-success">Convertir en facture</button>
      </form>
    {% endif %}
    {% if quote.status == 'sent' %}
      <form method="post" action="{{ path('app_quote_accept', {id: quote.id}) }}" style="display:inline">
        <input type="hidden" name="_token" value="{{ csrf_token('accept_quote_' ~ quote.id) }}">
        <button type="submit" class="btn btn-success">Accepté</button>
      </form>
      <form method="post" action="{{ path('app_quote_decline', {id: quote.id}) }}" style="display:inline">
        <input type="hidden" name="_token" value="{{ csrf_token('decline_quote_' ~ quote.id) }}">
        <button type="submit" class="btn btn-danger">Refusé</button>
      </form>
    {% endif %}
    <a href="{{ path('app_quotes') }}" class="btn btn-secondary">Retour</a>
  </div>
</div>
{% endblock %}

{% block body %}
<div style="display:grid; grid-template-columns:2fr 1fr; gap:20px; align-items:start;">
  <div>
    <div class="card">
      <div style="display:flex; justify-content:space-between; margin-bottom:20px;">
        <div>
          <div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.07em;margin-bottom:4px;">Client</div>
          <div style="font-size:15px;font-weight:600;color:#0f172a;">{{ quote.client.name }}</div>
          {% if quote.client.email %}<div style="color:#9ca3af;font-size:13px;margin-top:2px;">{{ quote.client.email }}</div>{% endif %}
          {% if quote.client.fullAddress %}<div style="color:#9ca3af;font-size:13px;">{{ quote.client.fullAddress }}</div>{% endif %}
        </div>
        <div style="text-align:right;">
          <div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.07em;margin-bottom:4px;">Émis le</div>
          <div style="font-size:13.5px;color:#374151;">{{ quote.issuedAt|date('d/m/Y') }}</div>
          {% if quote.dueAt %}
          <div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.07em;margin-top:10px;margin-bottom:4px;">Valable jusqu'au</div>
          <div style="font-size:13.5px;color:#374151;">{{ quote.dueAt|date('d/m/Y') }}</div>
          {% endif %}
        </div>
      </div>

      <table>
        <thead>
          <tr>
            <th>Description</th>
            <th style="text-align:right">Qté</th>
            <th style="text-align:right">PU HT</th>
            <th style="text-align:right">TVA</th>
            <th style="text-align:right">Total HT</th>
          </tr>
        </thead>
        <tbody>
          {% for line in quote.lines %}
          <tr>
            <td>{{ line.description }}</td>
            <td style="text-align:right"><span class="mono">{{ line.quantity }}</span></td>
            <td style="text-align:right"><span class="mono">{{ line.unitPrice|number_format(2, ',', ' ') }} €</span></td>
            <td style="text-align:right"><span class="mono">{{ line.tvaRate }} %</span></td>
            <td style="text-align:right"><strong class="mono">{{ line.totalHt|number_format(2, ',', ' ') }} €</strong></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>

      <div style="border-top:2px solid #e8eaed; margin-top:12px; padding-top:14px;">
        <div style="display:flex; justify-content:flex-end; gap:40px;">
          <div style="text-align:right; color:#9ca3af; font-size:13px; line-height:1.9;">
            <div>Total HT</div><div>TVA</div>
            <div style="color:#0f172a; font-weight:700; font-size:15px; margin-top:6px; border-top:1px solid #e8eaed; padding-top:6px;">Total TTC</div>
          </div>
          <div style="text-align:right; min-width:120px; line-height:1.9;">
            <div class="mono" style="font-size:13px; color:#374151;">{{ quote.totalHt|number_format(2, ',', ' ') }} €</div>
            <div class="mono" style="font-size:13px; color:#374151;">{{ quote.totalTva|number_format(2, ',', ' ') }} €</div>
            <div class="mono" style="font-size:15px; font-weight:700; margin-top:6px; border-top:1px solid #e8eaed; padding-top:6px;">{{ quote.totalTtc|number_format(2, ',', ' ') }} €</div>
          </div>
        </div>
      </div>

      {% if quote.notes %}
      <div style="margin-top:16px; padding-top:12px; border-top:1px solid #f1f3f5; color:#9ca3af; font-size:13px; line-height:1.6;">
        {{ quote.notes }}
      </div>
      {% endif %}
    </div>
  </div>

  <div>
    <div class="card">
      <div class="card-title">Statut</div>
      <div style="margin-bottom:16px;">
        {% if quote.status == 'draft' %}<span class="st-badge st-draft" style="font-size:13px;padding:5px 12px;">Brouillon</span>
        {% elseif quote.status == 'sent' %}<span class="st-badge st-sent" style="font-size:13px;padding:5px 12px;">Envoyé</span>
        {% elseif quote.status == 'accepted' %}<span class="st-badge st-accepted" style="font-size:13px;padding:5px 12px;">Accepté</span>
        {% elseif quote.status == 'declined' %}<span class="st-badge st-declined" style="font-size:13px;padding:5px 12px;">Refusé</span>
        {% elseif quote.status == 'expired' %}<span class="st-badge st-expired" style="font-size:13px;padding:5px 12px;">Expiré</span>
        {% endif %}
      </div>

      {% if quote.status == 'draft' %}
      <div style="border-top:1px solid #f1f3f5; padding-top:12px; margin-top:4px;">
        <form method="post" action="{{ path('app_quote_delete', {id: quote.id}) }}"
              onsubmit="return confirm('Supprimer ce devis définitivement ?')">
          <input type="hidden" name="_token" value="{{ csrf_token('delete_quote_' ~ quote.id) }}">
          <button type="submit" class="btn btn-danger btn-sm" style="width:100%">Supprimer</button>
        </form>
      </div>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
