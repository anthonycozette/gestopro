{% extends 'base.html.twig' %}
{% block title %}{{ quote.number }} — GestoPro{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/invoices.css') }}">
{% endblock %}

{% block topbar %}
<div class="topbar">
    <div style="display:flex;align-items:center;gap:12px;">
        <h1 style="margin:0;">{{ quote.number }}</h1>
        {% if quote.status == 'draft' %}<span class="status-chip draft">Brouillon</span>
        {% elseif quote.status == 'sent' %}<span class="status-chip sent">Envoyé</span>
        {% elseif quote.status == 'accepted' %}<span class="status-chip accepted">Accepté</span>
        {% elseif quote.status == 'declined' %}<span class="status-chip declined">Refusé</span>
        {% elseif quote.status == 'expired' %}<span class="status-chip expired">Expiré</span>
        {% endif %}
        <span style="font-size:13px;color:#9ca3af;">
            {{ quote.client.name }} · {{ quote.totalTtc|number_format(2, ',', ' ') }} €
        </span>
    </div>
    <div class="topbar-actions">
        {% if quote.status == 'draft' %}
            <form method="post" action="{{ path('app_quote_send', {id: quote.id}) }}" style="display:inline">
                <input type="hidden" name="_token" value="{{ csrf_token('send_quote_' ~ quote.id) }}">
                <button type="submit" class="btn btn-primary">Envoyer au client</button>
            </form>
            <a href="{{ path('app_quote_edit', {id: quote.id}) }}" class="btn btn-secondary">Modifier</a>
        {% endif %}
        {% if quote.status in ['sent', 'accepted'] %}
            <form method="post" action="{{ path('app_quote_convert', {id: quote.id}) }}" style="display:inline"
                  onsubmit="return confirm('Convertir ce devis en facture ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('convert_quote_' ~ quote.id) }}">
                <button type="submit" class="btn btn-primary" style="background:#7c3aed;border-color:#7c3aed;">⇄ Convertir en facture</button>
            </form>
        {% endif %}
        {% if quote.status == 'sent' %}
            <form method="post" action="{{ path('app_quote_accept', {id: quote.id}) }}" style="display:inline">
                <input type="hidden" name="_token" value="{{ csrf_token('accept_quote_' ~ quote.id) }}">
                <button type="submit" class="btn btn-secondary" style="color:#15803d;border-color:#bbf7d0;">✓ Accepté</button>
            </form>
            <form method="post" action="{{ path('app_quote_decline', {id: quote.id}) }}" style="display:inline">
                <input type="hidden" name="_token" value="{{ csrf_token('decline_quote_' ~ quote.id) }}">
                <button type="submit" class="btn btn-secondary" style="color:#b91c1c;border-color:#fecaca;">✕ Refusé</button>
            </form>
        {% endif %}
        <a href="{{ path('app_quotes') }}" class="btn btn-secondary">Retour</a>
    </div>
</div>
{% endblock %}

{% block body %}

{% set avatarColors = ['#2563eb','#7c3aed','#16a34a','#ea580c','#0891b2','#db2777','#ca8a04'] %}
{% set avatarBg     = avatarColors[quote.client.name|length % 7] %}
{% set isAccepted   = quote.status == 'accepted' %}
{% set isDeclined   = quote.status == 'declined' %}
{% set isExpired    = quote.status == 'expired' %}

<div class="inv-layout">

    {# Left: document devis #}
    <div class="inv-doc">
        <div class="inv-doc-top">

            <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px;">
                <div class="inv-doc-number">{{ quote.number }}</div>
                <span style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.1em;
                             background:#f8f9fa;border:1px solid #e8eaed;border-radius:6px;padding:4px 10px;">
                    Devis
                </span>
            </div>

            <div class="inv-parties">
                <div>
                    <div class="inv-party-label">De</div>
                    <div class="inv-party-name">Mon entreprise</div>
                </div>
                <div>
                    <div class="inv-party-label">Proposé à</div>
                    <div class="inv-party-name">{{ quote.client.name }}</div>
                    <div class="inv-party-detail">
                        {% if quote.client.email %}{{ quote.client.email }}<br>{% endif %}
                        {% if quote.client.fullAddress %}{{ quote.client.fullAddress }}{% endif %}
                    </div>
                </div>
            </div>

            <div class="inv-doc-dates">
                <div class="inv-date-item">
                    <div class="inv-date-label">Date d'émission</div>
                    <div class="inv-date-value">{{ quote.issuedAt|date('d/m/Y') }}</div>
                </div>
                {% if quote.dueAt %}
                <div class="inv-date-item">
                    <div class="inv-date-label">Valable jusqu'au</div>
                    <div class="inv-date-value{% if isExpired %} overdue{% endif %}">
                        {{ quote.dueAt|date('d/m/Y') }}{% if isExpired %} · Expiré{% endif %}
                    </div>
                </div>
                {% endif %}
            </div>
        </div>

        <div class="inv-doc-lines">
            <table>
                <thead>
                    <tr>
                        <th>Description</th>
                        <th style="text-align:right">Qté</th>
                        <th style="text-align:right">PU HT</th>
                        <th style="text-align:right">TVA</th>
                        <th style="text-align:right">Total HT</th>
                    </tr>
                </thead>
                <tbody>
                    {% for line in quote.lines %}
                    <tr>
                        <td>{{ line.description }}</td>
                        <td style="text-align:right"><span class="mono">{{ line.quantity }}</span></td>
                        <td style="text-align:right"><span class="mono">{{ line.unitPrice|number_format(2, ',', ' ') }} €</span></td>
                        <td style="text-align:right"><span class="mono">{{ line.tvaRate }} %</span></td>
                        <td style="text-align:right"><strong class="mono">{{ line.totalHt|number_format(2, ',', ' ') }} €</strong></td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="inv-totals-wrap">
            <div class="inv-totals">
                <div class="inv-totals-row">
                    <span>Total HT</span>
                    <span class="val">{{ quote.totalHt|number_format(2, ',', ' ') }} €</span>
                </div>
                <div class="inv-totals-row">
                    <span>TVA</span>
                    <span class="val" style="color:#2563eb;">{{ quote.totalTva|number_format(2, ',', ' ') }} €</span>
                </div>
                <div class="inv-totals-row total">
                    <span>Total TTC</span>
                    <span class="val">{{ quote.totalTtc|number_format(2, ',', ' ') }} €</span>
                </div>
                {% if isAccepted %}
                <div class="reste-du" style="background:#f0fdf4;border-color:#bbf7d0;">
                    <div class="reste-du-label" style="color:#15803d;">Devis accepté ✓</div>
                    <div class="reste-du-amount" style="color:#15803d;">{{ quote.totalTtc|number_format(2, ',', ' ') }} €</div>
                </div>
                {% elseif isDeclined %}
                <div class="reste-du" style="background:#fff9f9;border-color:#fecaca;">
                    <div class="reste-du-label" style="color:#b91c1c;">Devis refusé</div>
                    <div class="reste-du-amount" style="color:#b91c1c;font-size:16px;">—</div>
                </div>
                {% elseif quote.status == 'sent' %}
                <div class="reste-du">
                    <div class="reste-du-label">En attente de réponse</div>
                    <div class="reste-du-amount">{{ quote.totalTtc|number_format(2, ',', ' ') }} €</div>
                </div>
                {% endif %}
            </div>
        </div>

        {% if quote.notes %}
        <div class="inv-doc-notes">{{ quote.notes }}</div>
        {% endif %}
    </div>

    {# Right sidebar #}
    <div class="inv-aside">

        {# Client #}
        <div class="inv-panel">
            <div class="inv-panel-title">Client</div>
            <div class="inv-client-row">
                <span class="avatar avatar-md" style="background:{{ avatarBg }};">
                    {{ quote.client.name|first|upper }}
                </span>
                <div>
                    <div style="font-weight:700;font-size:14px;color:#1c1a17;">{{ quote.client.name }}</div>
                    {% if quote.client.email %}
                    <div style="font-size:12px;color:#9ca3af;margin-top:2px;">{{ quote.client.email }}</div>
                    {% endif %}
                </div>
            </div>
            <a href="{{ path('app_client_show', {id: quote.client.id}) }}" class="btn btn-secondary btn-sm" style="width:100%;">
                Voir le client →
            </a>
        </div>

        {# Statut & actions rapides #}
        <div class="inv-panel">
            <div class="inv-panel-title">Actions</div>

            {% if quote.status == 'draft' %}
                <p style="font-size:12px;color:#6b7280;margin:0 0 12px;">Finalisez le devis puis envoyez-le au client pour obtenir sa réponse.</p>
                <form method="post" action="{{ path('app_quote_send', {id: quote.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('send_quote_' ~ quote.id) }}">
                    <button type="submit" class="btn btn-primary" style="width:100%;margin-bottom:8px;">Envoyer au client</button>
                </form>
                <a href="{{ path('app_quote_edit', {id: quote.id}) }}" class="btn btn-secondary btn-sm" style="width:100%;">Modifier le devis</a>

            {% elseif quote.status == 'sent' %}
                <p style="font-size:12px;color:#6b7280;margin:0 0 12px;">En attente de la réponse du client. Marquez le statut dès réception.</p>
                <form method="post" action="{{ path('app_quote_accept', {id: quote.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('accept_quote_' ~ quote.id) }}">
                    <button type="submit" class="btn btn-primary" style="width:100%;margin-bottom:8px;background:#16a34a;border-color:#16a34a;">✓ Marquer accepté</button>
                </form>
                <form method="post" action="{{ path('app_quote_decline', {id: quote.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('decline_quote_' ~ quote.id) }}">
                    <button type="submit" class="btn btn-secondary btn-sm" style="width:100%;margin-bottom:8px;color:#b91c1c;border-color:#fecaca;">✕ Marquer refusé</button>
                </form>
                <form method="post" action="{{ path('app_quote_convert', {id: quote.id}) }}"
                      onsubmit="return confirm('Convertir ce devis en facture ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('convert_quote_' ~ quote.id) }}">
                    <button type="submit" class="btn btn-secondary btn-sm" style="width:100%;color:#7c3aed;border-color:#e9d5ff;">⇄ Convertir en facture</button>
                </form>

            {% elseif quote.status == 'accepted' %}
                <p style="font-size:12px;color:#6b7280;margin:0 0 12px;">Le client a accepté ce devis. Convertissez-le en facture pour encaisser.</p>
                <form method="post" action="{{ path('app_quote_convert', {id: quote.id}) }}"
                      onsubmit="return confirm('Convertir ce devis en facture ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('convert_quote_' ~ quote.id) }}">
                    <button type="submit" class="btn btn-primary" style="width:100%;background:#7c3aed;border-color:#7c3aed;">⇄ Convertir en facture</button>
                </form>

            {% elseif quote.status == 'declined' %}
                <p style="font-size:12px;color:#9ca3af;margin:0;">Le client a refusé ce devis. Vous pouvez le modifier et en créer un nouveau.</p>

            {% elseif quote.status == 'expired' %}
                <p style="font-size:12px;color:#9ca3af;margin:0;">Ce devis a dépassé sa date de validité.</p>
            {% endif %}
        </div>

        {# Activité #}
        <div class="inv-panel">
            <div class="inv-panel-title">Activité</div>
            <div class="activity-list">
                <div class="activity-item">
                    <div class="activity-dot created">C</div>
                    <div class="activity-body">
                        <div class="activity-title">Devis créé</div>
                        <div class="activity-date">{{ quote.issuedAt|date('d/m/Y') }}</div>
                    </div>
                </div>
                {% if quote.status not in ['draft'] %}
                <div class="activity-item">
                    <div class="activity-dot sent">E</div>
                    <div class="activity-body">
                        <div class="activity-title">Envoyé au client</div>
                        <div class="activity-date">{{ quote.issuedAt|date('d/m/Y') }}</div>
                    </div>
                </div>
                {% endif %}
                {% if isAccepted %}
                <div class="activity-item">
                    <div class="activity-dot paid">✓</div>
                    <div class="activity-body">
                        <div class="activity-title" style="color:#15803d;">Accepté par le client</div>
                        <div class="activity-date">—</div>
                    </div>
                </div>
                {% elseif isDeclined %}
                <div class="activity-item">
                    <div class="activity-dot overdue">✕</div>
                    <div class="activity-body">
                        <div class="activity-title" style="color:#b91c1c;">Refusé par le client</div>
                        <div class="activity-date">—</div>
                    </div>
                </div>
                {% elseif isExpired %}
                <div class="activity-item">
                    <div class="activity-dot" style="background:#d97706;">!</div>
                    <div class="activity-body">
                        <div class="activity-title" style="color:#b45309;">Devis expiré</div>
                        <div class="activity-date">{{ quote.dueAt ? quote.dueAt|date('d/m/Y') : '—' }}</div>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>

        {# Danger zone — uniquement si draft #}
        {% if quote.status == 'draft' %}
        <div class="inv-danger-panel">
            <div style="font-size:11px;font-weight:700;color:#dc2626;text-transform:uppercase;letter-spacing:.07em;margin-bottom:10px;">Zone de danger</div>
            <form method="post" action="{{ path('app_quote_delete', {id: quote.id}) }}"
                  onsubmit="return confirm('Supprimer ce devis définitivement ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_quote_' ~ quote.id) }}">
                <button type="submit" class="btn btn-danger btn-sm" style="width:100%;">Supprimer</button>
            </form>
        </div>
        {% endif %}

    </div>
</div>
{% endblock %}
