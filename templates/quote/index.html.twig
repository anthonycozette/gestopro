{% extends 'base.html.twig' %}
{% block title %}Devis — GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
  <h1>Devis</h1>
  <div class="topbar-actions">
    <a href="{{ path('app_quote_new') }}" class="btn btn-primary">+ Nouveau devis</a>
  </div>
</div>
{% endblock %}

{% block body %}
<div class="card">
  {% if quotes is empty %}
    <div class="empty-state">
      <div class="empty-state-icon">📋</div>
      <p>Aucun devis pour l'instant.</p>
      <a href="{{ path('app_quote_new') }}" class="btn btn-primary">Créer mon premier devis</a>
    </div>
  {% else %}
    <table>
      <thead>
        <tr>
          <th>Numéro</th>
          <th>Client</th>
          <th>Date</th>
          <th>Validité</th>
          <th style="text-align:right">Montant TTC</th>
          <th>Statut</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for quote in quotes %}
        <tr>
          <td><a href="{{ path('app_quote_show', {id: quote.id}) }}">{{ quote.number }}</a></td>
          <td style="color:#6b7280">{{ quote.client.name }}</td>
          <td style="color:#6b7280; font-size:13px">{{ quote.issuedAt|date('d/m/Y') }}</td>
          <td style="color:#6b7280; font-size:13px">{{ quote.dueAt ? quote.dueAt|date('d/m/Y') : '—' }}</td>
          <td style="text-align:right"><span class="mono">{{ quote.totalTtc|number_format(2, ',', ' ') }} €</span></td>
          <td>{{ _self.statusBadge(quote.status) }}</td>
          <td style="text-align:right">
            <a href="{{ path('app_quote_show', {id: quote.id}) }}" class="btn btn-secondary btn-sm">Voir</a>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
</div>

{% macro statusBadge(status) %}
  {% if status == 'draft' %}<span class="st-badge st-draft">Brouillon</span>
  {% elseif status == 'sent' %}<span class="st-badge st-sent">Envoyé</span>
  {% elseif status == 'accepted' %}<span class="st-badge st-accepted">Accepté</span>
  {% elseif status == 'declined' %}<span class="st-badge st-declined">Refusé</span>
  {% elseif status == 'expired' %}<span class="st-badge st-expired">Expiré</span>
  {% else %}<span class="st-badge st-draft">{{ status }}</span>{% endif %}
{% endmacro %}
{% endblock %}
