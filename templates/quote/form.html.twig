{% extends 'base.html.twig' %}
{% block title %}{{ title }} — GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>{{ title }}</h1>
    <div class="topbar-actions">
        <a href="{{ path('app_quotes') }}" class="btn btn-secondary">Annuler</a>
    </div>
</div>
{% endblock %}

{% block body %}
<form method="post" id="quote-form">
    {% if error %}<div class="alert alert-error">{{ error }}</div>{% endif %}

    <div style="display:grid; grid-template-columns:2fr 1fr; gap:20px; align-items:start;">

        <div>
            <!-- Lignes de prestation -->
            <div class="card">
                <div class="card-title">Prestations</div>
                <table id="lines-table" style="margin-bottom:12px;">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th style="width:80px">Qté</th>
                            <th style="width:110px">Prix unit. HT</th>
                            <th style="width:80px">TVA %</th>
                            <th style="width:100px">Total HT</th>
                            <th style="width:36px"></th>
                        </tr>
                    </thead>
                    <tbody id="lines-body">
                        {% if quote.lines is empty %}
                            {{ _self.lineRow(0, '', '1', '0.00', '20') }}
                        {% else %}
                            {% for i, line in quote.lines %}
                                {{ _self.lineRow(i, line.description, line.quantity, line.unitPrice, line.tvaRate) }}
                            {% endfor %}
                        {% endif %}
                    </tbody>
                </table>
                <button type="button" onclick="addLine()" class="btn btn-secondary btn-sm">+ Ajouter une ligne</button>
            </div>

            <!-- Notes -->
            <div class="card">
                <div class="form-group">
                    <label>Notes / conditions particulières</label>
                    <textarea name="notes" class="form-control" rows="3">{{ quote.notes }}</textarea>
                </div>
            </div>
        </div>

        <div>
            <!-- Infos devis -->
            <div class="card">
                <div class="card-title">Informations</div>

                <div class="form-group">
                    <label>Client <span style="color:#ef4444">*</span></label>
                    <select name="client_id" class="form-control" required>
                        <option value="">— Sélectionner —</option>
                        {% for client in clients %}
                            <option value="{{ client.id }}" {% if quote.client and quote.client.id == client.id %}selected{% endif %}>
                                {{ client.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group">
                    <label>Date d'émission</label>
                    <input type="date" name="issued_at" class="form-control"
                           value="{{ quote.issuedAt ? quote.issuedAt|date('Y-m-d') : 'now'|date('Y-m-d') }}">
                </div>

                <div class="form-group">
                    <label>Date de validité</label>
                    <input type="date" name="due_at" class="form-control"
                           value="{{ quote.dueAt ? quote.dueAt|date('Y-m-d') : '' }}">
                </div>

                <div class="form-group">
                    <label>Statut</label>
                    <select name="status" class="form-control">
                        <option value="draft" {% if quote.status == 'draft' %}selected{% endif %}>Brouillon</option>
                        <option value="sent" {% if quote.status == 'sent' %}selected{% endif %}>Envoyé</option>
                    </select>
                </div>

                <!-- Totaux -->
                <div style="border-top:1px solid #e5e7eb; padding-top:12px; margin-top:4px;">
                    <div style="display:flex; justify-content:space-between; margin-bottom:6px; font-size:14px;">
                        <span style="color:#6b7280">Total HT</span>
                        <span id="total-ht">0,00 €</span>
                    </div>
                    <div style="display:flex; justify-content:space-between; margin-bottom:6px; font-size:14px;">
                        <span style="color:#6b7280">TVA</span>
                        <span id="total-tva">0,00 €</span>
                    </div>
                    <div style="display:flex; justify-content:space-between; font-size:16px; font-weight:700; padding-top:8px; border-top:1px solid #e5e7eb;">
                        <span>Total TTC</span>
                        <span id="total-ttc">0,00 €</span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary" style="width:100%; margin-top:16px;">Enregistrer</button>
            </div>
        </div>
    </div>
</form>

{% macro lineRow(i, desc, qty, price, tva) %}
<tr class="line-row">
    <td><input type="text" name="description[]" class="form-control" value="{{ desc }}" placeholder="Description de la prestation" oninput="recalculate()" required></td>
    <td><input type="number" name="quantity[]" class="form-control line-qty" value="{{ qty }}" min="0.01" step="0.01" oninput="recalculate()"></td>
    <td><input type="number" name="unit_price[]" class="form-control line-price" value="{{ price }}" min="0" step="0.01" oninput="recalculate()"></td>
    <td><input type="number" name="tva_rate[]" class="form-control line-tva" value="{{ tva }}" min="0" max="100" step="0.1" oninput="recalculate()"></td>
    <td><span class="line-total" style="font-weight:500;">0,00 €</span></td>
    <td><button type="button" onclick="removeLine(this)" style="background:none;border:none;cursor:pointer;color:#ef4444;font-size:16px;">✕</button></td>
</tr>
{% endmacro %}
{% endblock %}

{% block javascripts %}
<script src="{{ asset('js/invoice-lines.js') }}" defer></script>
{% endblock %}
