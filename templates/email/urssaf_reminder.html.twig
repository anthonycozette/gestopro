<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f3f4f6; margin: 0; padding: 32px 16px; color: #111827; }
        .container { max-width: 560px; margin: 0 auto; background: #fff; border-radius: 10px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,.08); }
        .header { background: #1e293b; padding: 28px 32px; }
        .header h1 { color: #fff; margin: 0; font-size: 22px; font-weight: 700; }
        .header h1 span { color: #60a5fa; }
        .banner { background: {% if daysLeft <= 3 %}#fee2e2{% else %}#fef3c7{% endif %}; border-left: 4px solid {% if daysLeft <= 3 %}#dc2626{% else %}#f59e0b{% endif %}; padding: 14px 32px; font-size: 14px; color: {% if daysLeft <= 3 %}#991b1b{% else %}#92400e{% endif %}; font-weight: 500; }
        .body { padding: 32px; }
        .greeting { font-size: 16px; margin-bottom: 20px; color: #374151; }
        .box { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 20px; margin-bottom: 24px; }
        .row { display: flex; justify-content: space-between; padding: 6px 0; font-size: 14px; border-bottom: 1px solid #e2e8f0; }
        .row:last-child { border-bottom: none; font-weight: 700; font-size: 15px; padding-top: 10px; }
        .label { color: #6b7280; }
        .value { color: #111827; font-weight: 500; }
        .amount { color: #2563eb; font-size: 18px; font-weight: 800; }
        .message { font-size: 14px; color: #6b7280; line-height: 1.7; margin-bottom: 20px; }
        .footer { background: #f8fafc; padding: 20px 32px; font-size: 12px; color: #9ca3af; border-top: 1px solid #e5e7eb; }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>Gesto<span>Pro</span></h1>
    </div>
    <div class="banner">
        {% if daysLeft <= 3 %}🚨{% else %}⏰{% endif %}
        Rappel URSSAF — Échéance dans {{ daysLeft }} jour{{ daysLeft > 1 ? 's' : '' }}
    </div>
    <div class="body">
        <div class="greeting">Bonjour {{ user.fullName }},</div>

        <p class="message">
            Votre déclaration URSSAF pour la période <strong>{{ declaration.periodLabel }}</strong>
            doit être saisie sur <strong>urssaf.fr</strong> avant le <strong>{{ dueDate|date('d/m/Y') }}</strong>
            (dans {{ daysLeft }} jour{{ daysLeft > 1 ? 's' : '' }}).
        </p>

        <div class="box">
            <div class="row">
                <span class="label">Période</span>
                <span class="value">{{ declaration.periodLabel }}</span>
            </div>
            <div class="row">
                <span class="label">Début → Fin</span>
                <span class="value">{{ declaration.periodStart|date('d/m/Y') }} → {{ declaration.periodEnd|date('d/m/Y') }}</span>
            </div>
            <div class="row">
                <span class="label">CA à déclarer</span>
                <span class="value">{{ declaration.revenue|number_format(2, ',', ' ') }} €</span>
            </div>
            <div class="row">
                <span class="label">Cotisation estimée</span>
                <span class="amount">{{ declaration.cotisationAmount|number_format(2, ',', ' ') }} €</span>
            </div>
        </div>

        <p class="message">
            Connectez-vous sur <a href="https://www.urssaf.fr" style="color:#2563eb;">urssaf.fr</a>
            pour effectuer votre déclaration et votre paiement.
            Pensez à marquer la déclaration comme "effectuée" dans GestoPro ensuite.
        </p>
    </div>
    <div class="footer">
        Rappel automatique GestoPro — {{ user.fullName }}
    </div>
</div>
</body>
</html>
