{% extends 'base.html.twig' %}
{% block title %}Nouveau bilan — GestoPro{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/accounting.css') }}">
{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Nouveau bilan comptable</h1>
    <div class="topbar-actions">
        <a href="{{ path('app_balance_sheets') }}" class="btn btn-secondary">Annuler</a>
    </div>
</div>
{% endblock %}

{% block body %}
<div style="max-width:660px;">
    {% if error %}
    <div class="alert alert-error" style="margin-bottom:16px;">{{ error }}</div>
    {% endif %}

    {# ── Period selector ──────────────────────────────────────── #}
    <div class="card">
        <div style="font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:14px;">
            Sélectionner la période
        </div>

        <form method="post">
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:16px;">
                <div class="form-group" style="margin-bottom:0;">
                    <label>Type de période</label>
                    <select name="period_type" id="period-type" class="form-control" onchange="toggleSelectors()">
                        <option value="annual">Annuel</option>
                        <option value="quarterly">Trimestriel</option>
                        <option value="monthly">Mensuel</option>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom:0;">
                    <label>Année</label>
                    <select name="year" class="form-control">
                        {% set currentYear = "now"|date('Y') %}
                        {% for y in range(currentYear - 3, currentYear) %}
                            <option value="{{ y }}" {% if y == currentYear %}selected{% endif %}>{{ y }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-group" id="quarter-wrap" style="display:none;margin-bottom:0;">
                    <label>Trimestre</label>
                    <select name="quarter" class="form-control">
                        <option value="T1">T1 (Jan–Mar)</option>
                        <option value="T2">T2 (Avr–Jun)</option>
                        <option value="T3">T3 (Jul–Sep)</option>
                        <option value="T4">T4 (Oct–Déc)</option>
                    </select>
                </div>
                <div class="form-group" id="month-wrap" style="display:none;margin-bottom:0;">
                    <label>Mois</label>
                    <select name="month" class="form-control">
                        {% set monthNames = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'] %}
                        {% for i in 1..12 %}
                            <option value="{{ '%02d'|format(i) }}">{{ monthNames[i-1] }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <button type="submit" name="action" value="preview" class="btn btn-secondary">
                Calculer les données
            </button>
        </form>
    </div>

    {# ── Preview ──────────────────────────────────────────────── #}
    {% if preview %}
    <div class="acc-doc" style="margin-top:16px;">
        <div class="acc-doc-header">
            <div>
                <div class="acc-doc-eyebrow">Prévisualisation</div>
                <div class="acc-doc-period">{{ preview.label }}</div>
                <div class="acc-doc-dates">
                    {{ preview.start|date('d/m/Y') }} → {{ preview.end|date('d/m/Y') }}
                </div>
            </div>
            <span class="chip chip-gray">Brouillon</span>
        </div>

        <div class="acc-amounts" style="margin-bottom:20px;">
            <div class="acc-row">
                <span class="acc-row-label">Chiffre d'affaires HT</span>
                <span class="acc-row-value c-positive">{{ preview.revenue_ht|number_format(2, ',', ' ') }} €</span>
            </div>
            <div class="acc-row">
                <span class="acc-row-label">Dépenses TTC</span>
                <span class="acc-row-value c-negative">− {{ preview.expenses_ttc|number_format(2, ',', ' ') }} €</span>
            </div>
            <div class="acc-row">
                <span class="acc-row-label">Cotisations URSSAF</span>
                <span class="acc-row-value c-negative">− {{ preview.cotisations|number_format(2, ',', ' ') }} €</span>
            </div>
            <div class="acc-row-total">
                <span class="acc-row-label">Résultat net estimé</span>
                <span class="acc-row-value {{ preview.net_result >= 0 ? 'c-positive' : 'c-negative' }}">
                    {{ preview.net_result|number_format(2, ',', ' ') }} €
                </span>
            </div>
        </div>

        <form method="post">
            <input type="hidden" name="action" value="save">
            <input type="hidden" name="period_type" value="{{ app.request.request.get('period_type') }}">
            <input type="hidden" name="year" value="{{ app.request.request.get('year') }}">
            <input type="hidden" name="quarter" value="{{ app.request.request.get('quarter') }}">
            <input type="hidden" name="month" value="{{ app.request.request.get('month') }}">
            <button type="submit" class="btn btn-primary">Enregistrer ce bilan</button>
        </form>
    </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
<script>
function toggleSelectors() {
    const type = document.getElementById('period-type').value;
    document.getElementById('quarter-wrap').style.display = type === 'quarterly' ? 'block' : 'none';
    document.getElementById('month-wrap').style.display   = type === 'monthly'   ? 'block' : 'none';
}
toggleSelectors();
</script>
{% endblock %}
