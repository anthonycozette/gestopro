{% extends 'base.html.twig' %}
{% block title %}Bilan {{ sheet.period }} — GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Bilan {{ sheet.period }}</h1>
    <div class="topbar-actions">
        {% if sheet.status == 'draft' %}
            <form method="post" action="{{ path('app_balance_sheet_submit', {id: sheet.id}) }}" style="display:inline;">
                <input type="hidden" name="_token" value="{{ csrf_token('submit_sheet_' ~ sheet.id) }}">
                <button type="submit" class="btn btn-primary"
                        onclick="return confirm('Soumettre ce bilan à votre expert-comptable ?')">
                    Soumettre pour révision
                </button>
            </form>
        {% endif %}
        <a href="{{ path('app_balance_sheets') }}" class="btn btn-secondary">Retour</a>
    </div>
</div>
{% endblock %}

{% block body %}
{% set fd = sheet.financialData %}
<div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;align-items:start;">

    <div class="card">
        <div style="font-size:12px;color:#6b7280;margin-bottom:16px;">
            {{ sheet.periodStart|date('d/m/Y') }} → {{ sheet.periodEnd|date('d/m/Y') }}
        </div>

        <table style="width:360px;">
            <tr>
                <td style="color:#6b7280;padding:8px 0;">Chiffre d'affaires HT</td>
                <td style="text-align:right;font-weight:600;font-size:15px;">{{ fd.revenue_ht|number_format(2, ',', ' ') }} €</td>
            </tr>
            <tr>
                <td style="color:#6b7280;padding:8px 0;">Dépenses TTC</td>
                <td style="text-align:right;color:#ef4444;">− {{ fd.expenses_ttc|number_format(2, ',', ' ') }} €</td>
            </tr>
            <tr>
                <td style="color:#6b7280;padding:8px 0;">Cotisations URSSAF</td>
                <td style="text-align:right;color:#ef4444;">− {{ fd.cotisations|number_format(2, ',', ' ') }} €</td>
            </tr>
            <tr>
                <td colspan="2" style="padding:0;height:2px;background:#1e3a5f;"></td>
            </tr>
            <tr>
                <td style="font-weight:700;padding-top:12px;font-size:15px;">Résultat net estimé</td>
                <td style="text-align:right;font-weight:700;font-size:20px;padding-top:12px;color:{% if fd.net_result < 0 %}#ef4444{% else %}#16a34a{% endif %};">
                    {{ fd.net_result|number_format(2, ',', ' ') }} €
                </td>
            </tr>
        </table>

        {% if sheet.accountantComment %}
        <div style="margin-top:24px;padding:16px;background:#eff6ff;border:1px solid #bfdbfe;border-radius:6px;">
            <div style="font-size:12px;font-weight:600;color:#1e40af;margin-bottom:8px;">
                Commentaire de l'expert-comptable
            </div>
            <div style="font-size:13px;line-height:1.6;white-space:pre-wrap;color:#374151;">{{ sheet.accountantComment }}</div>
        </div>
        {% endif %}
    </div>

    <div>
        <div class="card">
            <div class="card-title">Statut</div>
            <div style="margin-bottom:16px;">
                {% if sheet.status == 'validated' %}<span class="badge badge-green" style="font-size:13px;padding:5px 12px;">Validé</span>
                {% elseif sheet.status == 'annotated' %}<span class="badge badge-blue" style="font-size:13px;padding:5px 12px;">Annoté par l'expert</span>
                {% elseif sheet.status == 'pending_review' %}<span class="badge badge-yellow" style="font-size:13px;padding:5px 12px;">En cours de révision</span>
                {% else %}<span class="badge badge-gray" style="font-size:13px;padding:5px 12px;">Brouillon</span>{% endif %}
            </div>

            {% if sheet.accountant %}
            <div style="font-size:13px;color:#6b7280;margin-bottom:4px;">Expert-comptable</div>
            <div style="font-size:14px;font-weight:600;">{{ sheet.accountant.fullName }}</div>
            {% if sheet.accountant.firm %}<div style="font-size:12px;color:#6b7280;">{{ sheet.accountant.firm }}</div>{% endif %}
            {% endif %}

            {% if sheet.validatedAt %}
            <div style="margin-top:12px;font-size:12px;color:#16a34a;">
                ✓ Validé le {{ sheet.validatedAt|date('d/m/Y à H:i') }}
            </div>
            {% endif %}

            {% if sheet.status == 'draft' %}
            <div style="margin-top:16px;border-top:1px solid #e5e7eb;padding-top:12px;">
                <form method="post" action="{{ path('app_balance_sheet_delete', {id: sheet.id}) }}"
                      onsubmit="return confirm('Supprimer ce bilan ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_sheet_' ~ sheet.id) }}">
                    <button type="submit" class="btn btn-danger btn-sm" style="width:100%;">Supprimer</button>
                </form>
            </div>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}
