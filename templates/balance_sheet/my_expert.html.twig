{% extends 'base.html.twig' %}
{% block title %}Mon Expert-Comptable — GestoPro{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/bilan.css') }}">
{% endblock %}

{% block topbar %}
<div class="topbar">
    <div>
        <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:2px;">
            Portail expert
        </div>
        <h1>Mon Expert-Comptable</h1>
    </div>
    <div class="topbar-actions">
        <a href="{{ path('app_balance_sheets') }}" class="btn btn-secondary">← Bilans</a>
    </div>
</div>
{% endblock %}

{% block body %}

{% if not invitation %}
{# ── No expert yet — empty state ────────────────────────────────── #}
<div style="max-width:520px;margin:60px auto;text-align:center;">
    <div style="font-size:56px;margin-bottom:16px;">🧑‍💼</div>
    <div style="font-size:20px;font-weight:700;letter-spacing:-.4px;margin-bottom:8px;">
        Aucun expert-comptable associé
    </div>
    <div style="font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:28px;">
        Invitez votre expert-comptable pour qu'il puisse réviser et valider vos bilans IA.
        Il aura accès à vos bilans soumis et pourra y apposer son tampon numérique.
    </div>
    <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
        <a href="{{ path('app_balance_sheets') }}" class="btn btn-secondary">Voir mes bilans</a>
    </div>
    <div style="margin-top:32px;padding:20px;background:#f8fafc;border-radius:14px;border:1px solid var(--bd);text-align:left;">
        <div style="font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px;">
            Ce que peut faire votre expert
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;">
            <div style="display:flex;align-items:center;gap:10px;font-size:13px;">
                <span style="width:24px;height:24px;border-radius:6px;background:#dcfce7;color:#16a34a;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">✓</span>
                Réviser et annoter vos bilans comptables
            </div>
            <div style="display:flex;align-items:center;gap:10px;font-size:13px;">
                <span style="width:24px;height:24px;border-radius:6px;background:#dcfce7;color:#16a34a;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">✓</span>
                Valider et apposer son tampon numérique
            </div>
            <div style="display:flex;align-items:center;gap:10px;font-size:13px;">
                <span style="width:24px;height:24px;border-radius:6px;background:#dcfce7;color:#16a34a;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;">✓</span>
                Vous envoyer des recommandations via la messagerie
            </div>
        </div>
    </div>
</div>

{% else %}
{# ── Invitation exists ───────────────────────────────────────────── #}

{% set expert = invitation.accountant %}

<div class="bl-expert-layout">

{# ──── LEFT: Hero + chat ─────────────────────────────────────────── #}
<div>

    {# Expert hero card #}
    <div class="bl-expert-hero">
        <div class="bl-expert-hero-bg"></div>
        <div class="bl-expert-hero-inner">
            <div class="bl-expert-avatar">
                {{ expert.firstName|first|upper }}{{ expert.lastName|first|upper }}
            </div>
            <div class="bl-expert-info">
                <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                    <div style="font-size:18px;font-weight:800;letter-spacing:-.4px;">
                        {{ expert.fullName }}
                    </div>
                    {% if invitation.status == 'accepted' %}
                        <span class="bl-badge bl-badge-green">✓ Connecté</span>
                    {% else %}
                        <span class="bl-badge bl-badge-orange">⏳ En attente</span>
                    {% endif %}
                </div>
                {% if expert.firm %}
                <div style="font-size:13px;color:rgba(255,255,255,.75);margin-top:3px;">{{ expert.firm }}</div>
                {% endif %}
                {% if expert.registrationNumber %}
                <div style="font-size:11.5px;color:rgba(255,255,255,.6);margin-top:2px;">
                    N° {{ expert.registrationNumber }}
                </div>
                {% endif %}
                <div style="font-size:11.5px;color:rgba(255,255,255,.55);margin-top:6px;">
                    Associé depuis le {{ invitation.createdAt|date('d/m/Y') }}
                </div>
            </div>
        </div>
        {% if expert.bio %}
        <div class="bl-expert-bio">{{ expert.bio }}</div>
        {% endif %}
    </div>

    {# Chat #}
    {% if invitation.status == 'accepted' %}
    <div class="bl-chat-wrap">
        <div class="bl-chat-header">
            <div style="font-size:13px;font-weight:700;">Messagerie</div>
            <div style="font-size:11.5px;color:var(--muted);">{{ messages|length }} message{{ messages|length != 1 ? 's' : '' }}</div>
        </div>
        <div class="bl-chat-messages" id="chat-messages">
            {% if messages is empty %}
            <div style="padding:32px 20px;text-align:center;color:var(--muted);font-size:13px;">
                Aucun message. Démarrez la conversation avec votre expert.
            </div>
            {% else %}
            {% for msg in messages %}
            <div class="bl-chat-bubble {% if msg.isFromClient() %}bl-bubble-client{% else %}bl-bubble-expert{% endif %}">
                <div class="bl-bubble-meta">
                    {% if msg.isFromClient() %}
                        Vous
                    {% else %}
                        {{ expert.firstName }}
                    {% endif %}
                    · {{ msg.createdAt|date('d/m/Y H:i') }}
                </div>
                <div class="bl-bubble-text">{{ msg.content|nl2br }}</div>
            </div>
            {% endfor %}
            {% endif %}
        </div>
        <form method="post" action="{{ path('app_balance_sheet_expert_message') }}" class="bl-chat-form">
            <input type="hidden" name="_token" value="{{ csrf_token('expert_msg') }}">
            <textarea name="content" class="bl-chat-input" placeholder="Écrivez un message à votre expert…" rows="2" required></textarea>
            <button type="submit" class="bl-chat-send">Envoyer →</button>
        </form>
    </div>
    {% else %}
    <div class="bl-panel" style="margin-top:16px;">
        <div style="padding:20px;text-align:center;">
            <div style="font-size:24px;margin-bottom:8px;">⏳</div>
            <div style="font-size:13px;font-weight:600;margin-bottom:4px;">Invitation en attente</div>
            <div style="font-size:12px;color:var(--muted);line-height:1.5;">
                Votre expert-comptable n'a pas encore accepté l'invitation.
                La messagerie sera disponible après acceptation.
            </div>
        </div>
    </div>
    {% endif %}

</div>

{# ──── RIGHT: Bilans soumis + activité ──────────────────────────── #}
<div>

    {# Bilans soumis #}
    <div class="bl-panel">
        <div class="bl-panel-title" style="margin-bottom:12px;">
            Bilans soumis
            <span style="font-size:11px;font-weight:400;color:var(--muted);margin-left:6px;">{{ submitted|length }}</span>
        </div>
        {% if submitted is empty %}
        <div style="font-size:13px;color:var(--muted);font-style:italic;padding:8px 0;">
            Aucun bilan soumis pour révision.
        </div>
        {% else %}
        <div style="display:flex;flex-direction:column;gap:8px;">
            {% for s in submitted %}
            {% set fd = s.financialData ?? {} %}
            <a href="{{ path('app_balance_sheet_show', {id: s.id}) }}" style="text-decoration:none;">
                <div class="bl-submitted-row">
                    <div class="bl-pdf-thumb" style="width:32px;height:40px;flex-shrink:0;">
                        <div class="bl-pdf-thumb-corner"></div>
                        <div class="bl-pdf-type" style="font-size:5.5px;">PDF</div>
                    </div>
                    <div style="flex:1;min-width:0;">
                        <div style="font-size:12.5px;font-weight:700;color:var(--text);">{{ s.period }}</div>
                        <div style="font-size:11px;color:var(--muted);">
                            Net : {{ (fd.net_result ?? 0)|number_format(0, ',', ' ') }} €
                        </div>
                    </div>
                    <div>
                        {% if s.status == 'validated' %}
                            <span class="bl-badge bl-badge-green" style="font-size:10px;">✓ Validé</span>
                        {% elseif s.status == 'annotated' %}
                            <span class="bl-badge bl-badge-blue" style="font-size:10px;">💬 Annoté</span>
                        {% else %}
                            <span class="bl-badge bl-badge-orange" style="font-size:10px;">⏳ Révision</span>
                        {% endif %}
                    </div>
                </div>
            </a>
            {% endfor %}
        </div>
        <a href="{{ path('app_balance_sheets') }}"
           style="display:block;margin-top:12px;font-size:12px;color:var(--accent);font-weight:600;text-decoration:none;">
            Voir tous mes bilans →
        </a>
        {% endif %}
    </div>

    {# Expert stamp / signature #}
    {% if expert.stampPath %}
    <div class="bl-panel" style="margin-top:12px;">
        <div class="bl-panel-title">Tampon numérique</div>
        <div style="margin-top:10px;padding:12px;background:#f8fafc;border-radius:8px;border:1px solid var(--bd);text-align:center;">
            <img src="{{ asset(expert.stampPath) }}" alt="Tampon expert"
                 style="max-width:120px;max-height:80px;opacity:.85;">
        </div>
        <div style="font-size:11px;color:var(--muted);margin-top:6px;text-align:center;">
            Apposé sur les bilans validés
        </div>
    </div>
    {% endif %}

    {# Activity #}
    <div class="bl-panel" style="margin-top:12px;">
        <div class="bl-panel-title">Activité récente</div>
        <div class="bl-activity">
            {% if messages is not empty %}
            {% set lastMsg = messages|last %}
            <div class="bl-activity-item">
                <span class="bl-activity-dot" style="background:#2563eb;"></span>
                <div>
                    <div style="font-size:12px;font-weight:600;">
                        {% if lastMsg.isFromClient() %}Vous avez envoyé un message{% else %}{{ expert.firstName }} a répondu{% endif %}
                    </div>
                    <div style="font-size:11px;color:var(--muted);">{{ lastMsg.createdAt|date('d/m/Y à H:i') }}</div>
                </div>
            </div>
            {% endif %}
            {% for s in submitted|slice(0,3) %}
            <div class="bl-activity-item">
                <span class="bl-activity-dot" style="background:
                    {% if s.status == 'validated' %}#16a34a
                    {% elseif s.status == 'annotated' %}#2563eb
                    {% else %}#f97316{% endif %};"></span>
                <div>
                    <div style="font-size:12px;font-weight:600;">
                        Bilan {{ s.period }}
                        {% if s.status == 'validated' %}validé
                        {% elseif s.status == 'annotated' %}annoté
                        {% else %}soumis pour révision{% endif %}
                    </div>
                    <div style="font-size:11px;color:var(--muted);">{{ s.createdAt|date('d/m/Y') }}</div>
                </div>
            </div>
            {% endfor %}
            {% if messages is empty and submitted is empty %}
            <div style="font-size:12px;color:var(--muted);font-style:italic;padding:8px 0;">Aucune activité récente.</div>
            {% endif %}
        </div>
    </div>

</div>
</div>{# end .bl-expert-layout #}
{% endif %}

{% endblock %}

{% block javascripts %}
<script>
// Auto-scroll chat to bottom
const chat = document.getElementById('chat-messages');
if (chat) chat.scrollTop = chat.scrollHeight;
</script>
{% endblock %}
