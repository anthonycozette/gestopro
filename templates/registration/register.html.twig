{% extends 'base.html.twig' %}
{% block title %}Créer un compte — GestoPro{% endblock %}

{% block body_public %}
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: #f5f6f8;
    font-family: "Inter", ui-sans-serif, system-ui, -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased;
  }
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .auth-card {
    background: #fff;
    border: 1px solid #e8eaed;
    border-radius: 14px;
    padding: 40px 36px;
    width: 100%;
    max-width: 440px;
    box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 8px 24px rgba(0,0,0,.04);
  }
  .auth-brand { text-align: center; margin-bottom: 32px; }
  .auth-brand .name { font-size: 22px; font-weight: 800; color: #0f172a; letter-spacing: -.03em; }
  .auth-brand .name span { color: #2563eb; }
  .auth-brand .sub { font-size: 12.5px; color: #9ca3af; margin-top: 4px; }
  h2.auth-heading { font-size: 16px; font-weight: 600; color: #0f172a; letter-spacing: -.01em; margin-bottom: 22px; }
  label.lbl { display: block; font-size: 12.5px; font-weight: 500; color: #374151; margin-bottom: 5px; }
  input.inp {
    width: 100%; padding: 9px 12px; border: 1px solid #d1d5db; border-radius: 7px;
    font-size: 14px; font-family: inherit; color: #0f172a; background: #fff;
    transition: border-color .15s, box-shadow .15s; margin-bottom: 14px;
  }
  input.inp:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,.1); }
  .name-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .submit-btn {
    width: 100%; padding: 10px; background: #2563eb; color: #fff; border: none;
    border-radius: 7px; font-size: 14px; font-weight: 600; font-family: inherit;
    cursor: pointer; transition: background .12s; letter-spacing: -.01em;
  }
  .submit-btn:hover { background: #1d4ed8; }
  .auth-foot { text-align: center; margin-top: 20px; font-size: 13px; color: #9ca3af; }
  .auth-foot a { color: #2563eb; font-weight: 500; }
  .err { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; padding: 10px 13px; border-radius: 7px; font-size: 13px; margin-bottom: 16px; }
  .hint { color: #9ca3af; font-size: 12px; font-weight: 400; }
</style>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <div class="name">Gesto<span>Pro</span></div>
      <div class="sub">Gérez votre activité en toute sérénité</div>
    </div>

    {% if error %}
      <div class="err">{{ error }}</div>
    {% endif %}

    <h2 class="auth-heading">Créer un compte gratuit</h2>

    <form method="post">
      <div class="name-grid">
        <div>
          <label class="lbl" for="reg-fn">Prénom</label>
          <input id="reg-fn" type="text" name="firstName" class="inp" required placeholder="Jean">
        </div>
        <div>
          <label class="lbl" for="reg-ln">Nom</label>
          <input id="reg-ln" type="text" name="lastName" class="inp" required placeholder="Dupont">
        </div>
      </div>
      <label class="lbl" for="reg-email">Adresse email</label>
      <input id="reg-email" type="email" name="email" class="inp" required autofocus
             autocomplete="email" placeholder="vous@exemple.fr">
      <label class="lbl" for="reg-pw">
        Mot de passe <span class="hint">(min. 8 caractères)</span>
      </label>
      <input id="reg-pw" type="password" name="password" class="inp" minlength="8" required
             autocomplete="new-password" placeholder="••••••••">
      <button type="submit" class="submit-btn">Créer mon compte</button>
    </form>

    <div class="auth-foot">
      Déjà inscrit ? <a href="{{ path('app_login') }}">Se connecter</a>
    </div>
  </div>
</div>
{% endblock %}
