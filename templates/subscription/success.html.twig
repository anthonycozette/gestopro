{% extends 'base.html.twig' %}
{% block title %}Abonnement activé — GestoPro{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/subscription.css') }}">
{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Abonnement activé</h1>
</div>
{% endblock %}

{% block body %}
{% set plan = app.user.plan %}

<div class="sub-success-wrap">
    <div class="sub-success-card">

        <div class="sub-success-emoji">🎉</div>

        <div class="sub-success-title">
            Bienvenue dans le plan {{ plan|capitalize }} !
        </div>

        <div class="sub-success-text">
            Votre abonnement est maintenant actif. Toutes les fonctionnalités
            de votre plan sont disponibles immédiatement.
        </div>

        {% if plan == 'pro' %}
        <div class="sub-success-features">
            <span class="feat-on">✓</span> Clients & factures illimités<br>
            <span class="feat-on">✓</span> Assistant IA Claude activé<br>
            <span class="feat-on">✓</span> Scan OCR des reçus disponible
        </div>
        {% elseif plan == 'expert' %}
        <div class="sub-success-features">
            <span class="feat-on">✓</span> Tout le plan Pro inclus<br>
            <span class="feat-on">✓</span> Portail expert-comptable activé<br>
            <span class="feat-on">✓</span> Bilans IA illimités disponibles
        </div>
        {% endif %}

        <a href="{{ path('app_dashboard') }}" class="btn btn-primary" style="display:inline-flex;padding:13px 32px;font-size:15px;width:100%;justify-content:center;">
            Aller au tableau de bord →
        </a>

        <div style="margin-top:16px;">
            <a href="{{ path('app_subscription_manage') }}" style="font-size:13px;color:#9ca3af;text-decoration:none;">
                Gérer mon abonnement
            </a>
        </div>

    </div>
</div>
{% endblock %}
