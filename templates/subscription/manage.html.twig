{% extends 'base.html.twig' %}
{% block title %}Mon abonnement — GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Mon abonnement</h1>
</div>
{% endblock %}

{% block body %}
{% set plan = user.plan %}

<div style="max-width:680px;">

    <!-- Plan actuel -->
    <div class="card">
        <div class="card-title">Plan actuel</div>

        <div style="display:flex;align-items:center;gap:20px;margin-bottom:24px;">
            <div style="flex:1;">
                {% if plan == 'free' %}
                    <div style="font-size:24px;font-weight:800;">Gratuit</div>
                    <div style="font-size:14px;color:#6b7280;margin-top:4px;">5 clients · 10 factures/mois · Sans IA</div>
                {% elseif plan == 'pro' %}
                    <div style="font-size:24px;font-weight:800;color:#2563eb;">Pro — 19 €/mois</div>
                    <div style="font-size:14px;color:#6b7280;margin-top:4px;">Illimité · Assistant IA · OCR reçus</div>
                {% else %}
                    <div style="font-size:24px;font-weight:800;color:#7c3aed;">Expert — 49 €/mois</div>
                    <div style="font-size:14px;color:#6b7280;margin-top:4px;">Tout Pro + Portail expert-comptable · Bilans IA illimités</div>
                {% endif %}
            </div>
            <div>
                {% if plan == 'free' %}
                    <span class="badge badge-gray" style="font-size:13px;padding:5px 14px;">Gratuit</span>
                {% elseif plan == 'pro' %}
                    <span class="badge badge-blue" style="font-size:13px;padding:5px 14px;">Pro</span>
                {% else %}
                    <span class="badge" style="background:#ede9fe;color:#5b21b6;font-size:13px;padding:5px 14px;">Expert</span>
                {% endif %}
            </div>
        </div>

        {% if user.subscriptionEndsAt %}
        <div class="alert alert-info" style="margin-bottom:0;">
            Votre abonnement se termine le <strong>{{ user.subscriptionEndsAt|date('d/m/Y') }}</strong>.
            Après cette date, vous basculerez sur le plan gratuit.
        </div>
        {% endif %}

        <div style="margin-top:16px;padding-top:16px;border-top:1px solid #e5e7eb;display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
            {% if plan != 'free' and user.stripeCustomerId %}
            <form method="post" action="{{ path('app_subscription_portal') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('subscription_portal') }}">
                <button type="submit" class="btn btn-secondary">
                    Gérer ma facturation Stripe →
                </button>
            </form>
            {% endif %}
            <form method="post" action="{{ path('app_subscription_sync') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('subscription_sync') }}">
                <button type="submit" class="btn btn-secondary" style="font-size:12px;color:#6b7280;">
                    ↻ Synchroniser depuis Stripe
                </button>
            </form>
        </div>
        <div style="font-size:12px;color:#9ca3af;margin-top:8px;">
            Si votre plan n'est pas à jour après un paiement, cliquez sur "Synchroniser".
        </div>
    </div>

    <!-- Changer de plan -->
    {% if plan == 'free' %}
    <div class="card">
        <div class="card-title">Passer à un plan payant</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">

            <div style="border:2px solid #2563eb;border-radius:8px;padding:20px;">
                <div style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#2563eb;margin-bottom:6px;">Pro</div>
                <div style="font-size:26px;font-weight:800;margin-bottom:4px;">19 €<span style="font-size:14px;font-weight:400;color:#9ca3af;">/mois</span></div>
                <ul style="font-size:13px;color:#374151;margin:12px 0 16px;padding-left:16px;line-height:1.8;">
                    <li>Clients et factures illimités</li>
                    <li>Assistant IA Claude</li>
                    <li>Scan OCR des reçus</li>
                </ul>
                <form method="post" action="{{ path('app_subscription_checkout', {plan: 'pro'}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('subscription_checkout') }}">
                    <button type="submit" class="btn btn-primary" style="width:100%;">Choisir Pro</button>
                </form>
            </div>

            <div style="border:2px solid #7c3aed;border-radius:8px;padding:20px;">
                <div style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#7c3aed;margin-bottom:6px;">Expert</div>
                <div style="font-size:26px;font-weight:800;margin-bottom:4px;">49 €<span style="font-size:14px;font-weight:400;color:#9ca3af;">/mois</span></div>
                <ul style="font-size:13px;color:#374151;margin:12px 0 16px;padding-left:16px;line-height:1.8;">
                    <li>Tout le plan Pro</li>
                    <li>Portail expert-comptable</li>
                    <li>Bilans IA illimités</li>
                </ul>
                <form method="post" action="{{ path('app_subscription_checkout', {plan: 'expert'}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('subscription_checkout') }}">
                    <button type="submit" class="btn" style="width:100%;background:#7c3aed;color:#fff;">Choisir Expert</button>
                </form>
            </div>

        </div>
    </div>
    {% endif %}

    {% if plan == 'pro' %}
    <div class="card">
        <div class="card-title">Passer à Expert</div>
        <div style="display:flex;gap:20px;align-items:center;">
            <div style="flex:1;font-size:14px;color:#374151;line-height:1.7;">
                Accédez au portail expert-comptable, aux bilans IA illimités et à la validation numérique.
            </div>
            <div>
                <form method="post" action="{{ path('app_subscription_checkout', {plan: 'expert'}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('subscription_checkout') }}">
                    <button type="submit" class="btn" style="background:#7c3aed;color:#fff;white-space:nowrap;">
                        Passer à Expert — 49 €/mois
                    </button>
                </form>
            </div>
        </div>
    </div>
    {% endif %}

    <!-- Limites plan gratuit -->
    {% if plan == 'free' %}
    <div class="card" style="border-color:#fbbf24;background:#fffbeb;">
        <div class="card-title" style="color:#92400e;">Limites du plan gratuit</div>
        <div style="font-size:14px;color:#78350f;line-height:1.7;">
            Sur le plan gratuit, vous êtes limité à <strong>5 clients</strong> et <strong>10 factures par mois</strong>.
            L'assistant IA Claude et le scan OCR des reçus sont réservés aux plans payants.
        </div>
        <a href="{{ path('app_pricing') }}" style="display:inline-block;margin-top:12px;font-size:13px;color:#2563eb;">
            Voir tous les plans →
        </a>
    </div>
    {% endif %}

</div>
{% endblock %}
