{% extends 'base.html.twig' %}
{% block title %}Mon abonnement — GestoPro{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/subscription.css') }}">
{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Mon abonnement</h1>
    <div class="topbar-actions">
        <a href="{{ path('app_pricing') }}" class="btn btn-secondary">Voir tous les plans</a>
    </div>
</div>
{% endblock %}

{% block body %}
{% set plan = user.plan %}

<div class="sub-layout">

    {# ── Plan actuel ── #}
    <div class="sub-plan-hero">
        <div class="sub-plan-banner {{ plan }}">
            <div class="sub-plan-icon {{ plan }}">
                {% if plan == 'free' %}🆓
                {% elseif plan == 'pro' %}⚡
                {% else %}✦{% endif %}
            </div>
            <div style="flex:1;">
                <div class="sub-plan-name {{ plan }}">
                    {% if plan == 'free' %}Gratuit
                    {% elseif plan == 'pro' %}Pro — 19 €/mois
                    {% else %}Expert — 49 €/mois{% endif %}
                </div>
                <div class="sub-plan-desc">
                    {% if plan == 'free' %}5 clients · 10 factures/mois · Sans IA
                    {% elseif plan == 'pro' %}Clients & factures illimités · Assistant IA · Scan OCR
                    {% else %}Tout le plan Pro · Portail expert-comptable · Bilans IA illimités{% endif %}
                </div>
            </div>
            <div>
                {% if plan == 'free' %}
                    <span class="st-badge st-draft" style="font-size:12px;padding:5px 14px;">Gratuit</span>
                {% elseif plan == 'pro' %}
                    <span class="st-badge st-sent" style="font-size:12px;padding:5px 14px;">Pro</span>
                {% else %}
                    <span style="background:#ede9fe;color:#6d28d9;font-size:12px;padding:5px 14px;border-radius:99px;font-weight:600;">Expert</span>
                {% endif %}
            </div>
        </div>

        {% if user.subscriptionEndsAt %}
        <div style="padding:12px 28px;background:#fffbeb;border-top:1px solid #fcd34d;">
            <div style="font-size:13px;color:#92400e;">
                ⚠️ Abonnement résilié — accès jusqu'au <strong>{{ user.subscriptionEndsAt|date('d/m/Y') }}</strong>, puis retour au plan gratuit.
            </div>
        </div>
        {% endif %}

        <div class="sub-plan-actions">
            {% if plan != 'free' and user.stripeCustomerId %}
            <form method="post" action="{{ path('app_subscription_portal') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('subscription_portal') }}">
                <button type="submit" class="btn btn-secondary">Portail de facturation Stripe →</button>
            </form>
            {% endif %}
            <form method="post" action="{{ path('app_subscription_sync') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('subscription_sync') }}">
                <button type="submit" class="btn btn-secondary" style="font-size:12px;color:#6b7280;">
                    ↻ Synchroniser depuis Stripe
                </button>
            </form>
            <span style="font-size:11px;color:#9ca3af;align-self:center;">
                Plan non à jour après un paiement ? Cliquez sur Synchroniser.
            </span>
        </div>
    </div>

    {# ── Limites plan gratuit ── #}
    {% if plan == 'free' %}
    <div class="sub-limits-card">
        <div class="sub-limits-title">⚠️ Limites du plan gratuit</div>
        <div class="sub-limits-text">
            Vous êtes limité à <strong>5 clients</strong> et <strong>10 factures par mois</strong>.
            L'assistant IA Claude et le scan OCR des reçus sont réservés aux plans payants.
        </div>
    </div>
    {% endif %}

    {# ── Changer de plan ── #}
    {% if plan == 'free' %}
    <div class="card">
        <div class="card-title">Passer à un plan payant</div>
        <div class="sub-upgrade-grid">

            <div class="sub-upgrade-card highlighted-pro">
                <div class="sub-upgrade-plan pro">Pro</div>
                <div class="sub-upgrade-price">19 € <span class="per">/mois</span></div>
                <div class="sub-upgrade-features">
                    ✓ Clients & factures illimités<br>
                    ✓ Assistant IA Claude<br>
                    ✓ Scan OCR des reçus
                </div>
                <form method="post" action="{{ path('app_subscription_checkout', {plan: 'pro'}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('subscription_checkout') }}">
                    <button type="submit" class="btn btn-primary" style="width:100%;">Choisir Pro →</button>
                </form>
            </div>

            <div class="sub-upgrade-card highlighted-expert">
                <div class="sub-upgrade-plan expert">Expert</div>
                <div class="sub-upgrade-price">49 € <span class="per">/mois</span></div>
                <div class="sub-upgrade-features">
                    ✓ Tout le plan Pro<br>
                    ✓ Portail expert-comptable<br>
                    ✓ Bilans IA illimités
                </div>
                <form method="post" action="{{ path('app_subscription_checkout', {plan: 'expert'}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('subscription_checkout') }}">
                    <button type="submit" class="btn" style="width:100%;background:#7c3aed;color:#fff;border-color:#7c3aed;">Choisir Expert →</button>
                </form>
            </div>

        </div>
    </div>
    {% endif %}

    {% if plan == 'pro' %}
    <div class="card">
        <div class="card-title">Changer de plan</div>
        <div class="sub-upgrade-grid">

            <div class="sub-upgrade-card highlighted-expert">
                <div class="sub-upgrade-plan expert">Expert ↑</div>
                <div class="sub-upgrade-price">49 € <span class="per">/mois</span></div>
                <div class="sub-upgrade-features">
                    Portail expert-comptable + bilans IA illimités + support prioritaire
                </div>
                <form method="post" action="{{ path('app_subscription_checkout', {plan: 'expert'}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('subscription_checkout') }}">
                    <button type="submit" class="btn" style="width:100%;background:#7c3aed;color:#fff;border-color:#7c3aed;">Passer à Expert</button>
                </form>
            </div>

            <div class="sub-upgrade-card dimmed">
                <div class="sub-upgrade-plan free">Gratuit ↓</div>
                <div class="sub-upgrade-price">0 € <span class="per">/mois</span></div>
                <div class="sub-upgrade-features">
                    5 clients, 10 factures/mois, sans IA
                </div>
                <form method="post" action="{{ path('app_subscription_cancel') }}"
                      data-confirm="Résilier votre abonnement Pro ? Vous conserverez l'accès jusqu'à la fin de la période payée." data-confirm-variant="danger">
                    <input type="hidden" name="_token" value="{{ csrf_token('subscription_cancel') }}">
                    <button type="submit" class="btn btn-secondary" style="width:100%;font-size:13px;">Résilier l'abonnement</button>
                </form>
            </div>

        </div>
    </div>
    {% endif %}

    {% if plan == 'expert' %}
    <div class="card">
        <div class="card-title">Changer de plan</div>
        <div class="sub-upgrade-grid">

            <div class="sub-upgrade-card highlighted-pro">
                <div class="sub-upgrade-plan pro">Pro ↓</div>
                <div class="sub-upgrade-price">19 € <span class="per">/mois</span></div>
                <div class="sub-upgrade-features">
                    Illimité, IA, OCR — sans portail expert-comptable
                </div>
                <form method="post" action="{{ path('app_subscription_checkout', {plan: 'pro'}) }}"
                      data-confirm="Passer au plan Pro ? La différence sera calculée au prorata.">
                    <input type="hidden" name="_token" value="{{ csrf_token('subscription_checkout') }}">
                    <button type="submit" class="btn btn-secondary" style="width:100%;font-size:13px;">Passer à Pro</button>
                </form>
            </div>

            <div class="sub-upgrade-card dimmed">
                <div class="sub-upgrade-plan free">Gratuit ↓</div>
                <div class="sub-upgrade-price">0 € <span class="per">/mois</span></div>
                <div class="sub-upgrade-features">
                    5 clients, 10 factures/mois, sans IA
                </div>
                <form method="post" action="{{ path('app_subscription_cancel') }}"
                      data-confirm="Résilier votre abonnement Expert ? Vous conserverez l'accès jusqu'à la fin de la période payée." data-confirm-variant="danger">
                    <input type="hidden" name="_token" value="{{ csrf_token('subscription_cancel') }}">
                    <button type="submit" class="btn btn-secondary" style="width:100%;font-size:13px;">Résilier l'abonnement</button>
                </form>
            </div>

        </div>
    </div>
    {% endif %}

    {# ── Ce qui est inclus ── #}
    <div class="card">
        <div class="card-title">Ce qui est inclus dans votre plan</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            {% set features = [
                {icon:'🧾', label:'Factures & devis', available: true},
                {icon:'👤', label:'Gestion des clients', available: true},
                {icon:'💸', label:'Suivi des dépenses', available: true},
                {icon:'📊', label:'Déclarations URSSAF', available: true},
                {icon:'🤖', label:'Assistant IA Claude', available: plan != 'free'},
                {icon:'📷', label:'Scan OCR des reçus', available: plan != 'free'},
                {icon:'📋', label:'Bilans IA', available: plan == 'expert'},
                {icon:'🏛️', label:'Portail expert-comptable', available: plan == 'expert'},
            ] %}
            {% for feature in features %}
            <div style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;background:{{ feature.available ? '#f0fdf4' : '#f9fafb' }};">
                <span style="font-size:18px;">{{ feature.icon }}</span>
                <span style="font-size:13px;color:{{ feature.available ? '#1c1a17' : '#9ca3af' }};flex:1;">{{ feature.label }}</span>
                {% if feature.available %}
                    <span style="color:#16a34a;font-weight:700;font-size:13px;">✓</span>
                {% else %}
                    <span style="color:#d1d5db;font-size:13px;">—</span>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </div>

</div>
{% endblock %}
