<aside class="sidebar">

    <!-- Brand -->
    <div class="brand-card">
        <div class="brand-icon">
            G
        </div>
        <div style="min-width:0; flex:1;">
            <div class="brand-text-name">
                GestoPro
            </div>
            <div class="brand-text-sub">
                {{ app.user.firstName }}
                's espace
            </div>
        </div>
    </div>

    <!-- Navigation -->
    <nav class="sidebar-nav">
        <div class="nav-section">
            Principal
        </div>

        <a href="{{ path('app_dashboard') }}" {% if app.request.attributes.get('_route') == 'app_dashboard' %} class="active" {% endif %}>
            <span class="nav-icon">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                    <rect x="1" y="1" width="6.5" height="6.5" rx="1.5" />
                    <rect x="8.5" y="1" width="6.5" height="6.5" rx="1.5" opacity=".45" />
                    <rect x="1" y="8.5" width="6.5" height="6.5" rx="1.5" opacity=".45" />
                    <rect x="8.5" y="8.5" width="6.5" height="6.5" rx="1.5" opacity=".45" />
                </svg>
            </span>
            Tableau de bord
        </a>

        <div class="nav-section">
            Comptabilité
        </div>

        <a href="{{ path('app_clients') }}" {% if app.request.attributes.get('_route') starts with 'app_client' %} class="active" {% endif %}>
            <span class="nav-icon">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-5 6a1 1 0 0 1-1-1c0-2.5 2.7-4 6-4s6 1.5 6 4a1 1 0 0 1-1 1H3Z" />
                </svg>
            </span>
            Clients
        </a>

        <a href="{{ path('app_invoices') }}" {% if app.request.attributes.get('_route') starts with 'app_invoice' %} class="active" {% endif %}>
            <span class="nav-icon">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M4 0a2 2 0 0 0-2 2v12l3-1.5L8 14l3-1.5L14 14V2a2 2 0 0 0-2-2H4Zm1 4h6v1H5V4Zm0 3h6v1H5V7Zm0 3h4v1H5v-1Z" />
                </svg>
            </span>
            Factures &amp; Devis
        </a>

        <a href="{{ path('app_expenses') }}" {% if app.request.attributes.get('_route') starts with 'app_expense' %} class="active" {% endif %}>
            <span class="nav-icon">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1Zm.5 3.5v.6A1.5 1.5 0 0 1 9 7.6l-1 .3a.5.5 0 1 0 0 1h1.25A.5.5 0 0 0 9.75 9H11A1.5 1.5 0 0 1 9.5 10.4v.6h-1.5v-.6A1.5 1.5 0 0 1 6.5 8.4l1-.3a.5.5 0 1 0 0-1H6.25a.5.5 0 0 0-.5.5H4.5A1.5 1.5 0 0 1 6 5.6v-.6h1.5l.5-.5h.5Z" />
                </svg>
            </span>
            Dépenses
        </a>

        <a href="{{ path('app_urssaf') }}" {% if app.request.attributes.get('_route') starts with 'app_urssaf' %} class="active" {% endif %}>
            <span class="nav-icon">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M1 4a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V4Zm0 5a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V9Zm1 4a1 1 0 0 0 0 2h7a1 1 0 0 0 0-2H2Z" />
                </svg>
            </span>
            URSSAF
        </a>

        <div class="nav-section">
            Expert-comptable
        </div>
        {% if app.user.isExpert() %}
            <a href="{{ path('app_experts') }}" {% if app.request.attributes.get('_route') starts with 'app_expert' %} class="active" {% endif %}>
                <span class="nav-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H3Zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm5.002-.274A2.5 2.5 0 0 0 13 3h-.5a.5.5 0 0 1 0-1H13a3.5 3.5 0 0 1 3.5 3.5.5.5 0 0 1-1 0 2.5 2.5 0 0 0-.498-1.5ZM13 8h-.5a.5.5 0 0 1 0-1H13a3.5 3.5 0 0 1 3.442 2.843.5.5 0 1 1-.984.174A2.5 2.5 0 0 0 13 8Z" />
                    </svg>
                </span>
                Mon expert-comptable
            </a>
        {% else %}
            <a href="{{ path('app_subscription_manage') }}" style="opacity:.35;" title="Réservé au plan Expert">
                <span class="nav-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M8 1a3.5 3.5 0 0 0-3.5 3.5V6H3v9h10V6h-1.5V4.5A3.5 3.5 0 0 0 8 1Zm2 5H6V4.5a2 2 0 1 1 4 0V6Z" />
                    </svg>
                </span>
                expert-comptable(Expert)
            </a>
        {% endif %}
        {% if app.user.isExpert() %}
            <a href="{{ path('app_balance_sheets') }}" {% if app.request.attributes.get('_route') starts with 'app_balance_sheet' %} class="active" {% endif %}>
                <span class="nav-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M3 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2H3Zm2 4h6v1H5V5Zm0 3h6v1H5V8Zm0 3h4v1H5v-1Z" />
                    </svg>
                </span>
                Bilans comptables
            </a>
        {% else %}
            <a href="{{ path('app_subscription_manage') }}" style="opacity:.35;" title="Réservé au plan Expert">
                <span class="nav-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M8 1a3.5 3.5 0 0 0-3.5 3.5V6H3v9h10V6h-1.5V4.5A3.5 3.5 0 0 0 8 1Zm2 5H6V4.5a2 2 0 1 1 4 0V6Z" />
                    </svg>
                </span>
                Bilans (Expert)
            </a>
        {% endif %}

        <div class="nav-section">
            Intelligence Artificielle
        </div>

        {% if app.user.isPro() %}
            <a href="{{ path('app_ai') }}" {% if app.request.attributes.get('_route') starts with 'app_ai' %} class="active" {% endif %}>
                <span class="nav-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M8 1a3 3 0 0 1 3 3 2.5 2.5 0 0 1 2.5 2.5c0 .9-.47 1.68-1.18 2.12A3 3 0 0 1 11 11H5a3 3 0 0 1-1.32-5.38A2.5 2.5 0 0 1 6 4a3 3 0 0 1 2-3ZM6 13h4v1.5a.5.5 0 0 1-1 0V14H7v.5a.5.5 0 0 1-1 0V13Z" />
                    </svg>
                </span>
                Assistant IA
            </a>
        {% else %}
            <a href="{{ path('app_subscription_manage') }}" style="opacity:.35;" title="Réservé au plan Pro">
                <span class="nav-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M8 1a3.5 3.5 0 0 0-3.5 3.5V6H3v9h10V6h-1.5V4.5A3.5 3.5 0 0 0 8 1Zm2 5H6V4.5a2 2 0 1 1 4 0V6Z" />
                    </svg>
                </span>
                Assistant IA (Pro)
            </a>
        {% endif %}
    </nav>

    <!-- Footer utilisateur -->
    <div class="sidebar-footer">
        <div class="sidebar-user">
            <div class="user-avatar">
                {{ app.user.firstName|first|upper }}
                {{ app.user.lastName|first|upper }}
            </div>
            <div style="min-width:0; flex:1;">
                <div class="user-name">
                    {{ app.user.firstName }}
                    {{ app.user.lastName }}
                </div>
                <div class="user-links">
                    <a href="{{ path('app_profile') }}">
                        Profil
                    </a>
                    <span style="color:#c7d6e3">
                        ·
                    </span>
                    <a href="{{ path('app_subscription_manage') }}">
                        Abonnement
                    </a>
                    <span style="color:#c7d6e3">
                        ·
                    </span>
                    <a href="{{ path('app_logout') }}">
                        Déco
                    </a>
                </div>
            </div>
            {% if app.user.plan == 'pro' %}
                <span class="plan-chip plan-pro">
                    PRO
                </span>
            {% elseif app.user.plan == 'expert' %}
                <span class="plan-chip plan-expert">
                    EXPERT
                </span>
            {% else %}
                <span class="plan-chip plan-free">
                    GRATUIT
                </span>
            {% endif %}
        </div>
    </div>

</aside>
