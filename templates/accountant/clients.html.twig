{% extends 'accountant/base.html.twig' %}

{% block title %}Mes clients{% endblock %}
{% block breadcrumb %}Mes clients{% endblock %}

{% block body %}

{# ── Pre-compute counts for tabs ──────────────────────────────────── #}
{% set expertCount = clientsData|filter(i => i.user.plan == 'expert')|length %}
{% set proCount    = clientsData|filter(i => i.user.plan == 'pro' or i.user.plan == 'free')|length %}
{% set riskTabCount = clientsData|filter(i => i.risk != 'low')|length %}
{% set riskNames   = clientsData|filter(i => i.risk != 'low')|map(i => i.user.firstName ~ ' ' ~ i.user.lastName|slice(0,1) ~ '.')|join(' · ') %}

{# ── Page header ─────────────────────────────────────────────────── #}
<div class="ec-page-hd">
    <div>
        <div class="ec-page-sub">Cabinet · {{ clientsData|length }} mandats actifs</div>
        <div class="ec-page-title">Mes clients</div>
    </div>
    <div style="flex:1;"></div>
    <div style="display:flex;gap:8px;">
        <button type="button" class="ec-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Export liasse
        </button>
        <button type="button" class="ec-btn ec-btn-ghost">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
            Importer FEC
        </button>
        <a href="{{ path('expert_invite') }}" class="ec-btn ec-btn-primary">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Nouveau mandat
        </a>
    </div>
</div>

{# ── KPI row ─────────────────────────────────────────────────────── #}
<div class="ec-kpi-grid-4">

    <div class="ec-kpi">
        <div class="ec-kpi-label">
            CLIENTS ACTIFS
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--ec-accent)" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="ec-kpi-val">{{ clientsData|length }}</div>
        <div class="ec-kpi-sub">{{ expertCount }} Plan Expert · {{ proCount }} Pro</div>
    </div>

    <div class="ec-kpi">
        <div class="ec-kpi-label">
            CA CUMULÉ · {{ year }}
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--ec-fg)" stroke-width="1.8"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div class="ec-kpi-val" style="font-size:20px;">{{ (totalCa / 1000)|number_format(0, ',', ' ') }} <span style="font-size:16px;font-weight:500;color:var(--ec-muted);">k€</span></div>
        <div class="ec-kpi-sub">Tous mandats confondus</div>
    </div>

    <div class="ec-kpi {{ riskCount > 0 ? 'alert' }}">
        <div class="ec-kpi-label">
            RISQUE PLAFOND AE
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="{{ riskCount > 0 ? 'var(--ec-warm)' : 'var(--ec-muted)' }}" stroke-width="1.8"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
        </div>
        <div class="ec-kpi-val" style="{{ riskCount > 0 ? 'color:var(--ec-warm);' }}">{{ riskCount }}</div>
        <div class="ec-kpi-sub">{{ riskNames ?: 'Aucun client à risque' }}</div>
    </div>

    <div class="ec-kpi">
        <div class="ec-kpi-label">
            BILANS VALIDÉS YTD
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--ec-accent)" stroke-width="1.8"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div class="ec-kpi-val">{{ bilansYtd }}</div>
        <div class="ec-kpi-sub">↑ +28% vs {{ year - 1 }}</div>
    </div>

</div>

{# ── Pending invitations ───────────────────────────────────────────── #}
{% if pending is not empty %}
<div class="ec-panel" style="margin-bottom:14px;border-left:3px solid var(--ec-blue);">
    <div class="ec-panel-head">
        <div>
            <div class="ec-panel-title">Demandes en attente</div>
            <div class="ec-panel-sub">{{ pending|length }} client{{ pending|length != 1 ? 's' }} souhaitent rejoindre votre cabinet</div>
        </div>
        <span class="ec-tag-blue" style="font-size:11px;font-weight:700;">{{ pending|length }}</span>
    </div>
    {% for inv in pending %}
    <div class="ec-inv-item">
        <div class="ec-avatar ec-avatar-sm ec-av-blue">
            {{ inv.user.firstName|first|upper }}{{ inv.user.lastName|first|upper }}
        </div>
        <div style="flex:1;min-width:0;">
            <div style="font-size:12.5px;font-weight:700;color:var(--ec-fg);">{{ inv.user.firstName }} {{ inv.user.lastName }}</div>
            <div style="font-size:11px;color:var(--ec-muted);margin-top:1px;">{{ inv.user.email }}{% if inv.user.siret %} · SIRET {{ inv.user.siret }}{% endif %}</div>
        </div>
        <div style="font-size:11px;color:var(--ec-subtle);font-family:var(--font-mono);">{{ inv.createdAt|date('d/m/Y') }}</div>
        <div style="display:flex;gap:8px;">
            <form method="post" action="{{ path('expert_invitation_accept', {id: inv.id}) }}" style="display:inline;">
                <input type="hidden" name="_token" value="{{ csrf_token('inv_accept_' ~ inv.id) }}">
                <button type="submit" class="ec-btn ec-btn-xs ec-btn-primary">Accepter</button>
            </form>
            <form method="post" action="{{ path('expert_invitation_decline', {id: inv.id}) }}" style="display:inline;">
                <input type="hidden" name="_token" value="{{ csrf_token('inv_decline_' ~ inv.id) }}">
                <button type="submit" class="ec-btn ec-btn-xs ec-btn-ghost">Refuser</button>
            </form>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

{# ── Toolbar ──────────────────────────────────────────────────────── #}
<div class="ec-toolbar">
    <div style="display:flex;gap:3px;">
        <button class="ec-tab-btn active" onclick="filterClients(this,'all')">
            Tous <span style="font-size:10.5px;color:inherit;font-weight:600;">{{ clientsData|length }}</span>
        </button>
        <button class="ec-tab-btn" onclick="filterClients(this,'expert')">
            Plan Expert <span style="font-size:10.5px;color:var(--ec-muted);font-weight:600;">{{ expertCount }}</span>
        </button>
        <button class="ec-tab-btn" onclick="filterClients(this,'pro')">
            Plan Pro <span style="font-size:10.5px;color:var(--ec-muted);font-weight:600;">{{ proCount }}</span>
        </button>
        <button class="ec-tab-btn" onclick="filterClients(this,'risk')" style="{{ riskTabCount > 0 ? 'color:var(--ec-warm);' }}">
            <span style="width:5px;height:5px;border-radius:99px;background:var(--ec-warm);display:inline-block;"></span>
            À risque <span style="font-size:10.5px;color:var(--ec-warm);font-weight:600;">{{ riskTabCount }}</span>
        </button>
        <button class="ec-tab-btn" onclick="filterClients(this,'inactive')" style="color:var(--ec-muted);">
            Inactifs <span style="font-size:10.5px;color:var(--ec-muted);font-weight:600;">0</span>
        </button>
    </div>
    <div style="flex:1;"></div>
    <div class="ec-toolbar-search">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="text" id="client-search" placeholder="Nom, SIRET, ville…" oninput="searchClients(this.value)"
            style="border:none;background:transparent;font-size:11.5px;color:var(--ec-fg);font-family:inherit;outline:none;width:160px;">
    </div>
    <button type="button" class="ec-btn ec-btn-ghost ec-btn-sm">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
        3 filtres
    </button>
    <button type="button" class="ec-btn ec-btn-sm">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Vue dense
    </button>
</div>

{# ── Clients table ────────────────────────────────────────────────── #}
{% if clientsData is empty %}
<div class="ec-panel">
    <div class="ec-empty">
        <div style="font-size:32px;margin-bottom:12px;">👤</div>
        <div style="font-size:14px;font-weight:600;margin-bottom:4px;">Aucun client pour le moment</div>
        <div style="font-size:12px;">Les clients qui acceptent votre invitation apparaîtront ici.</div>
    </div>
</div>
{% else %}
<section style="background:var(--ec-card);border:1px solid var(--ec-bd);border-radius:12px;overflow:hidden;">
    <table class="ec-tbl" id="clients-table">
        <thead>
            <tr>
                <th style="width:32px;padding:8px 12px;">
                    <span style="width:15px;height:15px;border-radius:4px;border:1.5px solid var(--ec-subtle);display:inline-flex;"></span>
                </th>
                <th>Client</th>
                <th>Activité</th>
                <th class="r">CA {{ year }}</th>
                <th>Plafond</th>
                <th>Bilan {{ year - 1 }}</th>
                <th>Dernier contact</th>
                <th>Risque</th>
                <th class="r">Msg</th>
                <th>Plan</th>
                <th style="width:80px;"></th>
            </tr>
        </thead>
        <tbody>
        {% for item in clientsData %}
        {% set u = item.user %}
        {% set plafColor = item.risk == 'high' ? '#dc2626' : (item.risk == 'med' ? 'var(--ec-warm)' : 'var(--ec-accent)') %}
        <tr data-plan="{{ u.plan }}" data-risk="{{ item.risk }}" data-name="{{ u.firstName ~ ' ' ~ u.lastName|lower }}">
            <td>
                <span style="width:15px;height:15px;border-radius:4px;border:1.5px solid var(--ec-subtle);display:inline-flex;align-items:center;justify-content:center;"></span>
            </td>
            <td>
                <div style="display:flex;align-items:center;gap:9px;">
                    <div class="ec-avatar ec-avatar-sm ec-av-green">
                        {{ u.firstName|first|upper }}{{ u.lastName|first|upper }}
                    </div>
                    <div style="min-width:0;">
                        <div style="font-size:12.5px;font-weight:700;color:var(--ec-fg);">{{ u.firstName }} {{ u.lastName }}</div>
                        <div style="font-size:10px;color:var(--ec-subtle);font-family:var(--font-mono);">
                            {{ u.siret ? 'SIRET ' ~ u.siret : u.email }}
                        </div>
                    </div>
                </div>
            </td>
            <td class="mu">{{ u.activityLabel ?: '—' }}</td>
            <td class="r" style="font-weight:700;">{{ item.caYear|number_format(0, ',', ' ') }} €</td>
            <td>
                <div style="display:flex;align-items:center;gap:7px;min-width:110px;">
                    <div style="flex:1;height:4px;border-radius:99px;background:var(--ec-bd);overflow:hidden;">
                        <div style="width:{{ item.pct }}%;height:100%;background:{{ plafColor }};border-radius:99px;"></div>
                    </div>
                    <span style="font-size:10.5px;font-weight:700;color:{{ plafColor }};min-width:28px;font-variant-numeric:tabular-nums;">{{ item.pct }}%</span>
                </div>
            </td>
            <td>
                {% if item.latestBilan %}
                    {% set bs = item.latestBilan %}
                    {% if bs.status == 'validated' %}
                        <span class="ec-bilan-badge validated">Validé</span>
                    {% elseif bs.status == 'pending_review' %}
                        <span class="ec-bilan-badge pending_review">En attente</span>
                    {% elseif bs.status == 'annotated' %}
                        <span class="ec-bilan-badge annotated">Annoté</span>
                    {% else %}
                        <span class="ec-bilan-badge draft">En cours</span>
                    {% endif %}
                {% else %}
                    <span style="font-size:10.5px;color:var(--ec-muted);background:var(--ec-card2);padding:2px 8px;border-radius:5px;font-weight:600;">Pas démarré</span>
                {% endif %}
            </td>
            <td class="mu" style="font-size:11.5px;">
                {% if item.lastMsg %}
                    {{ item.lastMsg.createdAt|date('d/m/Y') }}
                {% elseif item.latestBilan %}
                    {{ item.latestBilan.createdAt|date('d/m/Y') }}
                {% else %}
                    —
                {% endif %}
            </td>
            <td>
                {% if item.risk == 'high' %}
                    <span class="ec-risk-badge high">
                        <span class="ec-risk-dot" style="background:#dc2626;"></span>Élevé
                    </span>
                {% elseif item.risk == 'med' %}
                    <span class="ec-risk-badge med">
                        <span class="ec-risk-dot" style="background:var(--ec-warm);"></span>Moyen
                    </span>
                {% else %}
                    <span class="ec-risk-badge low">
                        <span class="ec-risk-dot" style="background:var(--ec-accent);"></span>Faible
                    </span>
                {% endif %}
            </td>
            <td class="r">
                {% if item.msgCount > 0 %}
                    <span style="padding:1px 7px;border-radius:99px;background:rgba(37,99,235,.1);color:var(--ec-blue);font-size:10.5px;font-weight:700;font-variant-numeric:tabular-nums;">{{ item.msgCount }}</span>
                {% else %}
                    <span style="color:var(--ec-subtle);">0</span>
                {% endif %}
            </td>
            <td>
                {% if u.plan == 'expert' %}
                    <span class="ec-plan-expert">EXPERT</span>
                {% elseif u.plan == 'pro' %}
                    <span class="ec-plan-pro">PRO</span>
                {% else %}
                    <span class="ec-tag-gray" style="font-size:9.5px;font-weight:700;letter-spacing:.04em;">FREE</span>
                {% endif %}
            </td>
            <td>
                <div style="display:inline-flex;gap:4px;">
                    <a href="{{ path('expert_client_detail', {id: item.invitation.id}) }}" class="ec-icon-btn" title="Voir le client">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    </a>
                    {% if item.latestBilan %}
                    <a href="{{ path('expert_bilan_show', {id: item.latestBilan.id}) }}" class="ec-icon-btn" title="Voir le bilan">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    </a>
                    {% else %}
                    <button type="button" class="ec-icon-btn" disabled style="opacity:.35;cursor:default;">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    </button>
                    {% endif %}
                    <button type="button" class="ec-icon-btn" title="Plus d'actions">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
                    </button>
                </div>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
</section>
{% endif %}

{% endblock %}

{% block javascripts %}
<script>
let activeFilter = 'all';

function filterClients(btn, filter) {
    activeFilter = filter;
    document.querySelectorAll('.ec-tab-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    applyFilters();
}

function searchClients(query) {
    applyFilters(query.toLowerCase().trim());
}

function applyFilters(query) {
    if (query === undefined) {
        query = (document.getElementById('client-search')?.value || '').toLowerCase().trim();
    }
    const rows = document.querySelectorAll('#clients-table tbody tr');
    rows.forEach(row => {
        let show = true;
        if (activeFilter === 'expert') show = row.dataset.plan === 'expert';
        else if (activeFilter === 'pro')  show = (row.dataset.plan === 'pro' || row.dataset.plan === 'free');
        else if (activeFilter === 'risk') show = (row.dataset.risk === 'high' || row.dataset.risk === 'med');
        else if (activeFilter === 'inactive') show = false;

        if (show && query) {
            show = (row.dataset.name || '').includes(query);
        }
        row.style.display = show ? '' : 'none';
    });
}
</script>
{% endblock %}
