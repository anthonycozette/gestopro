{% extends 'accountant/base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}
{% block breadcrumb %}Tableau de bord{% endblock %}

{% block body %}

{# ── KPI row ─────────────────────────────────────────────────────── #}
<div class="ec-kpi-grid">

    <div class="ec-kpi {{ topbar_pending > 0 ? 'alert' }}">
        <div class="ec-kpi-label">BILANS À VALIDER</div>
        <div class="ec-kpi-val">{{ topbar_pending }}</div>
        <div class="ec-kpi-sub">{{ topbar_pending == 0 ? 'Aucun en attente' : (topbar_pending == 1 ? '1 bilan en file' : topbar_pending ~ ' bilans en file') }}</div>
    </div>

    <div class="ec-kpi {{ topbar_msgs > 0 ? 'alert' }}">
        <div class="ec-kpi-label">MESSAGES NON LUS</div>
        <div class="ec-kpi-val">{{ topbar_msgs }}</div>
        <div class="ec-kpi-sub">De vos clients</div>
    </div>

    <div class="ec-kpi">
        <div class="ec-kpi-label">VALIDÉS CE MOIS</div>
        <div class="ec-kpi-val">{{ validatedThisMonth }}</div>
        <div class="ec-kpi-sub">Bilans signés</div>
    </div>

    <div class="ec-kpi">
        <div class="ec-kpi-label">CLIENTS ACTIFS</div>
        <div class="ec-kpi-val">{{ topbar_clients }}</div>
        <div class="ec-kpi-sub">Portefeuille</div>
    </div>

    <div class="ec-kpi">
        <div class="ec-kpi-label">SLA SEMAINE</div>
        {% set sla = topbar_pending == 0 ? 100 : (topbar_pending <= 2 ? 96 : 88) %}
        <div class="ec-kpi-val">{{ sla }} <span style="font-size:16px;color:var(--ec-fg-muted);font-weight:500;">%</span></div>
        <div class="ec-kpi-sub">Taux de traitement</div>
    </div>

</div>

{# ── Main grid ────────────────────────────────────────────────────── #}
<div class="ec-dash-grid">

    {# Left column : queue + risk #}
    <div class="ec-col" style="flex:2;min-width:0;">

        {# Validation queue #}
        <div class="ec-panel">
            <div class="ec-panel-head">
                <span class="ec-panel-title">File de validation</span>
                {% if pendingBilans|length > 0 %}
                    <span class="ec-tag-orange">{{ pendingBilans|length }} en attente</span>
                {% else %}
                    <span class="ec-tag-green">File vide</span>
                {% endif %}
            </div>

            {% if pendingBilans is empty %}
            <div style="padding:32px;text-align:center;color:var(--ec-fg-muted);font-size:13px;">
                <div style="font-size:28px;margin-bottom:8px;">✓</div>
                Aucun bilan en attente de validation
            </div>
            {% else %}
            {% for item in pendingBilans %}
            {% set sheet = item.sheet %}
            {% set inv = item.invitation %}
            {% set age = item.ageHours %}
            <div class="ec-queue-row {{ age > 72 ? 'urgent' }}">
                <div class="ec-queue-idx">{{ loop.index }}</div>
                <div class="ec-avatar ec-avatar-sm ec-av-green">
                    {{ inv.user.firstName|first|upper }}{{ inv.user.lastName|first|upper }}
                </div>
                <div style="flex:1;min-width:0;">
                    <div style="font-size:13px;font-weight:600;color:var(--ec-fg);">
                        {{ inv.user.firstName }} {{ inv.user.lastName }}
                    </div>
                    <div style="font-size:11px;color:var(--ec-fg-muted);margin-top:2px;">
                        Bilan {{ sheet.period }}
                        <span style="margin:0 6px;opacity:.4;">·</span>
                        Soumis il y a {{ age < 24 ? age ~ 'h' : (age // 24) ~ 'j' }}
                    </div>
                </div>
                {% if age > 72 %}
                    <span class="ec-flag">URGENT</span>
                {% endif %}
                <div style="flex:1;max-width:160px;">
                    <div class="ec-prog-bar">
                        <div class="ec-prog-fill" style="width:{{ age > 168 ? 100 : (age / 168 * 100)|round }}%;background:{{ age > 72 ? 'var(--ec-warm)' : 'var(--ec-accent)' }};"></div>
                    </div>
                    <div style="font-size:10px;color:var(--ec-fg-muted);margin-top:3px;text-align:right;">
                        {{ age < 24 ? age ~ 'h / 7j' : (age // 24) ~ 'j / 7j' }}
                    </div>
                </div>
                <a href="{{ path('expert_bilan_show', {id: sheet.id}) }}" class="ec-btn ec-btn-xs ec-btn-primary">
                    Traiter →
                </a>
            </div>
            {% endfor %}
            {% endif %}
        </div>

        {# Risk alerts #}
        {% if riskAlerts is not empty %}
        <div class="ec-panel" style="margin-top:16px;">
            <div class="ec-panel-head">
                <span class="ec-panel-title">Alertes risque</span>
                <span class="ec-tag-orange">{{ riskAlerts|length }}</span>
            </div>
            {% for alert in riskAlerts %}
            <div class="ec-risk-row">
                <div style="flex:1;min-width:0;">
                    <div style="font-size:12px;font-weight:700;color:var(--ec-fg);">{{ alert.client }}</div>
                    <div style="font-size:11px;color:var(--ec-fg-muted);margin-top:2px;">{{ alert.detail }}</div>
                </div>
                <div style="text-align:right;">
                    <div style="font-size:11px;font-weight:700;color:{{ alert.color }};">{{ alert.delta }}</div>
                    <div style="font-size:10px;color:var(--ec-fg-muted);margin-top:1px;">{{ alert.type }}</div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

    </div>

    {# Right column : AI panel + activity #}
    <div class="ec-col" style="flex:1;min-width:260px;">

        {# Recent activity #}
        <div class="ec-panel" style="margin-top:16px;">
            <div class="ec-panel-head">
                <span class="ec-panel-title">Activité récente</span>
            </div>
            {% if recentActivity is empty %}
            <div style="padding:20px;text-align:center;color:var(--ec-fg-muted);font-size:12px;">Aucune activité récente</div>
            {% else %}
            <div style="padding:8px 0;">
            {% for ev in recentActivity %}
            <div style="display:flex;align-items:flex-start;gap:10px;padding:8px 16px;">
                <div style="width:6px;height:6px;border-radius:50%;margin-top:5px;flex-shrink:0;background:{{
                    ev.type starts with 'bilan_validated' ? 'var(--ec-accent)' :
                    (ev.type starts with 'bilan_pending' ? 'var(--ec-warm)' :
                    (ev.type == 'msg_client' ? '#6366f1' : 'var(--ec-fg-muted)'))
                }};"></div>
                <div style="min-width:0;flex:1;">
                    <div style="font-size:12px;color:var(--ec-fg);">
                        <strong>{{ ev.who }}</strong> {{ ev.text }}
                    </div>
                    <div style="font-size:10px;color:var(--ec-fg-muted);margin-top:2px;">
                        {{ ev.date|date('d/m/Y H:i') }}
                    </div>
                </div>
            </div>
            {% endfor %}
            </div>
            {% endif %}
        </div>

    </div>

</div>

{% endblock %}
