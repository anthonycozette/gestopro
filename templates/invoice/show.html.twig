{% extends 'base.html.twig' %}
{% block title %}{{ invoice.number }} — GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
  <h1>{{ invoice.number }}</h1>
  <div class="topbar-actions">
    {% if invoice.status == 'draft' %}
      <form method="post" action="{{ path('app_invoice_status', {id: invoice.id, status: 'sent'}) }}" style="display:inline">
        <input type="hidden" name="_token" value="{{ csrf_token('status_invoice_' ~ invoice.id) }}">
        <button type="submit" class="btn btn-primary">Marquer comme envoyée</button>
      </form>
    {% endif %}
    {% if invoice.status == 'sent' %}
      <form method="post" action="{{ path('app_invoice_status', {id: invoice.id, status: 'paid'}) }}" style="display:inline">
        <input type="hidden" name="_token" value="{{ csrf_token('status_invoice_' ~ invoice.id) }}">
        <button type="submit" class="btn btn-success">Marquer comme payée</button>
      </form>
    {% endif %}
    <a href="{{ path('app_invoice_pdf', {id: invoice.id}) }}" class="btn btn-secondary">Télécharger PDF</a>
    <a href="{{ path('app_invoice_edit', {id: invoice.id}) }}" class="btn btn-secondary">Modifier</a>
    <a href="{{ path('app_invoices') }}" class="btn btn-secondary">Retour</a>
  </div>
</div>
{% endblock %}

{% block body %}
<div style="display:grid; grid-template-columns:2fr 1fr; gap:20px; align-items:start;">
  <div>
    <div class="card">
      <div style="display:flex; justify-content:space-between; margin-bottom:20px;">
        <div>
          <div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.07em;margin-bottom:4px;">Client</div>
          <div style="font-size:15px;font-weight:600;color:#0f172a;">{{ invoice.client.name }}</div>
          {% if invoice.client.email %}<div style="color:#9ca3af;font-size:13px;margin-top:2px;">{{ invoice.client.email }}</div>{% endif %}
          {% if invoice.client.fullAddress %}<div style="color:#9ca3af;font-size:13px;">{{ invoice.client.fullAddress }}</div>{% endif %}
        </div>
        <div style="text-align:right;">
          <div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.07em;margin-bottom:4px;">Émise le</div>
          <div style="font-size:13.5px;color:#374151;">{{ invoice.issuedAt|date('d/m/Y') }}</div>
          {% if invoice.dueAt %}
          <div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.07em;margin-top:10px;margin-bottom:4px;">Échéance</div>
          <div style="font-size:13.5px;color:#374151;">{{ invoice.dueAt|date('d/m/Y') }}</div>
          {% endif %}
        </div>
      </div>

      <table>
        <thead>
          <tr>
            <th>Description</th>
            <th style="text-align:right">Qté</th>
            <th style="text-align:right">PU HT</th>
            <th style="text-align:right">TVA</th>
            <th style="text-align:right">Total HT</th>
          </tr>
        </thead>
        <tbody>
          {% for line in invoice.lines %}
          <tr>
            <td>{{ line.description }}</td>
            <td style="text-align:right"><span class="mono">{{ line.quantity }}</span></td>
            <td style="text-align:right"><span class="mono">{{ line.unitPrice|number_format(2, ',', ' ') }} €</span></td>
            <td style="text-align:right"><span class="mono">{{ line.tvaRate }} %</span></td>
            <td style="text-align:right"><strong class="mono">{{ line.totalHt|number_format(2, ',', ' ') }} €</strong></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>

      <div style="border-top:2px solid #e8eaed; margin-top:12px; padding-top:14px;">
        <div style="display:flex; justify-content:flex-end; gap:40px;">
          <div style="text-align:right; color:#9ca3af; font-size:13px; line-height:1.9;">
            <div>Total HT</div><div>TVA</div>
            <div style="color:#0f172a; font-weight:700; font-size:15px; margin-top:6px; border-top:1px solid #e8eaed; padding-top:6px;">Total TTC</div>
          </div>
          <div style="text-align:right; min-width:120px; line-height:1.9;">
            <div class="mono" style="font-size:13px; color:#374151;">{{ invoice.totalHt|number_format(2, ',', ' ') }} €</div>
            <div class="mono" style="font-size:13px; color:#374151;">{{ invoice.totalTva|number_format(2, ',', ' ') }} €</div>
            <div class="mono" style="font-size:15px; font-weight:700; margin-top:6px; border-top:1px solid #e8eaed; padding-top:6px;">{{ invoice.totalTtc|number_format(2, ',', ' ') }} €</div>
          </div>
        </div>
      </div>

      {% if invoice.notes %}
      <div style="margin-top:16px; padding-top:12px; border-top:1px solid #f1f3f5; color:#9ca3af; font-size:13px; line-height:1.6;">
        {{ invoice.notes }}
      </div>
      {% endif %}
    </div>
  </div>

  <div>
    <div class="card">
      <div class="card-title">Statut</div>
      <div style="margin-bottom:16px;">
        {% if invoice.status == 'paid' %}<span class="st-badge st-paid" style="font-size:13px;padding:5px 12px;">Payée</span>
        {% elseif invoice.status == 'sent' %}<span class="st-badge st-sent" style="font-size:13px;padding:5px 12px;">Envoyée</span>
        {% elseif invoice.status == 'overdue' %}<span class="st-badge st-late" style="font-size:13px;padding:5px 12px;">En retard</span>
        {% elseif invoice.status == 'draft' %}<span class="st-badge st-draft" style="font-size:13px;padding:5px 12px;">Brouillon</span>
        {% elseif invoice.status == 'cancelled' %}<span class="st-badge st-cancel" style="font-size:13px;padding:5px 12px;">Annulée</span>
        {% endif %}
      </div>

      {% if invoice.paidAt %}
      <div style="font-size:13px; color:#9ca3af; margin-bottom:12px;">
        Payée le {{ invoice.paidAt|date('d/m/Y') }}
      </div>
      {% endif %}

      <div style="border-top:1px solid #f1f3f5; padding-top:12px; margin-top:4px;">
        <form method="post" action="{{ path('app_invoice_delete', {id: invoice.id}) }}"
              onsubmit="return confirm('Supprimer cette facture définitivement ?')">
          <input type="hidden" name="_token" value="{{ csrf_token('delete_invoice_' ~ invoice.id) }}">
          <button type="submit" class="btn btn-danger btn-sm" style="width:100%">Supprimer</button>
        </form>
      </div>
    </div>
  </div>
</div>
{% endblock %}
