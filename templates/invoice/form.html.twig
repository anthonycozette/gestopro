{% extends 'base.html.twig' %}
{% block title %}{{ title }} — GestoPro{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/invoices.css') }}">
{% endblock %}

{% block topbar %}
<div class="topbar">
    <div>
        <a href="{{ path('app_invoices') }}" style="display:inline-flex;align-items:center;gap:5px;font-size:12px;color:#6b7280;font-weight:500;text-decoration:none;margin-bottom:5px;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
            Factures
        </a>
        <h1>{{ title }}</h1>
    </div>
</div>
{% endblock %}

{% block body %}
<form method="post" id="invoice-form">
{% if error %}<div class="alert alert-error" style="margin-bottom:16px;">{{ error }}</div>{% endif %}

{# ── Action bar ─── #}
<div class="inv-form-bar">
    <span class="inv-autosave-chip">
        <span class="inv-autosave-dot"></span>
        Brouillon
    </span>
    <div style="flex:1;"></div>
    <a href="{{ path('app_invoices') }}" class="btn btn-secondary">Annuler</a>
    {% if invoice.id %}
    <a href="{{ path('app_invoice_pdf', {id: invoice.id}) }}" class="btn btn-secondary" style="display:inline-flex;align-items:center;gap:7px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/></svg>
        Aperçu PDF
    </a>
    {% endif %}
    <button type="submit" name="action" value="draft" class="btn btn-secondary">Enregistrer le brouillon</button>
    <button type="submit" name="action" value="send" class="btn btn-primary" style="display:inline-flex;align-items:center;gap:7px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
        Envoyer la facture
    </button>
</div>

<div class="inv-form-layout">

    {# ── Left: form sections ─── #}
    <div>

        {# Informations #}
        <div class="inv-section">
            <div class="inv-section-title">Informations</div>
            <div class="inv-section-sub">Le numéro est généré automatiquement à l'envoi.</div>

            <div class="form-grid">
                <div class="form-group">
                    <label>Numéro
                        <span style="font-size:11px;color:#9ca3af;font-weight:400;margin-left:6px;">Auto · {{ invoice.number ?: 'prochain à l\'envoi' }}</span>
                    </label>
                    <input type="text" class="form-control" value="{{ invoice.number }}" disabled style="font-family:ui-monospace,monospace;background:#f3f5f8;color:#8a93a3;">
                </div>
                <div class="form-group">
                    <label>Type</label>
                    <div style="display:flex;padding:3px;background:#f3f5f8;border-radius:9px;gap:2px;">
                        {% for t in [['invoice','Facture'],['quote','Devis'],['credit','Avoir']] %}
                        <label style="flex:1;text-align:center;">
                            <input type="radio" name="type" value="{{ t[0] }}" {% if invoice.type == t[0] or (not invoice.type and t[0] == 'invoice') %}checked{% endif %} style="display:none;" class="type-radio">
                            <span class="type-seg-btn" data-val="{{ t[0] }}" style="display:block;padding:6px 10px;border-radius:7px;font-size:12.5px;font-weight:600;cursor:pointer;color:#5b6573;transition:background .12s,color .12s;">{{ t[1] }}</span>
                        </label>
                        {% endfor %}
                    </div>
                </div>
                <div class="form-group">
                    <label>Date d'émission</label>
                    <input type="date" name="issued_at" class="form-control"
                           value="{{ invoice.issuedAt ? invoice.issuedAt|date('Y-m-d') : 'now'|date('Y-m-d') }}">
                </div>
                <div class="form-group">
                    <label>Date d'échéance
                        <span style="font-size:11px;color:#9ca3af;font-weight:400;margin-left:6px;">Calculée automatiquement</span>
                    </label>
                    <input type="date" name="due_at" class="form-control"
                           value="{{ invoice.dueAt ? invoice.dueAt|date('Y-m-d') : '' }}">
                </div>
            </div>
        </div>

        {# Client #}
        <div class="inv-section">
            <div class="inv-section-title">Client</div>
            <div class="inv-section-sub">Cherche un client existant ou ajoute-en un nouveau.</div>

            {% set avatarColors = ['#e53935','#8e24aa','#1e88e5','#00897b','#43a047','#fb8c00','#6d4c41','#546e7a'] %}

            {% if invoice.client %}
            {% set avatarBg = avatarColors[(invoice.client.name|length) % 8] %}
            <div class="inv-client-card" id="client-card">
                <span class="avatar avatar-md" style="background:{{ avatarBg }};">
                    {{ invoice.client.name|first|upper }}{{ invoice.client.name|split(' ')|last|first|upper }}
                </span>
                <div style="flex:1;min-width:0;">
                    <div class="inv-client-card-name">{{ invoice.client.name }}</div>
                    <div class="inv-client-card-sub">
                        {% if invoice.client.siret %}SIRET {{ invoice.client.siret }} · {% endif %}
                        {{ invoice.client.invoices|length }} facture{{ invoice.client.invoices|length != 1 ? 's' : '' }}
                    </div>
                </div>
                <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('client-select-wrap').style.display='block';document.getElementById('client-card').style.display='none';">Changer</button>
            </div>
            <div id="client-select-wrap" style="display:none;">
            {% else %}
            <div id="client-select-wrap">
            {% endif %}
                <select name="client_id" class="form-control" required id="client-select">
                    <option value="">— Sélectionner un client —</option>
                    {% for client in clients %}
                    <option value="{{ client.id }}"
                            data-name="{{ client.name }}"
                            data-siret="{{ client.siret }}"
                            {% if invoice.client and invoice.client.id == client.id %}selected{% endif %}>
                        {{ client.name }}{% if client.siret %} · {{ client.siret }}{% endif %}
                    </option>
                    {% endfor %}
                </select>
                <a href="{{ path('app_client_new') }}" class="btn btn-secondary btn-sm" style="margin-top:8px;display:inline-flex;align-items:center;gap:6px;">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                    Nouveau client
                </a>
            </div>
        </div>

        {# Prestations #}
        <div class="inv-section">
            <div class="inv-section-title">Prestations</div>
            <div class="inv-section-sub">Ajoute autant de lignes que tu veux. Total calculé en direct.</div>

            <div class="lines-table-wrap">
                <table class="lines-table" id="lines-table">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th style="text-align:right;width:70px;">Qté</th>
                            <th style="text-align:right;width:110px;">P.U. HT</th>
                            <th style="text-align:right;width:75px;">TVA %</th>
                            <th style="text-align:right;width:110px;">Total HT</th>
                            <th style="width:36px;"></th>
                        </tr>
                    </thead>
                    <tbody id="lines-body">
                        {% if invoice.lines is empty %}
                            {{ _self.lineRow(0, '', '1', '0.00', '20') }}
                        {% else %}
                            {% for i, line in invoice.lines %}
                                {{ _self.lineRow(i, line.description, line.quantity, line.unitPrice, line.tvaRate) }}
                            {% endfor %}
                        {% endif %}
                    </tbody>
                </table>
                <div style="padding:10px 14px;background:#fbfcfd;border-top:1px solid #e6e8ee;">
                    <button type="button" onclick="addLine()" class="btn-add-line">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                        Ajouter une prestation
                    </button>
                </div>
            </div>
        </div>

        {# Conditions & note #}
        <div class="inv-section">
            <div class="inv-section-title">Conditions &amp; note</div>
            <div class="inv-section-sub">Ce qui apparaîtra en bas de la facture.</div>

            <div class="form-grid" style="margin-bottom:14px;">
                <div class="form-group">
                    <label>Conditions de paiement</label>
                    <select name="payment_conditions" class="form-control">
                        {% set conds = ['Net 30 jours · Virement','Net 15 jours · Virement','Net 7 jours · Virement','Paiement à réception','Net 60 jours'] %}
                        <option value="">—</option>
                        {% for c in conds %}
                        <option value="{{ c }}" {% if invoice.paymentConditions == c %}selected{% endif %}>{{ c }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-group">
                    <label>Devise</label>
                    <select name="currency" class="form-control" id="currency-select" onchange="updateCurrencySymbol()">
                        <option value="EUR" {% if invoice.currency == 'EUR' or not invoice.currency %}selected{% endif %}>€ EUR — Euro</option>
                        <option value="USD" {% if invoice.currency == 'USD' %}selected{% endif %}>$ USD — Dollar</option>
                        <option value="GBP" {% if invoice.currency == 'GBP' %}selected{% endif %}>£ GBP — Livre sterling</option>
                        <option value="CHF" {% if invoice.currency == 'CHF' %}selected{% endif %}>CHF — Franc suisse</option>
                        <option value="CAD" {% if invoice.currency == 'CAD' %}selected{% endif %}>$ CAD — Dollar canadien</option>
                    </select>
                </div>
            </div>
            <div class="form-group" style="margin-bottom:0;">
                <label>Note libre <span style="font-size:11px;color:#9ca3af;font-weight:400;">(optionnel)</span></label>
                <textarea name="notes" class="form-control" rows="3"
                          placeholder="Merci de votre confiance. Conditions de paiement, mentions légales…">{{ invoice.notes }}</textarea>
            </div>
        </div>

    </div>

    {# ── Right sidebar ─── #}
    <div style="position:sticky;top:16px;display:flex;flex-direction:column;gap:14px;">

        {# Totaux #}
        <div class="inv-totals-panel">
            <div class="inv-panel-title">Totaux</div>
            <div class="form-totals-row">
                <span>Sous-total HT</span>
                <span class="val" id="total-ht">0,00 €</span>
            </div>
            <div class="form-totals-row">
                <span>TVA</span>
                <span class="val" id="total-tva" style="color:#2563eb;">0,00 €</span>
            </div>
            <div class="form-totals-grand">
                <span class="form-totals-grand-label">Total TTC</span>
                <span class="form-totals-grand-val" id="total-ttc">0,00 €</span>
            </div>
            <button type="submit" name="action" value="draft" class="btn btn-primary" style="width:100%;margin-top:14px;">
                Enregistrer
            </button>
        </div>

        {# Aperçu PDF #}
        <div class="pdf-preview-card">
            <div class="pdf-preview-title">Aperçu</div>
            <div class="pdf-thumb" style="font-size:14px;flex-direction:column;gap:8px;padding:12px;">
                <div style="width:100%;display:flex;justify-content:space-between;align-items:flex-start;">
                    <div>
                        <div style="font-size:7px;color:#8a93a3;font-weight:700;letter-spacing:.06em;">FACTURE</div>
                        <div style="font-size:14px;font-weight:700;color:#1c1a17;">{{ invoice.number ?: '—' }}</div>
                    </div>
                    <div style="width:18px;height:18px;border-radius:5px;background:linear-gradient(135deg,#2563eb,#ea580c);color:#fff;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;">G</div>
                </div>
                <div style="width:100%;">
                    <div style="height:4px;width:55%;background:#e5e7eb;border-radius:2px;margin-bottom:3px;"></div>
                    <div style="height:3px;width:38%;background:#eef0f3;border-radius:2px;"></div>
                </div>
                <div style="width:100%;margin-top:4px;">
                    {% for w in [80,55,70] %}
                    <div style="display:flex;align-items:center;gap:6px;padding:4px 0;{% if not loop.first %}border-top:1px solid #e6e8ee;{% endif %}">
                        <div style="flex:1;height:3px;background:#e5e7eb;border-radius:2px;max-width:{{ w }}%;"></div>
                        <div style="height:3px;width:24px;background:#cbd5e1;border-radius:2px;"></div>
                    </div>
                    {% endfor %}
                </div>
                <div style="width:100%;margin-top:auto;padding:5px 8px;border-radius:4px;background:rgba(37,99,235,.08);display:flex;justify-content:space-between;align-items:center;">
                    <span style="font-size:7px;color:#2563eb;font-weight:700;letter-spacing:.04em;">TOTAL TTC</span>
                    <span id="preview-ttc" style="font-size:11px;font-weight:700;color:#2563eb;font-variant-numeric:tabular-nums;">0 €</span>
                </div>
            </div>
            {% if invoice.id %}
            <a href="{{ path('app_invoice_pdf', {id: invoice.id}) }}" class="btn btn-secondary btn-sm" style="width:100%;justify-content:center;">↓ Télécharger</a>
            {% else %}
            <p style="font-size:11px;color:#9ca3af;text-align:center;margin:0;">Disponible après enregistrement</p>
            {% endif %}
        </div>

        {# Suggestion IA #}
        {% if app.user.plan in ['pro', 'expert'] %}
        <div class="inv-ai-card">
            <svg class="inv-ai-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M5.6 18.4l2.8-2.8M15.6 8.4l2.8-2.8"/></svg>
            <div class="inv-ai-text">
                <strong>Suggestion IA · </strong>
                Pensez à vérifier l'exactitude du SIRET client avant d'envoyer — obligatoire pour les professionnels.
            </div>
        </div>
        {% endif %}

    </div>
</div>
</form>

{% macro lineRow(i, desc, qty, price, tva) %}
<tr class="line-row">
    <td>
        <input type="text" name="description[]" class="form-control"
               value="{{ desc }}" placeholder="Description de la prestation"
               oninput="recalculate()" required>
    </td>
    <td>
        <input type="number" name="quantity[]" class="form-control line-qty"
               value="{{ qty }}" min="0.01" step="0.01" oninput="recalculate()"
               style="text-align:right;">
    </td>
    <td>
        <input type="number" name="unit_price[]" class="form-control line-price"
               value="{{ price }}" min="0" step="0.01" oninput="recalculate()"
               style="text-align:right;">
    </td>
    <td>
        <input type="number" name="tva_rate[]" class="form-control line-tva"
               value="{{ tva }}" min="0" max="100" step="0.1" oninput="recalculate()"
               style="text-align:right;">
    </td>
    <td class="line-total-cell"><span class="line-total">0,00 €</span></td>
    <td style="text-align:center;">
        <button type="button" onclick="removeLine(this)" class="btn-remove-line">✕</button>
    </td>
</tr>
{% endmacro %}
{% endblock %}

{% block javascripts %}
<script src="{{ asset('js/invoice-lines.js') }}"></script>
<script>
// Sync preview TTC
const origRecalc = window.recalculate;
window.recalculate = function() {
    if (origRecalc) origRecalc();
    const el = document.getElementById('preview-ttc');
    const ttc = document.getElementById('total-ttc');
    if (el && ttc) el.textContent = ttc.textContent;
};

// Type segment buttons
document.querySelectorAll('.type-seg-btn').forEach(btn => {
    const radio = btn.previousElementSibling;
    function update() {
        document.querySelectorAll('.type-seg-btn').forEach(b => {
            b.style.background = 'transparent'; b.style.color = '#5b6573';
        });
        if (radio.checked) { btn.style.background = '#fff'; btn.style.color = '#1c1a17'; btn.style.boxShadow = '0 1px 2px rgba(20,40,80,.08)'; }
    }
    btn.addEventListener('click', () => { radio.checked = true; document.querySelectorAll('.type-seg-btn').forEach(b => { b.style.background='transparent'; b.style.color='#5b6573'; b.style.boxShadow='none'; }); btn.style.background='#fff'; btn.style.color='#1c1a17'; btn.style.boxShadow='0 1px 2px rgba(20,40,80,.08)'; });
    if (radio.checked) update();
});

setTimeout(() => { if (window.recalculate) window.recalculate(); }, 100);
</script>
{% endblock %}
