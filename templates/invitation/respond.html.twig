{% extends 'base.html.twig' %}
{% block title %}Invitation — GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>Invitation Expert-Comptable</h1>
</div>
{% endblock %}

{% block body %}
<div style="max-width:520px;margin:0 auto;">
    <div class="card">
        {% if invitation.expired %}
            <div class="alert alert-error">Cette invitation a expiré.</div>
        {% elseif invitation.status == 'accepted' %}
            <div class="alert" style="background:#dcfce7;border:1px solid #86efac;color:#166534;">
                Vous avez déjà accepté cette invitation.
            </div>
        {% elseif invitation.status == 'declined' %}
            <div class="alert alert-error">Vous avez refusé cette invitation.</div>
        {% else %}
            <div style="margin-bottom:24px;">
                <div style="font-size:13px;color:#6b7280;margin-bottom:4px;">Invitation de</div>
                <div style="font-size:20px;font-weight:700;">{{ invitation.accountant.fullName }}</div>
                {% if invitation.accountant.firm %}
                    <div style="font-size:14px;color:#6b7280;">{{ invitation.accountant.firm }}</div>
                {% endif %}
                {% if invitation.accountant.registrationNumber %}
                    <div style="font-size:12px;color:#9ca3af;margin-top:4px;">N° inscription : {{ invitation.accountant.registrationNumber }}</div>
                {% endif %}
            </div>

            <p style="font-size:14px;color:#374151;line-height:1.7;margin-bottom:24px;">
                Cet expert-comptable souhaite vous accompagner sur GestoPro.
                En acceptant, il pourra consulter, annoter et valider vos bilans comptables.
                Vos données restent privées — il n'accède qu'aux bilans que vous lui soumettez.
            </p>

            <div style="font-size:12px;color:#9ca3af;margin-bottom:20px;">
                Expire le {{ invitation.expiresAt|date('d/m/Y') }}
            </div>

            <div style="display:flex;gap:12px;">
                <form method="post" action="{{ path('app_invitation_accept', {token: invitation.token}) }}" style="flex:1;">
                    <input type="hidden" name="_token" value="{{ csrf_token('invitation_' ~ invitation.token) }}">
                    <button type="submit" class="btn btn-success" style="width:100%;padding:10px;">
                        ✓ Accepter
                    </button>
                </form>
                <form method="post" action="{{ path('app_invitation_decline', {token: invitation.token}) }}" style="flex:1;">
                    <input type="hidden" name="_token" value="{{ csrf_token('invitation_' ~ invitation.token) }}">
                    <button type="submit" class="btn btn-secondary" style="width:100%;padding:10px;">
                        Refuser
                    </button>
                </form>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
