{% extends 'base.html.twig' %}
{% block title %}{{ client.name }} — GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>{{ client.name }}</h1>
    <div class="topbar-actions">
        <a href="{{ path('app_client_edit', {id: client.id}) }}" class="btn btn-secondary">Modifier</a>
        <a href="{{ path('app_clients') }}" class="btn btn-secondary">Retour</a>
    </div>
</div>
{% endblock %}

{% block body %}
<div style="display:grid; grid-template-columns:1fr 2fr; gap:20px;">

    <div>
        <div class="card">
            <div class="card-title">Informations</div>
            <div style="display:flex;flex-direction:column;gap:12px;">
                {% if client.email %}
                <div><div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.07em;margin-bottom:3px;">Email</div><div style="font-size:13.5px;color:#374151;">{{ client.email }}</div></div>
                {% endif %}
                {% if client.phone %}
                <div><div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.07em;margin-bottom:3px;">Téléphone</div><div style="font-size:13.5px;color:#374151;">{{ client.phone }}</div></div>
                {% endif %}
                {% if client.siret %}
                <div><div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.07em;margin-bottom:3px;">SIRET</div><div class="mono" style="font-size:13px;color:#374151;">{{ client.siret }}</div></div>
                {% endif %}
                {% if client.address %}
                <div><div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.07em;margin-bottom:3px;">Adresse</div><div style="font-size:13.5px;color:#374151;">{{ client.fullAddress }}</div></div>
                {% endif %}
                <div><div style="font-size:11px;color:#9ca3af;text-transform:uppercase;letter-spacing:.07em;margin-bottom:3px;">Client depuis</div><div style="font-size:13.5px;color:#374151;">{{ client.createdAt|date('d/m/Y') }}</div></div>
            </div>
        </div>
    </div>

    <div>
        <div class="card">
            <div class="card-title">Factures ({{ client.invoices|length }})</div>
            {% if client.invoices is empty %}
                <p style="color:#6b7280; font-size:14px;">Aucune facture pour ce client.</p>
            {% else %}
                <table>
                    <thead>
                        <tr>
                            <th>Numéro</th>
                            <th>Date</th>
                            <th>Montant TTC</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for invoice in client.invoices %}
                        <tr>
                            <td><a href="{{ path('app_invoice_show', {id: invoice.id}) }}">{{ invoice.number }}</a></td>
                            <td>{{ invoice.issuedAt|date('d/m/Y') }}</td>
                            <td>{{ invoice.totalTtc|number_format(2, ',', ' ') }} €</td>
                            <td>
                                {% if invoice.status == 'paid' %}<span class="st-badge st-paid">Payée</span>
                                {% elseif invoice.status == 'sent' %}<span class="st-badge st-sent">Envoyée</span>
                                {% elseif invoice.status == 'overdue' %}<span class="st-badge st-late">En retard</span>
                                {% elseif invoice.status == 'draft' %}<span class="st-badge st-draft">Brouillon</span>
                                {% else %}<span class="st-badge st-draft">{{ invoice.status }}</span>{% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
