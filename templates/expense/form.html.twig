{% extends 'base.html.twig' %}
{% block title %}{{ title }} — GestoPro{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/expenses.css') }}">
{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>{{ title }}</h1>
    <div class="topbar-actions">
        <a href="{{ path('app_expenses') }}" class="btn btn-secondary">Annuler</a>
    </div>
</div>
{% endblock %}

{% block body %}
<form method="post">
    {% if error %}<div class="alert alert-error">{{ error }}</div>{% endif %}

    <div style="display:grid; grid-template-columns:2fr 1fr; gap:20px; align-items:start;">

        <div>
            <div class="card">
                <div class="card-title">Informations de la dépense</div>

                <div class="form-group">
                    <label>Fournisseur <span style="color:#ef4444">*</span></label>
                    <input type="text" name="vendor" class="form-control"
                           value="{{ expense.vendor }}" placeholder="Ex : SNCF, Amazon, Adobe…" required autofocus>
                </div>

                <div class="form-grid">
                    <div class="form-group">
                        <label>Date <span style="color:#ef4444">*</span></label>
                        <input type="date" name="date" class="form-control"
                               value="{{ expense.date ? expense.date|date('Y-m-d') : 'now'|date('Y-m-d') }}" required>
                    </div>
                    <div class="form-group">
                        <label>Catégorie</label>
                        <select name="category_id" class="form-control">
                            <option value="">— Sans catégorie —</option>
                            {% for cat in categories %}
                                <option value="{{ cat.id }}"
                                    {% if expense.category and expense.category.id == cat.id %}selected{% endif %}>
                                    {{ cat.label }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Notes</label>
                    <textarea name="notes" class="form-control" rows="2"
                              placeholder="Détails, numéro de facture fournisseur…">{{ expense.notes }}</textarea>
                </div>

                <div class="form-group">
                    <label>Mode de paiement</label>
                    <select name="payment_method" class="form-control">
                        <option value="">— Non précisé —</option>
                        <option value="carte"       {% if expense.paymentMethod == 'carte' %}selected{% endif %}>Carte bancaire</option>
                        <option value="especes"     {% if expense.paymentMethod == 'especes' %}selected{% endif %}>Espèces</option>
                        <option value="virement"    {% if expense.paymentMethod == 'virement' %}selected{% endif %}>Virement</option>
                        <option value="cheque"      {% if expense.paymentMethod == 'cheque' %}selected{% endif %}>Chèque</option>
                        <option value="prelevement" {% if expense.paymentMethod == 'prelevement' %}selected{% endif %}>Prélèvement</option>
                    </select>
                </div>
            </div>
        </div>

        <div>
            <div class="card">
                <div class="card-title">Montant</div>

                <div class="form-group">
                    <label>Montant TTC <span style="color:#ef4444">*</span></label>
                    <div style="position:relative;">
                        <input type="number" name="amount_ttc" id="amount-ttc" class="form-control"
                               value="{{ expense.amountTtc != '0.00' ? expense.amountTtc : '' }}"
                               min="0" step="0.01" placeholder="0,00" oninput="recalc()" required
                               style="padding-right:32px; font-family:'JetBrains Mono',monospace;">
                        <span style="position:absolute;right:11px;top:50%;transform:translateY(-50%);color:#6b7280;font-size:13px;">€</span>
                    </div>
                </div>

                <div class="form-group">
                    <label>Taux de TVA</label>
                    <select name="tva_rate" id="tva-rate" class="form-control" onchange="recalc()">
                        <option value="0"   {% if expense.tvaRate == '0.00' or expense.tvaRate == '0' %}selected{% endif %}>0 % (exonéré)</option>
                        <option value="5.5" {% if expense.tvaRate == '5.50' %}selected{% endif %}>5,5 %</option>
                        <option value="10"  {% if expense.tvaRate == '10.00' %}selected{% endif %}>10 %</option>
                        <option value="20"  {% if expense.tvaRate == '20.00' or (expense.id is null) %}selected{% endif %}>20 %</option>
                    </select>
                </div>

                <div class="expense-totals">
                    <div class="expense-totals-row">
                        <span>Montant HT</span>
                        <span id="display-ht" class="mono">{{ expense.amountHt|number_format(2, ',', ' ') }} €</span>
                    </div>
                    <div class="expense-totals-row">
                        <span>TVA</span>
                        <span id="display-tva" class="mono" style="color:#2563eb;">{{ expense.tva|number_format(2, ',', ' ') }} €</span>
                    </div>
                    <div class="expense-totals-row">
                        <span>Total TTC</span>
                        <span id="display-ttc" class="mono">{{ expense.amountTtc|number_format(2, ',', ' ') }} €</span>
                    </div>
                </div>

                <div class="form-group" style="margin-bottom:4px;">
                    <label style="display:flex; align-items:center; gap:9px; cursor:pointer; font-size:13px;">
                        <input type="checkbox" name="deductible" value="1"
                               {% if expense.id is null or expense.deductible %}checked{% endif %}
                               style="width:16px;height:16px;accent-color:#2563eb;">
                        <span>Dépense déductible</span>
                    </label>
                </div>

                <button type="submit" class="btn btn-primary" style="width:100%;margin-top:16px;">
                    Enregistrer
                </button>
            </div>
        </div>

    </div>
</form>
{% endblock %}

{% block javascripts %}
<script src="{{ asset('js/expense-form.js') }}"></script>
{% endblock %}
