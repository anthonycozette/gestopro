{% extends 'base.html.twig' %}
{% block title %}{{ expense.vendor }} — GestoPro{% endblock %}

{% block topbar %}
<div class="topbar">
    <h1>{{ expense.vendor }}</h1>
    <div class="topbar-actions">
        <a href="{{ path('app_expense_edit', {id: expense.id}) }}" class="btn btn-secondary">Modifier</a>
        <a href="{{ path('app_expenses') }}" class="btn btn-secondary">Retour</a>
    </div>
</div>
{% endblock %}

{% block body %}
<div style="display:grid; grid-template-columns:2fr 1fr; gap:20px; align-items:start;">

    <div class="card">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:24px;">
            <div>
                <div style="font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px;">Fournisseur</div>
                <div style="font-size:16px;font-weight:600;">{{ expense.vendor }}</div>
            </div>
            <div>
                <div style="font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px;">Date</div>
                <div style="font-size:16px;">{{ expense.date|date('d/m/Y') }}</div>
            </div>
            <div>
                <div style="font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px;">Catégorie</div>
                <div>
                    {% if expense.category %}
                        <span class="badge badge-gray">{{ expense.category.label }}</span>
                    {% else %}
                        <span style="color:#9ca3af">Non catégorisée</span>
                    {% endif %}
                </div>
            </div>
            <div>
                <div style="font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px;">Mode de paiement</div>
                <div>{{ expense.paymentMethod ?: '—' }}</div>
            </div>
        </div>

        <div style="border-top:2px solid #e5e7eb; padding-top:16px;">
            <div style="display:flex; justify-content:flex-end;">
                <table style="width:260px;">
                    <tr>
                        <td style="color:#6b7280; font-size:13px; padding:4px 0;">Montant HT</td>
                        <td style="text-align:right; font-size:13px;">{{ expense.amountHt|number_format(2, ',', ' ') }} €</td>
                    </tr>
                    <tr>
                        <td style="color:#6b7280; font-size:13px; padding:4px 0;">TVA ({{ expense.tvaRate }} %)</td>
                        <td style="text-align:right; font-size:13px;">{{ expense.tva|number_format(2, ',', ' ') }} €</td>
                    </tr>
                    <tr style="border-top:2px solid #1e40af;">
                        <td style="font-weight:700; font-size:16px; padding-top:8px;">Total TTC</td>
                        <td style="text-align:right; font-weight:700; font-size:16px; padding-top:8px;">{{ expense.amountTtc|number_format(2, ',', ' ') }} €</td>
                    </tr>
                </table>
            </div>
        </div>

        {% if expense.notes %}
        <div style="margin-top:16px; padding-top:12px; border-top:1px solid #e5e7eb; color:#6b7280; font-size:13px;">
            {{ expense.notes }}
        </div>
        {% endif %}
    </div>

    <div>
        {# Justificatif #}
        <div class="card" style="margin-bottom:0;">
            <div class="card-title">Justificatif</div>

            {% if expense.receiptPath %}
            <div style="display:flex;align-items:center;gap:10px;padding:10px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:6px;margin-bottom:12px;">
                <span style="font-size:20px;">📎</span>
                <div style="flex:1;min-width:0;">
                    <div style="font-size:13px;font-weight:500;color:#15803d;margin-bottom:2px;">Justificatif joint</div>
                    <a href="{{ path('app_expense_receipt', {id: expense.id}) }}" target="_blank"
                       class="btn btn-secondary btn-sm">Voir le fichier</a>
                </div>
            </div>
            <form method="post" action="{{ path('app_expense_receipt_delete', {id: expense.id}) }}"
                  data-confirm="Supprimer le justificatif ?" data-confirm-variant="danger"
                  style="margin-top:8px;">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_receipt_' ~ expense.id) }}">
                <button type="submit" class="btn btn-danger btn-sm" style="width:100%;">Supprimer le justificatif</button>
            </form>
            {% else %}
            <div style="text-align:center;padding:20px;color:#9ca3af;font-size:13px;">
                <div style="font-size:24px;margin-bottom:6px;">📂</div>
                Aucun justificatif<br>
                <a href="{{ path('app_expense_edit', {id: expense.id}) }}" style="color:#2563eb;font-size:12px;margin-top:4px;display:inline-block;">Ajouter depuis la modification</a>
            </div>
            {% endif %}
        </div>

        <div class="card">
            <div class="card-title">Déductibilité</div>
            <div style="margin-bottom:16px;">
                {% if expense.deductible %}
                    <span class="badge badge-green" style="font-size:13px;padding:4px 12px;">Déductible</span>
                {% else %}
                    <span class="badge badge-gray" style="font-size:13px;padding:4px 12px;">Non déductible</span>
                {% endif %}
            </div>

            {% if expense.ocrConfidence is not null %}
            <div style="margin-top:12px; padding-top:12px; border-top:1px solid #e5e7eb;">
                <div style="font-size:12px; color:#6b7280; margin-bottom:6px;">Confiance OCR</div>
                {% set level = expense.ocrConfidenceLevel %}
                {% if level == 'high' %}
                    <span class="badge badge-green">{{ (expense.ocrConfidence * 100)|round }}% — Élevée</span>
                {% elseif level == 'medium' %}
                    <span class="badge badge-yellow">{{ (expense.ocrConfidence * 100)|round }}% — Moyenne</span>
                {% else %}
                    <span class="badge badge-red">{{ (expense.ocrConfidence * 100)|round }}% — Faible</span>
                {% endif %}
                {% if expense.ocrVerified %}
                    <div style="font-size:11px; color:#16a34a; margin-top:6px;">✓ Données vérifiées</div>
                {% endif %}
            </div>
            {% endif %}

            <div style="margin-top:16px; border-top:1px solid #e5e7eb; padding-top:12px;">
                <form method="post" action="{{ path('app_expense_delete', {id: expense.id}) }}"
                      data-confirm="Supprimer cette dépense ?" data-confirm-variant="danger">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_expense_' ~ expense.id) }}">
                    <button type="submit" class="btn btn-danger btn-sm" style="width:100%">Supprimer</button>
                </form>
            </div>
        </div>
    </div>

</div>
{% endblock %}
